;-------------------------------------------
; Increase blue bar filling rate for var(7)
[State 0, VarAdd]
type = Varadd
triggerall = fVar(23) >= 0
triggerall = fVar(23) <= 1000
triggerall = var(7) = 0
trigger1 = timemod = 1,0
fv = 23
value = IFELSE(VAR(5) = 1,1.7,1.5)

; Increase purple bar filling rate for var(5)
[State 0, VarAdd]
type = Varadd
triggerall = fVar(25) >= 0
triggerall = fVar(25) <= 1000
triggerall = var(5) = 0
trigger1 = timemod = 1,0
fv = 25
value = IFELSE(VAR(7) = 1,1.3,0.5) ; Increase the values to make it fill faster

[State 0, VarAdd]
type = Varadd
triggerall = fVar(23) > 0
triggerall = var(7) = 1
trigger1 = movehit = 1
fv = 23 ;fv = 10
value = 10

[State 0, VarAdd]
type = Varadd
triggerall = fVar(25) > 0
triggerall = var(5) = 1
trigger1 = movehit = 1
fv = 25  ;fv = 10
value = 10

; DECREASE BLUE AFTER ACTIVATED
[State 0, VarAdd]
type = Varadd
triggerall = fVar(23) > 0
triggerall = var(7) = 1
triggerall = stateno != [550,551]
triggerall = stateno != 6010
trigger1 = time%2 = 0
fv = 23
value = IFELSE(life <= lifemax*0.5,-2,-1.4)

; DECREASE PURPLE AFTER ACTIVATED
[State 0, VarAdd]
type = Varadd
triggerall = fVar(25) > 0
triggerall = var(5) = 1
triggerall = stateno != [555,556]
triggerall = stateno != 6010
trigger1 = time%2 = 0
fv = 25
value = -1 ;IFELSE(VAR(7) = 1,-0.5,-0.8)

; revert from blue
[State 0, Vuelta a la Normalidad]
type = ChangeState
triggerall = var(7) = 1
triggerall = stateno != 551
triggerall = statetype = S || statetype = C || statetype = A || stateno = 5101
triggerall = fVar(23) <= 0
triggerall = roundstate = 2
trigger1 = 1
value = 551

;revert from purple
[State 0, Vuelta a la Normalidad]
type = ChangeState
triggerall = var(5) = 1
triggerall = stateno != 556
triggerall = statetype = S || statetype = C || statetype = A || stateno = 5101
triggerall = fVar(25) <= 0
triggerall = roundstate = 2
trigger1 = 1
value = 556