; Invisible - Escudo Invisible (State 60006)
[Statedef 60006]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 60006
sprpriority = 2

; Prevent hits when helper(60000) is in state 60004
[State 0, NotHitBy]
type = NotHitBy
triggerall = numhelper(60000) > 0 ; Ensure helper 60000 exists
trigger1 = helper(60000),stateno = 60004
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1

; Set position relative to helper(60000)
[State 0, BindToRoot]
type = posset
trigger1 = numhelper(60000) > 0 ; Ensure helper 60000 exists
x = helper(60000),pos x - 1

; Set default position if helper(60000) does not exist
[State 0, BindToRootFallback]
type = posset
trigger1 = numhelper(60000) = 0
x = 0 ; Default position

[State 0, DefenceMulSet]
type = DefenceMulSet
trigger1 = 1
value = 1.2

[State 0, Width]
type = Width
trigger1 = 1
player = 20,20

[State 0, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = 60007
time = 10

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0

[State 200, End]
type = DestroySelf
trigger1 = root,FVar(30) = 0

