;-------------------------------------------------------------------------------
; bar
[Statedef 60008]
type = S
physics = S
juggle = 1
velset = 0,0
ctrl = 0
anim = 9999
sprpriority = 2

; Check if the helper 60000 exists before using its position
[State 0, BindToRoot]
type = posset
trigger1 = numhelper(60000) > 0 ; Ensure helper 60000 exists
x = helper(60000),pos x - 1

[State 0, BindToRootFallback]
type = posset
trigger1 = numhelper(60000) = 0 ; If helper 60000 does not exist
x = 0 ; Default position or some fallback value

; Ensure FVar(30) conditions before creating Explods
[State 0, Explod1]
type = Explod
triggerall = numhelper(60000) > 0 ; Ensure helper 60000 exists
triggerall = root,FVar(30) != 0
triggerall = root,FVar(30) > 0
triggerall = root,FVar(30) <= 1000
trigger1 = 1
anim = 90000
ID = 4444
pos = 10, -150
postype = P1
removetime = -2
ontop = 1
scale = .055, .055
ownpal = 1
facing = ifelse(teamside = 2, -1, 1)
ignorehitpause = 1
sprpriority = 9999
priority = 9999

[State 0, Explod2]
type = Explod
triggerall = numhelper(60000) > 0 ; Ensure helper 60000 exists
triggerall = root,FVar(30) != 0
triggerall = root,FVar(30) > 0
triggerall = root,FVar(30) <= 1000
trigger1 = 1
anim = 90006
ID = 4444
pos = 10, -150
postype = P1
removetime = -2
ontop = 1
scale = -root,FVar(30) * .000331, .055
ownpal = 1
facing = ifelse(teamside = 2, -1, 1)
ignorehitpause = 1
sprpriority = 9999
priority = 9999

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0

[State 200, End]
type = DestroySelf
trigger1 = root,FVar(30) = 0

