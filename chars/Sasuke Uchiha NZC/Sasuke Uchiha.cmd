;===========================================================================
;---------------------------Basicos-----------------------------------------
;---------------------------------------------------------------------------
; Correr Adelante
[State -1, Correr Adelante]
type = ChangeState
triggerall = stateno != 2060
triggerall = stateno != 2070
value = 2060
trigger1 = command = "FF"
trigger1 = ctrl
;---------------------------------------------------------------------------
[State -1, Super Jump]
type = ChangeState
value = 80
trigger1 = command = "Super Jump"
trigger1 = statetype = S
trigger1 = ctrl
;---------------------------------------------------------------------------
; Correr Atras
[State -1, Correr Atras]
type = ChangeState
triggerall = stateno != 2060
triggerall = stateno != 2070
value = 2070
trigger1 = command = "BB"
trigger1 = ctrl
;===========================================================================
; Jutsu:
;===========================================================================
; Chidori
[State -1, Chidori]
type = ChangeState
Triggerall = power >= 1000
value = 1000
triggerall = command = "SPECIAL 1"
Triggerall = statetype != A
trigger1 = ctrl
;--------------------------------------------------------------------------- 
; Katon Gokakyu no Jutsu
[State -1, Katon Gokakyu no Jutsu]
type = ChangeState
Triggerall = var(4) = 0
Triggerall = numhelper(1150) = 0
Triggerall = numhelper(1190) = 0
Triggerall = power >= 1000
value = ifelse(statetype = A,1180,1100)
triggerall = command = "SPECIAL 2"
trigger1 = ctrl
trigger2 = numhelper(700) > 0
;---------------------------------------------------------------------------
; Chidori Zembon
[State -1, Chidori Zembon]
type = ChangeState
Triggerall = numhelper(1250) = 0
Triggerall = power >= 500
value = 1200
Triggerall = command = "SPECIAL 3"
Triggerall = statetype != A
trigger1 = ctrl
trigger2 = numhelper(700) > 0
;--------------------------------------------------------------------------- 
; Genjutsu : Sharingan
[State -1, Genjutsu : Sharingan]
type = ChangeState
Triggerall = power >= 500
value = 1300
triggerall = command = "SPECIAL 4"
Triggerall = statetype != A
trigger1 = ctrl
;---------------------------------------------------------------------------
; Chidori Eiso
[State -1, Chidori Eiso]
type = ChangeState
Triggerall = power >= 1500
value = 1400
triggerall = command = "SPECIAL 5"
Triggerall = statetype != A
trigger1 = ctrl
;--------------------------------------------------------------------------- 
[State -1, Chidori Nagashi]
type = ChangeState
Triggerall = numhelper(1550) = 0
Triggerall = power >= 1000
value = 1500
triggerall = command = "SPECIAL 6"
triggerall = statetype != A
trigger1 = ctrl
trigger2 = numhelper(700) > 0
;===============================================================================
; Ultimate Jutsu
;===============================================================================
; Kirin
[State -1, Kirin]
type = ChangeState
Triggerall = numhelper(2040) = 0
Triggerall = power >= 2500
value = 2000
triggerall = command = "holddown"
triggerall = command = "c"
Triggerall = statetype != A
trigger1 = ctrl
trigger2 = numhelper(700) > 0
[State -1, Kirin]
type = ChangeState
Triggerall = numhelper(2040) = 1
value = 2002
triggerall = command = "holddown"
triggerall = command = "c"
triggerall = statetype != A
trigger1 = ctrl
trigger2 = numhelper(700) > 0
;===========================================================================
;--------------------------------Ataques Normales---------------------------
;---------------------------------------------------------------------------
; Power Charge
[State -1, Power Charge]
type = ChangeState
triggerall = power < powermax
value = 500
triggerall = command = "s"
Triggerall = statetype != A
trigger1 = ctrl
;---------------------------------------------------------------------------
; Combo 1
[State -1, Combo 1]
type = ChangeState
value = 200
triggerall = command = "a"
Triggerall = statetype != A
trigger1 = ctrl
;---------------------------------------------------------------------------
; Combo 2
[State -1, Combo 2]
type = ChangeState
value = 300
triggerall = command = "b"
Triggerall = statetype != A
trigger1 = ctrl
;---------------------------------------------------------------------------
; Shuriken
[State -1, Shuriken]
type = ChangeState
Triggerall = power >= 100
value = ifelse(statetype = A,630,400)
triggerall = command = "c"
trigger1 = ctrl
;---------------------------------------------------------------------------
; Air Combo
[State -1, Air Combo]
type = ChangeState
value = 600
triggerall = command = "a" || command = "b"
Triggerall = statetype = A
trigger1 = ctrl
;---------------------------------------------------------------------------
; Kawarimi
[State -1, Kawarimi]
type = ChangeState
triggerall = var(6) < 5
triggerall = numhelper(60003) = 0
value = 66000
triggerall = command = "x"
trigger1 = statetype = S
trigger1 = ctrl
