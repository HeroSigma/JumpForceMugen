trigger4 = root,stateno = [3001,3005]
trigger5 = root,movetype = H && (root,stateno != [5000,5150]) && enemynear,hitdefattr=SCA,HA,HP,HT
id = 4016
ignorehitpause = 1
[State 0, RemoveExplod]
