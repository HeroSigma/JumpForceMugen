[Statedef -2]

[State 0, Run]
type = ChangeState
triggerall = var(5) = 0
triggerall = var(2) = 0
triggerall = stateno != 60
triggerall = stateno != 70
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/5
value = ifelse(pos y >= 0,60,70)

[State 0, Power Charge]
type = ChangeState
triggerall = statetype != A
triggerall = var(2) = 0
