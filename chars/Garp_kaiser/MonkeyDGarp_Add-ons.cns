;===============================================================================
;----- Stun Bar ----------------------------------------------------------------
;===============================================================================
[Statedef 8300]
type    = A
physics = N
velset = 0,0
anim = 8299
ctrl = 0
sprpriority = -1



[State 0, VarSet]; Contador del Stun cuando llega a 68 Stunea
type = VarSet
trigger1 = time = 0
trigger2 = Parent, stateno = 5400 ;Reset del contador cuando se entra en stun
v = 20
value = 0
[State 0, VarAdd]; Contador de dańo para sumar a la barra (equivale a 748 de dańo continuo)
type = VarAdd
triggerall = Parent, stateno = 5000 || Parent, stateno = 5010 || Parent, stateno = 5020 || (Parent, stateno = 5030) && (parent, prevstateno != [5000,5050])
triggerall = Parent, stateno != 5400
triggerall = var(22) != [1,30]; para que no sume barra de stun mientras lo golpean en el Stun
trigger1 = parent, time = 1
v = 20
value = (parent, var(23))
[State 0, VarAdd]; Ritmo de Enfriamiento
type = VarAdd
triggerall = var(21) > 15 ;Tiempo para que comience el Enfriamiento
triggerall = var(20) > 0
trigger1 = time%20 = 0
v = 20
value = -1

[State 0, VarSet] ;Contador para que comience el Enfriamiento
type = VarSet
triggerall = Parent, stateno = [5000,5030]
trigger1 = parent, time = 1
v = 21
value = 0
[State 0, VarAdd]
type = VarAdd
trigger1 = time%10 = 0
v = 21
value = 1



[State 0, VarSet] ;Certificados de cumplimiento de todo el Ciclo
type = VarSet
trigger1 = time = 0
trigger2 = Parent, stateno = [5000,5050]
trigger2 = var(22) >= 30
v = 22
value = 0
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
triggerall = var(22) = 0
trigger1 = var(20) > 67
v = 22
value = 1
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
triggerall = var(22) = 1
trigger1 = parent, stateno = 5400
v = 22
value = 2
ignorehitpause = 1
[State 0, VarAdd] ; con esto da margen para que empiece a sumar la barra luego del stun
type = VarAdd
triggerall = var(22) >= 2
triggerall = var(22) <= 29
trigger1 = time%15 = 0
v = 22
value = 1

[State 3290, DestroySelf]
type = DestroySelf
trigger1 = Roundstate != [2,4]


