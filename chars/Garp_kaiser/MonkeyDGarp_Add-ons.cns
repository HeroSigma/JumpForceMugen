;----- Guard Bar ----------------------------------------------------------------
;===============================================================================
[Statedef 8400]
type    = A
physics = N
velset = 0,0
anim = 8299
ctrl = 0
sprpriority = -1


[State 0, VarSet]; Contador del Guard cuando llega a 0 se quiebra la Guardia
type = VarSet
trigger1 = time = 0
trigger2 = var(32) >= 30 ;Reset del contador cuando se entra el Guard Break
v = 30
value = 68
[State 0, VarAdd]; Contador de desgaste para quitar a la Guard Bar
type = VarAdd
triggerall = Parent, stateno = 150 || Parent, stateno = 152 || Parent, stateno = 154
triggerall = Parent, stateno != 160 || Parent, stateno != 161
triggerall = var(30) > 0
trigger1 = parent, time = 2
v = 30
value = -(parent, var(33))*ifelse(numhelper(8561)=1,0,1)
; el helper 8561 es para que no gaste barra de guard si se realiza un Instant Block
[State 0, VarAdd]; Ritmo de recuperación
type = VarAdd
triggerall = var(31) > 20 ;Tiempo para que comience la Recuperación
triggerall = var(30) < 68
triggerall = var(32) < 3
trigger1 = time%15 = 0
v = 30
value = 1

[State 0, VarSet] ;Contador para que comience el Recuperación
type = VarSet
triggerall = Parent, stateno = [150,155]
trigger1 = parent, time = 1
v = 31
value = 0
[State 0, VarAdd]
type = VarAdd
trigger1 = time%5 = 0
v = 31
value = 1



[State 0, VarSet] ;Certificados de cumplimiento de todo el Ciclo
type = VarSet
trigger1 = time = 0
trigger2 = Parent, stateno = [150,155]
trigger2 = var(32) >= 30
v = 32
value = 0
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
triggerall = var(32) = 0
trigger1 = var(30) <= 0
v = 32
value = 1
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
triggerall = var(32) = 1
trigger1 = parent, stateno = 160
trigger2 = parent, stateno = 161
v = 32
value = 2
ignorehitpause = 1
[State 0, VarAdd] ; Este es el tiempo que dura el Guard Break (y el personaje no se puede defender)
type = VarAdd
triggerall = var(32) = [2,29]
trigger1 = time%20 = 0
v = 32
value = 1

[State 3290, DestroySelf]
type = DestroySelf
trigger1 = Roundstate != [2,4]



