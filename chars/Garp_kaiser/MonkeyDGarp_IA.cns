;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------




[Statedef -3]

[State 0, PowerAdd]
type = PowerAdd
triggerall = stateno != [3000,3900]
triggerall = time%10 = 0
trigger1 = movehit
value = 10
ignorehitpause = 0


[State 0, Stand Air Fix]
type = ChangeState
triggerall = stateno = [0,20]
triggerall = statetype != A
trigger1 = pos y < 0
value = 50
ctrl = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = stateno = 100
trigger2 = prevstateno = 100
flag = noautoturn



