;===============================================================================
; Scoring Hits System - Based on RajaaBoy System -------------------------------
;===============================================================================
; Reset Score at Beginning of Match
[State -3, Reset Score]
type = varset
triggerall = Var(50) > 0
triggerall = RoundState = [0,1]
trigger1 = !time && !roundsexisted
var(50) = 0 + 0 * (var(56) := 0)

; Increase Score on Movehit (Change Triggers and Parameters Accordingly)
[State -3, Increase Score - on Basic hits]
type = varadd
triggerall = stateno = [200,699]
trigger1 = movehit = 1 && var(56) = 0
trigger2 = movehit != 1 && var(56) = 0
trigger2 = enemy, stateno = 5000 || enemy, stateno = 5010 || enemy, stateno = 5020 || enemy, stateno = 5030
trigger2 = enemy, time = 0
var(50) = ifelse(hitcount > 0,floor(100/HitCount),100)

[State -3, Increase Score - on Specials hits]
type = varadd
triggerall = stateno = [1000,2999]
trigger1 = movehit = 1 && var(56) = 0
trigger2 = movehit != 1 && var(56) = 0
trigger2 = enemy, stateno = 5000 || enemy, stateno = 5010 || enemy, stateno = 5020 || enemy, stateno = 5030
trigger2 = enemy, time = 0
var(50) = ifelse(hitcount > 0,floor(200/HitCount),200)

[State -3, Increase Score - on Supers hits]
type = varadd
triggerall = stateno = [3000,3299]
trigger1 = movehit = 1 && var(56) = 0
trigger2 = movehit != 1 && var(56) = 0
trigger2 = enemy, stateno = 5000 || enemy, stateno = 5010 || enemy, stateno = 5020 || enemy, stateno = 5030
trigger2 = enemy, time = 0
var(50) = ifelse(hitcount > 0,floor(300/HitCount),300)



[State -3, Increase Score - on Supers lvl Max hits]
type = varadd
triggerall = stateno = [3300,3999]
trigger1 = movehit = 1 && var(56) = 0
trigger2 = movehit != 1 && var(56) = 0
trigger2 = enemy, stateno = 5000 || enemy, stateno = 5010 || enemy, stateno = 5020 || enemy, stateno = 5030
trigger2 = enemy, time = 0
var(50) = ifelse(hitcount > 0,floor(1000/HitCount),1000)
; ceil(50/hitcount) es para dividir los puntos según la cantidad de hits, pero no funciona con helpers...

[State -3, Increase Score]; Super Roll
type = varadd
trigger1 = stateno = 705  && time = 1
trigger2 = stateno = 715  && time = 1
var(50) = 250


; Decrease Score on Gethit (Change Triggers and Parameters Accordingly)
[State -3, Decrease Score]
type = varadd
trigger1 = movetype = H && !hitover && stateno = [5000, 5199]
trigger1 = gethitvar(hitshaketime) && time <= 1 && var(56) = 0
var(50) = -50
[State -3, Decrease Score]  ; Guard Break
type = varadd
trigger1 = stateno = 160  && time = 1
var(50) = -200
[State -3, Decrease Score]  ; Stun
type = varadd
trigger1 = stateno = 5400  && time = 1
var(50) = -500

; Allow the above state controllers to be activated again
[State -3, Reset Controller Limiter]
type = varset
trigger1 = 1
var(56) = 0

; This limits the state controllers above to activating only during the tick that the score is changed.
; This state controller should contain the same triggers used to increase AND decrease var(0).
[State -3, Controller Limiter]
type = varset
trigger1 = movehit = 1 && var(56) = 0
trigger2 = movetype = H && !hitover && stateno = [5000, 5199]
trigger2 = gethitvar(hitshaketime) && time <= 1 && var(56) = 0
trigger3 = movehit != 1 && var(56) = 0
trigger3 = enemy, stateno = 5000 || enemy, stateno = 5010 || enemy, stateno = 5020 || enemy, stateno = 5030
trigger3 = enemy, time = 0
var(56) = 1


;---- Prevent Score from Going out of Bounds --------

; Keep Score bewteen 0 and 999,999,999
[State -3, Limit Score]
type = varset
trigger1 = var(50) != [0, 99999]
var(50) = cond(var(50) > 99999, 99999, 0)

;---- Detect Place Values -----------------------------

[State -3, Score For Ones Place]
type = varset
trigger1 = 1
var(51) = floor(var(50) / 1) % 10 ; * 1 ; uncomment to get exact amount of ones
[State -3, Score For Tens Place]
type = varset
trigger1 = 1
var(52) = floor(var(50) / 10) % 10 ; * 10 ; uncomment to get exact amount of tens
[State -3, Score For Hundreds Place]
type = varset
trigger1 = 1
var(53) = floor(var(50) / 100) % 10 ; * 100 ; uncomment to get exact amount of hundreds
[State -3, Score For Thousands Place]
type = varset
trigger1 = 1
var(54) = floor(var(50) / 1000) % 10 ; * 1000 ; uncomment to get exact amount of thousands
[State -3, Score For Ten Thousands Place]
type = varset
trigger1 = 1
var(55) = floor(var(50) / 10000) % 10 ; * 1000 ; uncomment to get exact amount of thousands




