triggerall = RoundState = [0,1]
trigger1 = time && !roundsexisted
fvar(30) = 0

; Keep Score bewteen 0 and 9999
[State -3, Limit Objetives Score]
type = varset
trigger1 = floor(fvar(30) != [0, 9999])
fvar(30) = cond(fvar(30) > 9999, 9999, 0)

