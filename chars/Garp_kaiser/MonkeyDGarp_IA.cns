;===============================================================================
; Counter Hit Notification  (Taken from Vans, who based his on Sander's Method)

[State -3, VarSet];Checks if opponent is in attack state
type = VarSet
triggerall = numenemy
trigger1 = enemy, movetype = A
var(36) = 1
ignorehitpause = 1

[State -3, Increase Objetives Score]; Counter Hit
type = varadd
triggerall = enemy, movetype = h
trigger1 = var(36) = 1 && movehit  ;Move hit, Ok
trigger2 = var(36) = 1 && projhit = 1 ;Projectile hit, Ok
fvar(30) = 50
ignorehitpause = 1
persistent = 0

[State -3, VarSet];This resets the condition if counter not succesful and succesful
type = VarSet
triggerall = numenemy
trigger1 = enemy, movetype = I || var(37) >= 1  ;Enemy is Idle | Counter was Succesful
trigger2 = var(37) > 10 && enemy, movetype = H  ;10 ticks passed & enemy is on gethit state
var(36) = 0
ignorehitpause = 1

[State -3, VarSet];Counter Hit Succesful
type = VarSet
trigger1 = var(36) = 1 && movehit ;Counter Check Ok, Move Hit Succesfully.
trigger1 = stateno != [190,199] ;Does not activate during intros.
trigger2 = var(36) = 1 && projhit = 1  ;Counter Check Ok, Projectile Hit Succesfully.
var(37) = 1
ignorehitpause = 1

[State -3, VarAdd];Counter Hit Timer
type = VarAdd
trigger1 = var(37) >= 1 ;Counter was succesful
var(37) = 1
ignorehitpause = 1

[State -3, VarSet];Counter Hit Reset
type = VarSet
trigger1 = var(37) >= 22 && movehit ;Reset if 22 ticks passed and move hit
trigger2 = p2movetype != H ;Reset if P2 is no longer in gethit state
trigger3 = movetype = H ;Reset if P1 is getting hit
trigger4 = var(37) >= 22 && projhit = 1 ;Reset if 22 ticks passed and projectile hit
var(37) = 0
ignorehitpause = 1

[State -3, AssertSpecial];This will award free juggles for Counter Hit.
type = AssertSpecial
trigger1 = var(37) > 0
flag = nojugglecheck



[State -3, Pause] ; Pausa cuando entra el Counter
type = Pause
triggerall = enemy, movetype = h ;Enemy was indeed HIT, otherwise this'd be retarded.
trigger1 = var(36) = 1 && movehit  ;Move hit, Ok
trigger2 = var(36) = 1 && projhit = 1 ;Projectile hit, Ok
time = 5
movetime = 0
ignorehitpause = 1

[State -3, EnvShake] ; Envshake cuando entra el Counter
type = EnvShake
triggerall = enemy, movetype = h ;Enemy was indeed HIT, otherwise this'd be retarded.
trigger1 = var(36) = 1 && movehit  ;Move hit, Ok
trigger2 = var(36) = 1 && projhit = 1 ;Projectile hit, Ok
time = 5
freq = 120
ampl = -2
phase = 90
ignorehitpause = 1


[State -3, Explod];Counter Explod for P1 Side.
type = Explod
triggerall = numenemy
triggerall = var(36) = 1 && numexplod(8511) = 0 && teamside = 1 ;Counter Ok, Explod has not played, P1 Side
triggerall = enemy, movetype = h ;Enemy was indeed HIT, otherwise this'd be retarded.
trigger1 = movehit ;Move hits
trigger2 = projhit = 1 ;Projectile Hits
anim = 8511
pos = 45,ifelse((numexplod(8501) || numexplod(8561)),65,85)
postype = left  ;p2,front,back,left,right
removetime = 103
supermove = 1
scale = 0.5,0.5
sprpriority = -3
id = 8511
bindtime = -1
ontop = 0
ownpal = 1
ignorehitpause = 1
pausemovetime = -1

[State -3, Explod];Counter Explod for P2 Side.
type = Explod
triggerall = numenemy
triggerall = var(36) = 1 && numexplod(8512) = 0 && teamside = 2 ;Counter Ok, Explod has not played, P2 Side
triggerall = enemy, movetype = h ;Enemy was indeed HIT, otherwise this'd be retarded.
trigger1 = movehit ;Move hits
trigger2 = projhit = 1 ;Projectile Hits
anim = 8512
pos = -45,ifelse((numexplod(8501) || numexplod(8561)),65,85)
postype = right  ;p2,front,back,left,right
removetime = 103
supermove = 1
scale = 0.5,0.5
sprpriority = -3
id = 8512
bindtime = -1
ontop = 0
ownpal = 1
ignorehitpause = 1
pausemovetime = -1


