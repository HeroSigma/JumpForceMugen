[Statedef -2]
;===========================================================================
;Palette:
;===========================================================================
[State 0, RemapPal] ; BASE
type = RemapPal
trigger1 = var(2) = 0
source = 1,1 ; NO CAMBIAR
dest = 1,1 ; CAMBIAR

[State 0, RemapPal] ; SSJ
type = RemapPal
trigger1 = var(2) = 1
source = 1,1 ; NO CAMBIAR
dest = 1,2 ; CAMBIAR

[State 0, RemapPal] ; SSB
