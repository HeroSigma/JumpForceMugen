; Urahara DESpawn
[Statedef 4101]
type    = A
movetype= I
physics = N
juggle  = 0
Velset = -3,-8
ctrl = 0
anim = 4100
poweradd = 0
sprpriority = 3

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 1
ignorehitpause = 1
[State 0, NotHitBy]
type = NotHitBy
trigger1 = !time||1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
ignorehitpause = 1


[State 0, VelSet]
type = VelSet
triggerall = time >= 5
trigger1 = vel y >=0
x = 0
y = -.1
ignorehitpause = 1

[State 0, Gravity]
type = Gravity
trigger1 = 1
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
trigger1 = 1
x = -5*parent,backedgedist*.02
ignorehitpause = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0
movecamera = 0,0
ignorehitpause = 1

[State 0, DestroySelf]
type = DestroySelf
triggerall = !numhelper(4510)
trigger1 = backedgedist < -60
ignorehitpause = 1
removeexplods = 1
