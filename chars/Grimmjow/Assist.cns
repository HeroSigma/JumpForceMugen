; Urahara Spawn
[Statedef 4100]
type    = A
movetype= I
physics = N
juggle  = 0
Velset = 3,0
ctrl = 0 
anim = 4100
poweradd = 0 
sprpriority = 3

[State 0, Voz]
type = null
trigger1 = !time
value = S10,4
channel = 5
volumescale = 600

[State 0, ParentVarSet]
type = ParentVarSet
trigger1 = 1
v = 55
value = 0
ignorehitpause = 1

[State 0, Gravity]
type = Gravity
trigger1 = 1
ignorehitpause = 1
[State 0, VelAdd]
type = VelAdd
trigger1 = time >0
x = 0
y = .22
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
trigger1 = 1
x = cond(rootdist x*1.1,.2*(rootdist x+(40*const(size.xscale)))*.92,2+(rootdist x+(40*const(size.xscale)))*.92);cond(rootdist x*1.1,.2*rootdist x*.6,2+rootdist x*.5)
ignorehitpause = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0
movecamera = 0,0
ignorehitpause = 1

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
ignorehitpause = 1
[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 1
ignorehitpause = 1

[State 4100, End]
type = ChangeState
trigger1 = pos Y >= -6
value = 4105
ctrl = 0
