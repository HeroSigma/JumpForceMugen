;===============================================================================
; ASSIST SYSTEM:
;-------------------------------------------------------------------------------
[Statedef 4000]
type    = A
movetype= I
physics = N
anim = 9999
ctrl = 0

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = 0
ignorehitpause = 1

;---------------------------------- Var System

[State 0, Game Start]
type = VarSet
trigger1 = !time 
v = 55
value = cond(roundstate=2,cond(roundno = 1,100,20),255)
ignorehitpause = 1
[State 0, Game Start]
type = VarSet
trigger1 = roundstate = 2
v = 55
value = cond(roundno = 1,100,20)
ignorehitpause = 1
persistent = 0

[State 0, Assist Ready]
type = VarSet
trigger1 = var(55) >= 255
v = 55   
value = 256
[State 0, Assist Cooldown]
type = VarAdd
triggerall = !numhelper(4100) 
triggerall = time
triggerall = timemod = 2,0;3,0
trigger1 = var(55) = [0,255]
v = 55   
value = 1  ;1

[State 0, Summon PLAYER Normal]
type = VarSet
;triggerall = root,pos y > -1000;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(19) = 0
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
trigger1 = root,command = "y"
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA Urahara|Riruka Normal]
type = VarSet
triggerall = !((p2stateno = 4719)&&(p2movetype=H))
triggerall = !(p2stateno =1819&&p2movetype=H)
triggerall = var(58) = 1||var(58)= 7
triggerall = root,pos y > -30;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(19) = 0
triggerall = gametime > 300
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
triggerall = !root,movecontact
trigger1= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(9-cond((root,stateno = 1510&&root,movehit&&time>30),9,0))
trigger1= root,p2bodydist x = [0,255]
trigger1= enemynear,pos y>= -const(size.height)
trigger1= enemynear,statetype != L
trigger1= enemynear,vel x > -.7
trigger1= root,vel x < 8
trigger2= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)/(18-cond((enemynear,stateno = 500),16,0))
trigger2= root,p2bodydist x = [0,385]
trigger2= root,stateno = 500
trigger2= enemynear,statetype != L
trigger3= random < (root,ailevel * 100+enemy, gethitvar(hitcount)*1)
trigger3= root,p2bodydist x = [30,385]
trigger3= root,movetype = A
trigger3= enemynear,statetype != L
v = 55   
value = -1
ignorehitpause = 1

