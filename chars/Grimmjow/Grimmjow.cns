trigger1 = SelfAnimExist(5100 + (anim % 10))
value = (5100+cond(authorname = "Burako",0,cond(authorname = "Dano",var(10),cond(authorname = "Rivelio",var(51),cond(authorname = "Mikel8888",var(10),cond(authorname = "Petamynx" || authorname = "Petamynx&Dano",var(11),0)))))) + (anim % 10)

[State 5100, 4]
