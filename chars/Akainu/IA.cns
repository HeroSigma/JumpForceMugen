;===============================================================================
; AI:
;===============================================================================
[Statedef -2]
;===============================================================================
;-------------------------------------------------------------------------------
; FVARS:
;-------------------------------------------------------------------------------
[State 0, VarSet]
type = VarSet
trigger1 = var(3) = 0
fv = 3
value = 0

[State 0, VarSet]
type = VarSet
trigger1 = var(3) = 1
fv = 3
value = .5
;-------------------------------------------------------------------------------
; Sonidos Comunes:
;-------------------------------------------------------------------------------
[State 0, Andando // Corriendo]
type = PlaySnd
triggerall = stateno = 20||stateno = 60
trigger1 = animelem = 4 || animelem = 8
value = S20,1
volume = 50

[State 0, Saltando]
type = PlaySnd
triggerall = stateno = 40
trigger1 = Time = 1
value = S40,1
volume = 55
channel = -1

[State 0, Super Jump]
type = PlaySnd
triggerall = stateno = 80
trigger1 = Time = 1
value = S60,1
volume = 55
channel = -1

[State 0, Land]
type = PlaySnd
triggerall = stateno = 52
trigger1 = time = 1
value = S52,1
volume = 50

[State 0, Run FWD]
type = PlaySnd
triggerall = stateno = 65
trigger1 = time = 1
value = S60,1
volume = 50

[State 0, Run FWD Air y BACK]
type = PlaySnd
triggerall = stateno = 60 || stateno = 70
trigger1 = time = 1
value = S40,1
volume = 50

[State 0, RemoveExplod]
type = RemoveExplod
TRIGGERALL = stateno != 500
trigger1 = time = 1
id = 550

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 9

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 1

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 2

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 3

[State 0, Hitted]
type = PlaySnd
trigger1 = movetype=H && (stateno!=[0,155]) && !time && HitOver=0 && random%3=0
value = 5000,ifelse(random < 500,1,ifelse(random < 500,2,3))

[State -2]
type = Explod
triggerall = life <= 700 && life > 0
triggerall = numexplod(7062) < 2
trigger1 = time%50 = 0
anim = 7062+(random%2)
ID = 7062
pos = -7+(random%14),ifelse(stateno = 11,-30,-45-(random%20))
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
vel = 0,0
accel = 0,0
ownpal = 1
scale = 0.25,0.15
removeongethit = 1
ontop = 0
supermovetime 	= 999
ignorehitpause  = 1

[State -2]
type = Explod
triggerall = life <= 700 && life > 0
triggerall = numexplod(7060) < 2
trigger1 = time%50 = 0
anim = 7060
ID = 7060
pos = 0+(random%10),ifelse(stateno = 11,-30,-40-(random%25))
sprpriority = -1
supermove = 1
removetime = -2
bindtime = 1
vel = 0,0
accel = 0,0
facing = ifelse(anim = 21,-1,1)
ownpal = 1
scale = 0.35,0.35
removeongethit = 1
ontop = 0
supermovetime 	= 999
ignorehitpause  = 1

[State -2]
type = Explod
triggerall = life <= 700 && life > 0
triggerall = numexplod(7061) < 2
trigger1 = time%50 = 0
anim = 7060
ID = 7061
pos = -10+(random%15),ifelse(stateno = 11,-30,-45-(random%20))
sprpriority = 3
supermove = 1
removetime = -2
bindtime = 1
vel = 0,0
accel = 0,0
facing = ifelse(anim = 21,-1,1)
ownpal = 1
scale = 0.3,0.3
removeongethit = 1
ontop = 0
supermovetime 	= 999
ignorehitpause  = 1


[Statedef -3]

[State 0, VarSet]
type = VarSet
trigger1 = var(5) = 0 && (stateno = 60||stateno = 70||stateno = 75)
v = 5
value = 1

[State 0, VarSet]
type = VarSet
trigger1 = var(5) = 1 && pos y >= 0
v = 5
value = 0

[State 0, Fix standing in the air]
type = ChangeState
triggerall = stateno = 0||stateno = 20
trigger1 = pos y < 0
value = 50
ctrl = 1


