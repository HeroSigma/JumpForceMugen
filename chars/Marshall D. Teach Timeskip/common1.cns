; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0

[State 0, Explod] ;Circle FX
type = Explod
trigger1 = time = 0 && command != "holdback" && command != "holdfwd"
anim = 70003
pos = -37,13
postype = p1  ;p2,front,back,left,right
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
pausemovetime = 0
scale = .3,.3
sprpriority = 3
ownpal = 1
removeongethit = 0
angle = -52

[State 0, Explod] ;Circle FX
type = Explod
trigger1 = time = 0 && command = "holdfwd"
anim = 70003
pos = -40,0
postype = p1  ;p2,front,back,left,right
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
pausemovetime = 0
scale = .3,.3
sprpriority = 3
ownpal = 1
removeongethit = 0
angle = -66

[State 0, Explod] ;Circle FX
type = Explod
trigger1 = time = 0 && command = "holdback"
anim = 70003
pos = 38.5,0
postype = p1  ;p2,front,back,left,right
facing = -1
vfacing = 1
bindtime = 1
removetime = -2
pausemovetime = 0
scale = .3,.3
sprpriority = 3
ownpal = 1
removeongethit = 0
angle = -66

[State 45, 1]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45, 2]
type = ChangeAnim
trigger1 = !SelfAnimExist(44)
value = 41

[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = Cond(sysvar(1)=0, const(velocity.airjump.neu.x), Cond(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1

;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = Cond((vel x)=0, 41, Cond((vel x)>0, 42, 43))

[State 0, VelAdd]
type = VelAdd
triggerall = time > 5
trigger1 = command = "holdback"
x = -1.3
[State 0, VelSet]
type = VelSet
triggerall = time > 5
trigger1 = vel x < -3
x = -3
[State 0, VelAdd]
type = VelAdd
triggerall = time > 5
trigger1 = command = "holdfwd"
x = 1.3
[State 0, VelSet]
type = VelSet
triggerall = time > 5
trigger1 = vel x > 3
x = 3

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = prevstateno = 620
trigger1 = time = 0
id = 7050

[State 200, Dark Whirl - Finish]
type = Explod
triggerall = prevstateno = 620
trigger1 = time = 0
anim = 7051
ID = 7051
postype = P1
pos = 55,-50
facing = -1
sprpriority = -1
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = 0.15,0.3
removeongethit = 1
ontop = 0
supermovetime 	= 999
ignorehitpause  = 1

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > -2
trigger1 = SelfAnimExist(anim + 3)
persistent = 0
value = Anim + 3

[State 200, End]
type = ChangeState
triggerall = var(25) >= 1
triggerall = p2bodydist x < 5
triggerall = p2bodydist y < 5
triggerall = prevstateno = 45
triggerall = root,stateno = [410,420]
triggerall = numhelper(720) = 0
trigger1 = ailevel = 0
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
value = Cond(p2name="Blackbeard [Kuro]",610,620)

