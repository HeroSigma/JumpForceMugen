;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = Animelem = 98
value = S800,0
volume = 50

[State 0, EnvShake]
type = EnvShake
trigger1 = Animelem = 98
time = 5
freq = 120
ampl = -4

[State 0, Explod]
Type = Explod
trigger1 = Animelem = 98
anim = 70001
ID = 70001
postype = p1
pos = 0,0
scale = .4,.4
ownpal = 1
sprpriority = 3

[State 0, Explod]
type = Explod
trigger1 = Animelem = 98
anim = 70002
id = 70002
postype = p1
pos = 0,0
scale = .5,.5
ownpal = 1
sprpriority = 4

[State 0, Explod]
type = Explod
trigger1 = Animelem = 98
anim = 7103
id = 7103
postype = p1
pos = 0,0
scale = .3,.3
ownpal = 1
sprpriority = 5

[State 210, 2]
type = PlaySnd
trigger1 = time = 1250 || time = 1779 || Time = 2500
value = 4, 23
volumescale = 280

[State 210, 2]
type = PlaySnd
trigger1 = time = 1310 || Time = 1820 || Time = 2560
value = 4, 1
volumescale = 280

[State 210, 2]
type = PlaySnd
trigger1 = time = 1380 || Time = 2000 || Time = 2630
value = 4, 24
volumescale = 280

[State 210, 2]
type = PlaySnd
trigger1 = time = 1443 || Time = 2063 || Time = 2693
value = 4, 9
volumescale = 280

[State 210, 2]
type = PlaySnd
trigger1 = time = 1522 || Time = 2120 || Time = 2752
value = 4, 25
volumescale = 280

[State 210, 2]
type = PlaySnd
trigger1 = time = 1683 || Time = 2283 || Time = 2900
value = 4, 21
volumescale = 280

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 0 && Anim != 5)
trigger2 = (Anim = 5) && AnimTime = 0
value = 0

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050

;---------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11

;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 0
velset = (PrevStateno = 9000)* 0,(PrevStateno = 9000)* 0
facep2 = !(PrevStateno = 9000)
ctrl = 1

;[State 11, 1] ;Change from turning animation
;type = ChangeAnim
;trigger1 = Anim = 6 && AnimTime = 0
;value = 11

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 11 && Anim != 6)
trigger2 = (Anim = 6) && AnimTime = 0
value = 11


[State 0, ChangeAnim]
type = ChangeAnim
triggerall = (var(2) = 1)
trigger1 = anim = 6
value = 2006

;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0

;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 0, PlaySnd]
type = PlaySnd
triggerall = Anim = 20
trigger1 = Animelem = 3 || animelem = 7
value = S40,0
volume = 50
[State 0, PlaySnd]
type = PlaySnd
triggerall = Anim = 21
trigger1 = Animelem = 3 || animelem = 7
value = S40,0
volume = 50

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5)
trigger2 = (Anim = 5) && AnimTime = 0
value = 20

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5)
trigger2 = (Anim = 5) && AnimTime = 0
value = 21

;---------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = Cond(sysvar(1)=0, const(velocity.jump.neu.x), Cond(sysvar(1)=1, const(velocity.jump.fwd.x)-(Cond(var(3) = 1,0.7,0)), const(velocity.jump.back.x)+(Cond(var(3) = 1,0.7,0))))
y = const(velocity.jump.y)+(Cond(var(3) = 1,0.7,0))

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S1,5
volume = 50

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

