type    = S
physics = S
ctrl = 0
sprpriority = 1

;Normal (Right Side)
[State 0, 0]
type = ChangeAnim
trigger1 = var(2) = 0
triggerall = facing != 1
trigger1 = Anim != 23
value = 23

;Normal (Left Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 0
triggerall = facing = 1
trigger1 = Anim != 40
value = 40

;HOS (Right Side)
[State 0, 0]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = facing != 1
trigger1 = Anim != 2023
value = 2023

;HOS (Left Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = facing = 1
trigger1 = Anim != 2040
value = 2040

;BANKAI
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = Anim != 11040
value = 11040

;HOS + BANKAI (Right Side)
[State 0, 0]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = facing != 1
trigger1 = Anim != 13023
value = 13023

;HOS + BANKAI (Left Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = facing = 1
trigger1 = Anim != 13040
value = 13040

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 0, VelSet]
type = VelSet
triggerall = ailevel > 0 && prevstateno = 310
trigger1 = animtime = 0
x = 4

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
