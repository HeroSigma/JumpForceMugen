;===============================================================================
;--------------------------Constantes Básicas-----------------------------------
;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State -3, Turn SS1]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = facing = 1
trigger1 = anim = 5
value = 2005

[State -3, Turn SS1]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = facing != 1
trigger1 = anim = 4
value = 2004

[State -3, Turn SS2]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = anim = 5
value = 11005

[State -3, Turn SS God]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = facing = 1
trigger1 = anim = 5
value = 13005

[State -3, Turn SS God]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = facing != 1
trigger1 = anim = 5
value = 13004

;Normal (Left Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 0
triggerall = facing = 1
trigger1 = Anim != 0 && Anim != 5
trigger2 = Anim = 5  && AnimTime = 0 ;Turn anim over
value = 0

;Normal (Right Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 0
triggerall = facing != 1
trigger1 = Anim != 1 && Anim != 5
trigger2 = Anim = 5  && AnimTime = 0 ;Turn anim over
value = 1

;HOS (Left Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = facing = 1
trigger1 = Anim != 2000&& Anim != 2005
trigger2 = anim = 2005 && AnimTime = 0 ;Turn anim over
value = 2000

;HOS (Right Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 1
triggerall = facing != 1
trigger1 = Anim != 2001 && Anim != 2005
trigger2 = anim = 2005 && AnimTime = 0 ;Turn anim over
value = 2001

;BANKAI
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 2
trigger1 = Anim != 11000 && Anim != 11005
trigger2 = Anim = 11005  && AnimTime = 0 ;Turn anim over
value = 11000

;HOS + BANKAI (Left Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = facing = 1
trigger1 = Anim != 13000&& Anim != 13005
trigger2 = anim = 13005 && AnimTime = 0 ;Turn anim over
value = 13000

;HOS + BANKAI (Right Side)
[State 0, 1]
type = ChangeAnim
trigger1 = var(2) = 3
triggerall = facing != 1
trigger1 = Anim != 13001 && Anim !=13005
trigger2 = anim = 13005 && AnimTime = 0 ;Turn anim over
value = 13001

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
