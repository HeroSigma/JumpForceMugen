; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)+ifelse(var(2) = 1,const(velocity.walk.fwd.x)/4,0)+ifelse(var(2) = 2,const(velocity.walk.fwd.x)/3,0)+ifelse(var(2) = 3,const(velocity.walk.fwd.x)/2,0)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)-ifelse(var(2) = 1,const(velocity.walk.fwd.x)/4,0)-ifelse(var(2) = 2,const(velocity.walk.fwd.x)/3,0)-ifelse(var(2) = 3,const(velocity.walk.fwd.x)/2,0)

;Normal (Right Side)
[State 0, 2]
type = ChangeAnim
trigger1 = facing = 1
trigger1 = var(2) = 0
triggerall = vel x > 0
trigger1 = Anim != 20
value = 20

;Normal (Left Side)
