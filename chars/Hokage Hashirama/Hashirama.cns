;===============================================================================
;-----------------Constantes y Ataques normales---------------------------------
;===============================================================================

;Var List:

; - Var(5) = Limitador Air Jump
; - Var(6) = Lifeadd Mokuton Mokujin no Jutsu
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(12) = Oscurecer Pantalla
; - Var(15) = Gojuu Rashomon

[Data]
life = 1650
power = 3000
attack = 125
defence = 150
fall.defence_up = 80
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 1
yscale = 1
ground.back = 13
ground.front = 13
air.back = 13
air.front = 13
height = 60
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[quotes]
victory0 = "This is the power of the Senju clan!"
victory1 = "No matter what happens, I will protect my village!"
victory2 = "Better luck next time"
victory3 = "Train harder and try again"
victory4 = "It is my duty to protect the village!"
victory5 = "No Hokage worthy of the name could lose this battle!"
victory6 = "This is the power of the Hokage! The ultimate, without peer!"
victory7 = "I will let no one harm the Hidden Leaf Village!"
victory8 = "Hm? Was that it? I can still go on"
