airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
Victory0 = "Was i able to change myself...even a little?"
victory1 = "I will never go back on my word,because that is my Ninja way too."
victory2 = "I no longer want to run away!"
victory3 = "You make mistakes… but because of those mistakes you get the strength to stand up to them."
victory4 = "When I watch you, I feel strong, like I can do anything,that even I am worth something."
victory5 = "In my eyes, you’re a proud failure! When I look at you… I get an intense feeling in my heart." 
victory6 = "You’re wrong, Neji… Because I can see that you are suffering more than me… You are the one who is confused and suffering inside the fate of the head and branch families."
victory7 = "Thank you Shino,but i want to do the best job i can.Failure is not an option."
