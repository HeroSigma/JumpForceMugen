unhittable = 1

[State 0, ZoomIn]
type = Zoom
trigger1 = time = [0,10] 
scale = 1 + (time * 0.03)
pos = (pos x/(1 + (time * 0.03))) * camerazoom,0

[State 0, Zoom] 
type = Zoom
trigger1 = time = [10,60] 
scale = 1.3
pos = (pos x/2) * camerazoom,0

[State 0, ZoomOut]
type = Zoom
trigger1 = time = [60,65]
scale = 1.3 -((time - 70)*0.03)
pos = (pos x/(1.5 -((time - 70)* 0.03)))* camerazoom,0

