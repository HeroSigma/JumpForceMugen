;---------------------------------------------------------------------------
[Statedef -2]
;---------------------------------------------------------------------------
;Doflamingo Passive
[State 0, LifeAdd] ;Normals
type = LifeAdd
trigger1 = stateno = 220 || stateno = 225 || stateno = 250  || stateno = 261 || stateno = 262 || stateno = 280 || stateno = 600 || stateno = 605 || stateno = 615 ||  stateno = [1000,2999]
value = floor(enemynear,gethitvar(damage)* 0.3)
ignorehitpause = 1
;---------------------------------------------------------------------------
[State 0, RemoveExplod] ;Blur Removal
type = RemoveExplod
trigger1 = time = 1 && (prevstateno=[200,699]) && stateno!=[200,699]
id = 200
ignorehitpause = 1
[State 0, RemoveExplod] ;Palette FX Removal
type = RemoveExplod
trigger1 = !alive
id = 700
ignorehitpause = 1
[State 0, RemoveExplod] ;Palette FX Removal
type = RemoveExplod
trigger1 = !alive
id = 710
ignorehitpause = 1
[State 0, RemoveExplod] ;Palette FX Removal
type = RemoveExplod
trigger1 = !alive
id = 711
ignorehitpause = 1

[State 0, VarRandom]
type = VarRandom
trigger1 = 1
v = 59
range = 0,999
ignorehitpause = 1
;-----------------------CONFIG------------------------------------
;Kanjo Bar Y Position
[State 0, BAR POSITION]
type = VarSet
trigger1 = 1 || !time
v = 11    ;fv = 10
value = 120 ;<----- EDIT THIS ;DEFAULT 120
;----------------------------------------------------------------------
;===============================================================================
; AI
;-------------------------------------------------------------------------------
;--------------- GUARD
[State 0, Guard]
type = ChangeState
triggerall = stateno != [120,155]
triggerall = ailevel > 0 && roundstate = 2 && (numenemy) 
triggerall = (inguarddist)&&(stateno!=[120,155]) && !(enemynear,hitdefattr = SCA,AT) 
trigger1 = ctrl
trigger2 = prevstateno = 5120 && ( random<((700)*(ailevel**2/64.0)) )
trigger2 = ctrl
trigger3 = numhelper(33333333)
trigger3 = PlayerIDExist(helper(33333333),var(3))
trigger3 = PlayerID(helper(33333333),var(3)), pos y > -70
trigger3 = PlayerID(helper(33333333),var(3)), vel x != 0.0
trigger3 = cond(numhelper(33333333),helper(33333333), cond(1, var(20) := 2, 0), 0)
trigger3 = cond(helper(33333333),numexplod((helper(33333333),var(20)*100000000)+PlayerID(helper(33333333),var(3)),stateno) = 0, 1, helper(33333333),numexplod((helper(33333333),var(20)*100000000)+abs(floor(PlayerID(helper(33333333),var(3)),vel x))) = 0)
trigger3 = random < ((300)*(AILevel ** 2 / 50))
trigger3 = ailevel >= 5; && !numhelper(1350)
trigger3 = ctrl
value = 120

[State -1,] 
type = explod
triggerall = numhelper(33333333)
triggerall = ailevel
triggerall = ctrl
triggerall = stateno != [40,52]
triggerall = statetype = S || statetype = C
triggerall = numexplod(33330001) = 0
trigger1 = PlayerIdExist(helper(33333333),var(3)) 
trigger1 = PlayerID(helper(33333333),var(3)), pos y > -60 
trigger1 = PlayerID(helper(33333333),var(3)), vel x != 0.0 
trigger1 = cond(numhelper(33333333),helper(33333333), cond(1, var(20) := 1, 0), 0) 
trigger1 = cond(helper(33333333),numexplod((helper(33333333),var(20)*100000000)+PlayerID(helper(33333333),var(3)),stateno) = 0, 1, helper(33333333),numexplod((helper(33333333),var(20)*100000000)+abs(floor(PlayerID(helper(33333333),var(3)),vel x))) = 0)
trigger1 = ceil(((PlayerID(helper(33333333),var(3)), pos x - pos x )* facing) / PlayerID(helper(33333333),var(3)), vel x ) = floor(abs(const(velocity.jump.y)) / const(movement.yaccel))
anim = helper(33333333), anim 
ID = 33330001
 
[State -1, ] 
type = varset
triggerall = numhelper(33333333)
trigger1 = numexplod(33330001) = 1
sysvar(1) = 1

[State -1, ] 
type = removeexplod
triggerall = numhelper(33333333)
triggerall = numexplod(33330001) = 1
trigger1 = prevstateno = 40
trigger2 = movetype = H
ID = 33330001
ignorehitpause = 1
;--------------- GUARD 
[State 0, Run FWD]
type = ChangeState
triggerall = stateno != 100
triggerall = stateno != 105
triggerall = frontedgebodydist > 50
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
trigger1 = p2bodydist x >= 100
trigger1 = random < (ailevel * 100)/2
trigger2 = p2bodydist y < -10
trigger2 = p2bodydist x < 90
value = 100

[State 0, Run BACK]
type = ChangeState
triggerall = stateno != 100
triggerall = stateno != 105
triggerall = statetype != A
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
trigger1 = p2bodydist x <= 100 && p2movetype = A
trigger1 = random < (ailevel * 100)/5
trigger2 = p2stateno = [120,155]  
trigger2 = random < (ailevel * 100)/3
trigger3 = p2statetype = L
trigger3 = random < (ailevel * 20+enemy, gethitvar(hitcount))
value = 105

[State 0, Power Charge]
type = ChangeState
triggerall = power < 3000
triggerall = var(7) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = p2movetype != A && random < (ailevel * 100+enemy, gethitvar(hitcount)*5)/2
trigger2 = enemynear,stateno = cond(enemy,authorname = "Planeptune"||enemy,authorname = "Planeptune Arte"||enemy,authorname = "Nepgear",195,500) && random < (ailevel * 100+ceil(life*.8))
trigger3 = p2movetype != A && random < (ailevel * 100+enemy, gethitvar(hitcount)*5) && var(59)<4
value = 500

[State 0, Power Charge End]
type = ChangeState
trigger2 = power = 3000
triggerall = time >= 12
triggerall = stateno = 500 
triggerall = ailevel > 0
trigger1 = (p2bodydist x < 50) || (enemy,numproj > 0)
trigger4 = enemynear,stateno = 60
trigger4 = random < (ailevel * 150)
trigger4 = p2bodydist x < 100
trigger5 = enemynear,hitdefattr = SCA,NP,SP,HP,HA || (enemy,numproj > 0)
trigger5 = random < (ailevel * 200)
trigger5 = p2bodydist x = [-360,450]
trigger6 = enemynear,hitdefattr = SCA,NA,SA,HA || (enemy,numproj > 0) || enemynear,movetype = A
trigger6 = random < (ailevel * 400)
trigger6 = p2bodydist x = [-10,350]
trigger9 = numhelper(33333333)
trigger9 = PlayerIDExist(helper(33333333),var(3))
trigger9 = PlayerID(helper(33333333),var(3)), pos y > -70
trigger9 = PlayerID(helper(33333333),var(3)), vel x != 0.0
trigger9 = cond(numhelper(33333333),helper(33333333), cond(1, var(20) := 2, 0), 0)
trigger9 = cond(helper(33333333),numexplod((helper(33333333),var(20)*100000000)+PlayerID(helper(33333333),var(3)),stateno) = 0, 1, helper(33333333),numexplod((helper(33333333),var(20)*100000000)+abs(floor(PlayerID(helper(33333333),var(3)),vel x))) = 0)
trigger9 = random < ((300)*(AILevel ** 2 / 40))
trigger9 = ailevel >= 5 ; && !numhelper(1350)
value = 501

[State 0, Boundary Push Offensive]
type = ChangeState
triggerall = (var(7) = 0) && (power = [1500,1700]) && (ailevel > 0) && (roundstate = 2) && (movetype = H) && (p2movetype = A) && (stateno = [200,499]) && (p2bodydist x < 45)
trigger1 = random < (ailevel * 100)/3
value = 4002

[State 0, Grab]
type = ChangeState
triggerall = enemynear,statetype!=L
triggerall = (ailevel > 0) && (roundstate = 2) && (ctrl) && (statetype != A) && (p2bodydist x < 55) && (p2stateno = [120,155])
trigger1 = random < (ailevel * 100)
value = 290

[State 0, A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x =[0,25]
triggerall= enemynear,statetype != L
trigger1= enemynear,pos y>= -const(size.height)
trigger1 = random < (ailevel * 100)
trigger2= enemynear,pos y>= -const(size.height)*.8
value = 200

[State 0, Crouch A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x  = [0,25]
triggerall= enemynear,statetype != L
triggerall= enemynear,pos y>= -const(size.height)*.25
trigger1 = random < (ailevel * 100)/2
trigger2 = p2movetype = H && random < (ailevel * 100-enemy, gethitvar(hitcount))
value = 400

[State 0, B]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x =[0,35]
triggerall= enemynear,statetype != L
triggerall= enemynear,pos y>= -const(size.height)
trigger1 = random < (ailevel * 100)/3
value = 230

[State 0, Crouch B]
