triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x  =[0,30]
triggerall= enemynear,statetype != L
triggerall= enemynear,pos y>= -const(size.height)*.19
trigger1 = random < (ailevel * 100)/4
trigger2 = p2movetype = H && random < (ailevel * 100-enemy, gethitvar(hitcount))
value = 405

[State 0, C]
