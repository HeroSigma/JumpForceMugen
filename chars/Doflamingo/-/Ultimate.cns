trigger1 = time = [10,70] 
scale = 1.5
pos = (pos x/2) * camerazoom,0

[State 0, ZoomOut]
type = Zoom
trigger1 = time = [70,75]
scale = 1.5 -((time - 70)*0.05)
pos = (pos x/(1.5 -((time - 70)* 0.05)))* camerazoom,0

