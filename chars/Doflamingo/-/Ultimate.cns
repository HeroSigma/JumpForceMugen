v = 40
value = 0
ignorehitpause = 1
persistent = 0

[State 0, ZoomIn]
type = Zoom
trigger1 = time = [0,10] 
scale = 1 + (time * 0.05)
pos = (pos x/(1 + (time * 0.05))) * camerazoom,0

[State 0, Zoom] 
