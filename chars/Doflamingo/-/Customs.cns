;-------------------------------------------------------------------
;P2State Air Spin By Keyser
[Statedef 6020]
type    = A
movetype= H
physics = N
velset = 0,0
sprpriority = 1
facep2 = 1

[state -2]
type = ChangeAnim2
Trigger1 = Time=0
value = 6020

[state -2]
type = ChangeAnim2
Trigger1 = !HitShakeOver
Trigger1 = Time > 0
value = 6020

[state -2]
type = HitVelSet
TriggerAll = HitShakeOver
Trigger1   = Vel Y = 0
Trigger1   = AnimElem = 1,=1
Trigger2   = Time = 0
x = 1
y = 1

[state -2]
type = VelAdd
TriggerAll = HitShakeOver
Trigger1   = Vel Y != 0
Trigger2   = Time >= 120
Trigger2   = Vel Y = 0
y = GetHitVar(yaccel)

[state -2]
type = ChangeAnim2
Trigger1 = Vel Y > 0
Trigger1 = Pos Y < 0
Trigger1 = Anim=6020
value = 6021

[state -2]
type = ScreenBound
Trigger1 = 1
value = 1
movecamera = 1,0

[state -2]
Type = DefenceMulSet
Trigger1 = 1
value = 1

[State AngleDraw]
type = AngleDraw
trigger1 = HitShakeOver
scale = 1,1
value = 15 * time

[state -2] 
type = ChangeState
Trigger1 = Vel Y > 0 && Pos Y >= 0
value = 6021
;--------------------------------------------------------------------------------------
;P2State Bounce
[Statedef 6021]
type    = A
movetype= H
physics = N
velset = vel x*.4,-4
sprpriority = 0

[State 0, PosSet]
type = PosSet
trigger1 = Animelem = 2,<0
y = 0

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,0

[State 820, 1]
type = ChangeAnim2
Trigger1 = Time = 0
value = 6022

[State 0, VelAdd]
type = VelAdd
trigger1 = Animelem = 2,>=0
y = .3

[state a]
type = SelfState
Trigger1 = Vel Y > 0 && Pos Y >= 0
value = 5100

;-------------------------------------------------------------------
;P2State Air Spin By Keyser
[Statedef 6030]
type    = A
movetype= H
physics = N
velset = 0,0
sprpriority = 1
facep2 = 1

[state -2]
type = ChangeAnim
Trigger1 = Time=0
value = 5031+cond(authorname = "Burako",0,cond(authorname = "Dano",var(10),cond(authorname = "Rivelio",var(51),cond(authorname = "Mikel8888",var(10),cond(authorname = "Petamynx" || authorname = "Petamynx&Dano",var(11),0)))))
elem = 1

[state -2]
type = ChangeAnim
Trigger1 = !HitShakeOver
Trigger1 = Time > 0
value = 5031+cond(authorname = "Burako",0,cond(authorname = "Dano",var(10),cond(authorname = "Rivelio",var(51),cond(authorname = "Mikel8888",var(10),cond(authorname = "Petamynx" || authorname = "Petamynx&Dano",var(11),0)))))
elem = 1

[state -2]
type = HitVelSet
TriggerAll = HitShakeOver
Trigger1   = Vel Y = 0
Trigger1   = AnimElem = 1,=1
Trigger2   = Time = 0
x = 1
y = 1

[state -2]
type = VelAdd
TriggerAll = HitShakeOver
Trigger1   = Vel Y != 0
Trigger2   = Time >= 120
Trigger2   = Vel Y = 0
y = GetHitVar(yaccel)

[state -2]
type = ChangeAnim
Trigger1 = Vel Y > 0
Trigger1 = Pos Y < 0
Trigger1 = anim= 5031+cond(authorname = "Burako",0,cond(authorname = "Dano",var(10),cond(authorname = "Rivelio",var(51),cond(authorname = "Mikel8888",var(10),cond(authorname = "Petamynx" || authorname = "Petamynx&Dano",var(11),0)))))
value = 5050+cond(authorname = "Burako",0,cond(authorname = "Dano",var(10),cond(authorname = "Rivelio",var(51),cond(authorname = "Mikel8888",var(10),cond(authorname = "Petamynx" || authorname = "Petamynx&Dano",var(11),0)))))
elem = 1

[state -2]
type = ScreenBound
Trigger1 = 1
value = 1
movecamera = 1,0

[state -2]
Type = DefenceMulSet
Trigger1 = 1
value = 1

[State AngleDraw]
type = AngleDraw
trigger1 = HitShakeOver
scale = 1,1
value = 15 * time

[state -2] 
type = ChangeState
Trigger1 = Vel Y > 0 && Pos Y >= 0
value = 6031
;--------------------------------------------------------------------------------------
;P2State Bounce
[Statedef 6031]
type    = A
movetype= H
physics = N
velset = vel x*.4,-4
sprpriority = 0

[State 0, PosSet]
type = PosSet
trigger1 = Animelem = 2,<0
y = 0

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = 1

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
movecamera = 1,0

[State 820, 1]
type = ChangeAnim
Trigger1 = Time = 0
value = 5160+cond(authorname = "Burako",0,cond(authorname = "Dano",var(10),cond(authorname = "Rivelio",var(51),cond(authorname = "Mikel8888",var(10),cond(authorname = "Petamynx" || authorname = "Petamynx&Dano",var(11),0)))))
elem = 1

