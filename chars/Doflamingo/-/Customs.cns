;-------------------------------------------------------------------------------
;State Rebote Ground
[Statedef 6100]
type    = U
movetype= H
physics = N
juggle  = 1
velset = -2,7
ctrl = 0
sprpriority = 1
;Facep2 = 1

[State 0, ChangeAnim2]
type = ChangeAnim2
trigger1 = !time
value = 5810
elem = 1
persistent = 0

[State 0, PlayerPush]
type = PlayerPush
trigger1 = anim=5810
value = 0
ignorehitpause = 1
[State 0, NotHitBy]
type = NotHitBy
trigger1 = anim=5810
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1
;----------------------------------------------------------------------------------
;rebote
[State 0, ChangeAnim2]
type = ChangeAnim2
triggerall = anim = 5810
trigger1 = pos y >= 0
value = 5811
elem = 1
persistent =0

[State 0, PlayerPush]
type = PlayerPush
trigger1 = anim = 5811
value = 1
ignorehitpause = 1
[State 0, NotHitBy]
type = HitBy
trigger1 = anim = 5811
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1

[State 0, StateTypeSet]
type = StateTypeSet
triggerall = anim = 5811
trigger1 = 1
statetype = A
movetype = H        ;I,A,H
physics = N         ;A,C,S,N
persistent = 0
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
triggerall = anim = 5811
trigger1 = 1
x = -2
y = -6
persistent = 0
ignorehitpause = 1

[State 0, VelAdd]
type = VelAdd
trigger1 = anim = 5811
y= const(movement.yaccel)

[State 0, End]
type = SelfState
triggerall = anim = 5811 && pos y >= 0
trigger1 = animelemtime(2)>= 0
value = 5110
ctrl = 1
