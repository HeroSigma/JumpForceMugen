[Statedef -2]

[State 0, ChangeState]
type = ChangeState
triggerall = (var(5) = 0) && (enemy,numproj = 0) && (stateno != 60) && (stateno != 65) && (stateno != 70) && (ailevel > 0) && (roundstate = 2) && (ctrl) && (p2bodydist x > 100)
trigger1 = random < (ailevel * 100)/2
value = cond(pos y >= 0,60,65)

[State 0, Run Atras]
type = ChangeState
triggerall = (var(5) = 0) && (stateno != 60) && (stateno != 65) && (stateno != 70) && (ailevel > 0) && (roundstate = 2) && (ctrl) && (p2bodydist x < 100) && (backedgebodydist > 50) && (p2movetype = A) && (statetype != A)
trigger1 = random < (ailevel * 100)/4
value = cond(pos y >= 0,70,66)

[State 0, Guard]
type = ChangeState
triggerall = (ailevel > 0) && (roundstate = 2) && (ctrl)
triggerall = (p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)*1.5
value = cond(statetype = A,132,130)

[State 0, Power Charge]
type = ChangeState
triggerall = var(28)=0
triggerall = (ailevel > 0) && (roundstate = 2) && (ctrl) && (statetype != A) && (p2movetype != A) && (power < 3000) && (p2bodydist x >= 100)
trigger1 = random < (ailevel * 100)/3 || p2stateno = cond(enemy,authorname = "Planeptune"||enemy,authorname = "Planeptune Arte"||enemy,authorname = "Nepgear",195,500)
value = 500

[State 0, Power Charge End]
type = ChangeState
triggerall = (ailevel > 0) && (time >= 12) && (stateno = 500)
trigger1 = (p2bodydist x < 75) || (enemy,numproj > 0) || (p2movetype = A)
trigger2 = power = 3000
value = 501

