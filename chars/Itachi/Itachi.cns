walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 1
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Seus olhos nao veem nada."
victory1 = "Sua derrota... e a minha realidade..."
victory2 = "Afunde na escuridao do Mangekyo Sharingan..."
victory3 = "Existe muita diferenca entre seu poder e o meu..."
