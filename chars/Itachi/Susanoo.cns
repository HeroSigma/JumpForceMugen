;===============================================================================
; SUSANOO:
;-------------------------------------------------------------------------------
; SUSANOO - Transform
[Statedef 2000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 2000+var(13)
poweradd = -1500
sprpriority = 2

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,41
volume = 999
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,41
volume = 999

[State 3000, SuperPause]
type = SuperPause
trigger1 = time = 0
time = 120
movetime = 120
anim = -1
sound = -1
pos = 999,999
darken = 0
unhittable = 1

[State 3000, VarSet]
type = Varset
trigger1 = time = 0
v = 12
value = -100

[State 3000, VarSet]
type = Varset
trigger1 = time = 120
v = 12
value = 0

[State 3000, VarAdd]
type = VarAdd
trigger1 = time >= 130 && Var(12) < 0
v = 12
value = 6

[State 3000, BGColorFX]
type = BGPalFX
trigger1 = Time > 0
time = 1
add = Var(12),Var(12),Var(12)

[State 0, Susanoo]
type = Helper
trigger1 = time = 120
helpertype = normal
name = "Susanoo"
ID = 9000
stateno = 9000
pos = 0,0
postype = p1
facing = 1
ownpal = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 120
value = S4,36
volume = 50

[State 0, EnvShake]
type = EnvShake
trigger1 = time = 120
time = 20

[State 200, End]
type = ChangeState
trigger1 = time = 150
value = 2001
;-------------------------------------------------------------------------------
; Susanoo - Stance
[Statedef 2001]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 2001+var(13)
sprpriority = 0

[State 0, Helper Tiempo]
type = Helper
trigger1 = prevstateno = 2000 && time = 0
helpertype = normal
name = "Helper Tiempo"
ID = 2100
stateno = 2100
pos = 0,0
postype = p1

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 0, WALK FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel = 0 && command = "FF"
trigger3 = ailevel > 0 && random < (ailevel * 100)/4 && p2bodydist x > 75
value = 2020

[State 0, WALK BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel = 0 && command = "BB"
trigger3 = ailevel > 0 && random < (ailevel * 100)/8 && p2bodydist x <= 75
value = 2021

[State 0, Yasaka no Magatama]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x >= 100
value = 2500

[State 0, Shield Attack]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 2"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x <= 20
value = 2510

[State 0, Susanoo Amaterasu]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 3"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [75,150]
value = 2600

[State -1, Amaterasu Defense]
type = ChangeState
Triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 4"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [-50,50]
value = 2650

[State 0, Totsuka no Tsurugi]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 5"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,300]
value = 2700

[State 0, Susanoo Rashoomon]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 6"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [-150,150]
value = 2750

[State 0, Totsuke Blade]
type = ChangeState
Triggerall = p2life <= lifemax/2
triggerall = power >= 3000
trigger1 = ailevel = 0 && command = "SUPER1"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [-150,50]
value = 2800

[State 0, SUSANOO A]
type = ChangeState
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 75
trigger2 = p2bodydist y < -50
value = 2200

[State 0, SUSANOO B]
type = ChangeState
trigger1 = ailevel = 0 && command = "b"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 75
value = 2300

[State 0, SUSANOO C]
type = ChangeState
trigger1 = ailevel = 0 && command = "c"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4 && p2bodydist x > 100
value = 2400

[State 200, End]
type = ChangeState
trigger1 = numhelper(2100) = 0 || roundstate != 2
value = 4000

[State 200, End]
type = ChangeState
trigger1 = !alive
value = 5050
