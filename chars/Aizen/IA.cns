[Statedef -2]
;===========================================================================
;Basic:
;===========================================================================

;---------------
;Against Lower Health Enemies

[State 0, AttackMulSet]
type = AttackMulSet
triggerall = var(2) = 1
trigger1 = enemy,lifemax < lifemax
value = 1*enemy,lifemax/1500
ignorehitpause = 1
persistent = 0

[State 0, AttackMulSet]
type = AttackMulSet
triggerall = var(2) = 2
trigger1 = enemy,lifemax < lifemax
value = 1*enemy,lifemax/1400
ignorehitpause = 1
persistent = 1
;---------------
;Against Higher Health Enemies

[State 0, AttackMulSet]
type = AttackMulSet
triggerall = var(2) = 1
trigger1 = enemy,lifemax >= lifemax
value = 1*enemy,lifemax/1000
ignorehitpause = 1
persistent = 0

[State 0, AttackMulSet]
type = AttackMulSet
triggerall = var(2) = 2
trigger1 = enemy,lifemax >= lifemax
value = 1*enemy,lifemax/950
ignorehitpause = 1
persistent = 1

[State - 2, Second Chance]
type = LifeSet
Trigger1 = (Life <= 200) && movetype != H && alive && numhelper(15050) = 1
value = 1
IgnoreHitPause = 1

[State -2, Just Recovered...]
type = VarSet
trigger1 = AnimTime = 0
trigger2 = stateno=[5200,5210]
var(40) = 1
ignorehitpause = 1

[State -2, Just Recovered... Reset]
type = VarSet
trigger1 = var(40) = 1 && statetype != A
var(40) = 0
ignorehitpause = 1

;---------------
;Activates Second Chance 14000

[State -2, VarSet]
