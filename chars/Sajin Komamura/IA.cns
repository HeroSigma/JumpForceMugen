; Bankai:
;-------------------------------------------------------------------------------
[State 0, VarSet] ; Siempre Bankai
type = VarSet
trigger1 = palno >= 7
Fv = 18
value = 1

[State 0, VarSet] ; Activar
type = VarSet
trigger1 = fvar(18) = 1 || Numhelper(6004) = 1
v = 2
value = 1

[State 0, VarSet] ; Desactivar
type = VarSet
triggerall = Fvar(18) = 0
trigger1 = Var(2) = 1 && Numhelper(6004) = 0
v = 2
value = 0
