;===============================================================================
; INTELIGENCIA ARTIFICIAL:
;===============================================================================
[Statedef -2]

[State 0, Run]
type = ChangeState
triggerall = stateno != 100
triggerall = stateno != 105
triggerall = stateno != 110
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/2
value = ifelse(pos y >= 0,100,110)

[State 0, Run Atras]
type = ChangeState
triggerall = stateno != 100
triggerall = stateno != 105
triggerall = stateno != 110
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100 && p2movetype = A
trigger1 = random < (ailevel * 100)/4
value = ifelse(pos y >= 0,105,110)

[state 0]
type = changestate
triggerall = (roundstate = 2) && (alive) && ((ctrl) || (numhelper(99999) > 0)) && (pos y = 0)
trigger1 = ((!ailevel) && (command = "FF"))
trigger2 = ((ailevel) && (stateno = 20) && (animelemtime(2) >= 0) && (enemynear, p2bodydist x = [100, (helper(99000), var(1))]) && (var(58) = (1 + (random % 6))))
trigger2 = ((enemynear, movetype != a))
trigger3 = ((ailevel) && (enemynear, p2bodydist x = [50, (helper(99000), var(1)) * 4]) && (var(58) = (1 + (random % 6))))
trigger3 = (enemynear, stateno != [5090, 5150])
value = 100
[state 0]
type = changestate
triggerall = (roundstate = 2) && (alive) && (ctrl) && (pos y = 0) && (numhelper(1350) = 0)
trigger1 = ((!ailevel) && (command = "BB"))
trigger2 = ((ailevel) && (stateno = 100) && (animelemtime(2) >= 0) && (enemynear, p2bodydist x <= (helper(99000), var(1))) && (var(58) = (1 + (random % 6))))
trigger2 = ((enemynear, movetype != a))
trigger3 = ((ailevel) && (enemynear, p2bodydist x >= (helper(99000), var(1))) && ((var(58) = 1) || (var(58) = 3)))
trigger3 = ((enemynear, movetype = a))
value = 105
[state 0]
type = changestate
triggerall = (roundstate = 2) && (alive) && (ctrl) && (numhelper(1350) = 0)
trigger1 = ((!ailevel) && (command = "FF") || (command = "BB"))
trigger2 = ((ailevel) && (enemynear, p2bodydist x = [50, (helper(99000), var(1)) * 2]) && (var(58) = (1 + (random % 6))))
trigger2 = ((enemynear, movetype != a))
trigger3 = ((ailevel) && (enemynear, p2bodydist x = [0, (helper(99000), var(1)) * 2]) && (var(58) = (1 + (random % 6))))
trigger3 = ((enemynear, movetype = a))
value = 110



[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

[State 0, Power Charge]
type = ChangeState
triggerall = statetype != A
triggerall = power < 3000
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)*2
value = 500

[State 0, Power Charge End]
type = ChangeState
triggerall = time >= 12
triggerall = stateno = 500
triggerall = ailevel > 0
trigger1 = (p2bodydist x < 50) || (enemy,numproj > 0)
trigger2 = power = 3000
value = 501

[State 0, A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 30
trigger1 = random < (ailevel * 100)*2
value = 200

[State 0, B]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 50
trigger1 = random < (ailevel * 100)
value = 300

[State 0, C]
type = ChangeState
triggerall = power >= 200
triggerall = numhelper(450) = 0
triggerall = numhelper(455) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x >= 50
trigger1 = random < (ailevel * 100)/8
value = 400

[State 0, A Aire]
type = ChangeState
triggerall = statetype = A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 30
trigger1 = random < (ailevel * 100)
value = 600

[State 0, B Aire]
type = ChangeState
triggerall = statetype = A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 60
trigger1 = random < (ailevel * 100)*2
value = 610

[State 0, C Aire]
type = ChangeState
triggerall = power >= 200
triggerall = statetype = A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 50
trigger1 = random < (ailevel * 100)/2
value = 620

[State 0, Dash Execution]
type = ChangeState
triggerall = power >= 1000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x >= 81
trigger1 = random < (ailevel * 100)/2
value = 1000

[State 0, Kinshara Attacks]
type = ChangeState
triggerall = power >= 1000
triggerall = numhelper(1150) = 0
triggerall = numhelper(1151) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [-80,80]
trigger1 = random < (ailevel * 100)/2
value = 1100

[State 0, Arpeggio]
type = ChangeState
triggerall = power >= 1500
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [51,150]
trigger1 = random < (ailevel * 100)
value = 1200

[State 0, Shikai : Kinshara]
type = ChangeState
triggerall = power >= 1500
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [0,50]
trigger1 = random < (ailevel * 100)
value = 1400

[State 0, Kinshara S?kyoku Dai J?ichiban - Izayoi Bara]
type = ChangeState
triggerall = power >= 2000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x= [70,150]
trigger1 = random < (ailevel * 100)*2
value = 1600

[State 0, Kanadero kinshara]
type = ChangeState
triggerall = power >= 2000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x= [0,69]
trigger1 = random < (ailevel * 100)*2.25
value = 1500

[State 0, Bankai : Kinshara Butodan]
type = ChangeState
triggerall = power >= 3000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [0,200]
trigger1 = random < (ailevel * 100)*4
value = 3000
