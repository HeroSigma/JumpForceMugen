; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...
[Quotes]
victory1 = "You know how chess played...pieces must be sacrificed."
victory2 = "People can change.Or they die before they do.It's one or the other."
victory3 = "Hate only gives birth to even more hate."
victory4 = "I want to obtain all the techniques and gain a true understanding of everything in this world."
victory5 = "You see, I also want to find who I really am. That's why I'm collecting a bit of everything."
victory6 = "Only one who understands everything after spending such time on this can be fittingly called the Ultimate Being."
