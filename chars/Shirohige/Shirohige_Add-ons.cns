trigger1 = time = 0
trigger2 = Parent, stateno = [150,155]
trigger2 = var(32) >= 30
v = 32
value = 0
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
triggerall = var(32) = 0
trigger1 = var(30) <= 0
v = 32
value = 1
ignorehitpause = 1
[State 0, VarSet]
type = VarSet
triggerall = var(32) = 1
trigger1 = parent, stateno = 160
trigger2 = parent, stateno = 161
v = 32
value = 2
ignorehitpause = 1
[State 0, VarAdd] ; Este es el tiempo que dura el Guard Break (y el personaje no se puede defender)
type = VarAdd
triggerall = var(32) = [2,29]
trigger1 = time%20 = 0
v = 32
value = 1

