;----- Button Acept/Cancel System ------------
[State 0, VarSet]
type = VarSet
trigger1 = time = 0
v = 18
value = 0
[State 0, VarAdd]
type = VarAdd
triggerall = time > 20
trigger1 = root, command = "a"
trigger2 = root, command = "b"
trigger3 = root, command = "c"
trigger4 = root, command = "x"
trigger5 = root, command = "y"
trigger6 = root, command = "z"
v = 18
value = ifelse((var(18) = 1),-1,1)


[State 0, PlaySnd]
type = PlaySnd
triggerall = time > 20
trigger1 = root, command = "a"
trigger2 = root, command = "b"
trigger3 = root, command = "c"
trigger4 = root, command = "x"
trigger5 = root, command = "y"
trigger6 = root, command = "z"
value = F800,ifelse((var(18) = 1),3,2)
volume = 100
channel = 2





