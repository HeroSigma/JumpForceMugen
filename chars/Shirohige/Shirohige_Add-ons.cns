volume = 100
channel = 1

;---- Movelist Change Table  ---------
[State 0, VarSet]
type = VarSet
trigger1 = time  = 0
v = 17
value = 43

[State 0, VarAdd]
type = VarAdd
triggerall = var(17) < 48
triggerall = var(17) != 6
triggerall = var(17) != 12
triggerall = var(17) != 18
triggerall = var(17) != 24
triggerall = var(17) != 30
triggerall = var(17) != 36
triggerall = var(17) != 42
trigger1 = ifelse((parent,facing = 1),(parent,command = "fwd"),(parent,command = "back"))
v = 17
value = 1
[State 0, VarAdd]
type = VarAdd
triggerall = var(17) > 1
triggerall = var(17) != 7
triggerall = var(17) != 13
triggerall = var(17) != 19
triggerall = var(17) != 25
triggerall = var(17) != 31
triggerall = var(17) != 37
triggerall = var(17) != 43
trigger1 =ifelse((parent,facing = 1),(parent,command = "back"),(parent,command = "fwd"))
v = 17
value = -1

[State 0, VarAdd]
type = VarAdd
triggerall = var(17) <= 42
trigger1 = parent, command = "down"
v = 17
value = 6
[State 0, VarAdd]
type = VarAdd
triggerall = var(17) > 6
trigger1 = parent, command = "up"
v = 17
value = -6
