;trigger6 = stateno = 320 && helper(325),movehit && helper(325),time > 2
;trigger7 = stateno = 400 && helper(405),time >= 16 && helper(405),movecontact
helpertype = normal
name = "Helper de Conexiones"
ID = 700
stateno = 700
pos = 999999,999999
postype = p1

