value = S0,19
volume = 200

[State 1900, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S0,19
volume = 200

[State 1900, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S0,19
volume = 200

