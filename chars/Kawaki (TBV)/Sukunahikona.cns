; Kawaki Karma Auto-Absorb State
[Statedef 1930]
type    = S
movetype= I
physics = S
ctrl    = 0
velset  = 0,0
anim    = 1901   ; optional base animation
sprpriority = 3
poweradd = 0

;----------------------------------------
; Block / Absorb all incoming attacks
[State 1930, Absorb_NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1

;----------------------------------------
; HitDef to trigger absorb effect
[State 1930, Absorb_HitDef]
type = HitDef
trigger1 = movehit = 1
attr = S, ST
damage = 0
pausetime = 0,0
hitonce = 1
hitflag = MAF

;----------------------------------------
; Gain chakra / life on hit
[State 1930, Absorb_PowerAdd]
