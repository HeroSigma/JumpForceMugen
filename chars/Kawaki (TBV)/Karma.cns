value = 0

;------------------------------------
; Karma Idle Override
;------------------------------------
[Statedef 0]
type = S
physics = S
sprpriority = 0

; Karma Active → use custom idle
[State 0, Karma Idle]
type = ChangeAnim
triggerall = var(21) = 1
trigger1 = Anim != 19187
value = 19187

; Normal idle (fallback if not Kyubi)
[State 0, Normal Idle]
type = ChangeAnim
triggerall = var(21) = 0
trigger1 = Anim != 0
value = 0










