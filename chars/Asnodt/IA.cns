;===============================================================================
;---------------------------IA: ASNODT "THE FEAR"-------------------------------
;===============================================================================
;-------------------------------------------------------------------------------
[Statedef -2]

[State 0, Run]
type = ChangeState
triggerall = var(11) = 0
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 200
trigger1 = random < (ailevel * 100)/3
value = 60

[State 0, Run Atras]
type = ChangeState
triggerall = var(11) = 0
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 30
triggerall=  p2movetype = A
trigger1 = random < (ailevel * 100)/4
value = 70

[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

[State 0, Power Charge]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype != A
triggerall = power < 3000
triggerall = ailevel > 0
triggerall = ctrl
triggerall = p2bodydist x > 150
trigger1 = random < (ailevel * 100)/2
value = 500

[State 0, Power Charge End]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype != A
triggerall = time >= 12
triggerall = stateno = 500
triggerall = ailevel > 0
trigger1 = (p2bodydist x < 50) || (enemy,numproj > 0)
trigger2 = power = 3000
value = 501

[State 0, A]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [200,500]
trigger1 = random < (ailevel * 100)/2
trigger1 = Random = [600,800]
value = 200

[State 0, B]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 60
trigger1 = random < (ailevel * 100)/4
trigger2 = var(22) = 1
trigger2 = random < (ailevel * 100)/2
trigger1 = Random = [600,800]
value = 240

[State 0, C]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [50,250]
trigger1 = random < (ailevel * 100)/2
trigger1 = Random = [600,800]
value = 220

[State 0, A Aire]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype = A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [50,500]
triggerall = p2bodydist y = [-20,0]
trigger1 = random < (ailevel * 100)*2
trigger1 = Random = [600,800]
value = 600

[State 0, B Aire]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype = A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 40
triggerall = p2bodydist y = [-10,5]
trigger1 = random < (ailevel * 100)*2
value = 610

[State 0, C Aire]
type = ChangeState
triggerall = var(11) = 0
triggerall = statetype = A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [50,100]
triggerall = p2bodydist y < 10
trigger1 = random < (ailevel * 100)*2
value = 620

[State 0, SUPER 2: TRANSFORM]
type = ChangeState
triggerall = var(11) = 0
Triggerall = power >= cond(life<=lifemax/4,0,3000)
triggerall = life <= lifemax/2
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
trigger1 = random < (ailevel * 100)*2
value = 3600

[State 0, SUPER 1: BANKAI]
type = ChangeState
triggerall = var(11) = 0
triggerall = power >= 3000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)*2
value = 2500

[State 0, SUPER 2: NO TRANSFORM]
type = ChangeState
triggerall = var(11) = 0
triggerall = power >= 1000
triggerall = life > lifemax/2
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100
trigger1 = random < (ailevel * 100)*2
value = 3500

[State 0, SKILL 1: DF+A]
type = ChangeState
triggerall = var(11) = 0
triggerall = power >= 1000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = p2bodydist x = [200,600]
triggerall = ctrl || numhelper(700) > 0
trigger1 = random < (ailevel * 100)/2
trigger1 = Random = [100,200]
value = 1000

[State 0, SKILL 3: DF+B]
