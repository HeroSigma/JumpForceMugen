trigger1 = ailevel = 0 && command = "SPECIAL 3"
trigger2 = ailevel > 0 && p2bodydist x < 90 && p2bodydist x > 60 && random < (ailevel * 100)/3
value = 4700
[State 0, SPESIAL 4]
