;===============================================================================
;-----------------------------Susanoo Mode--------------------------------------
;-------------------------------------------------------------------------------
; Stand:
;-------------------------------------------------------------------------------
[Statedef 21000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 0
sprpriority = -2

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -40

[State 200, End]
type = ChangeState
trigger1 = ailevel = 0 && command = "holddown" && command = "s"
trigger2 = ailevel > 0 && random < (ailevel * 100)/50
trigger3 = !numhelper(21005)
trigger4 = roundstate != 2
value = 21001

[State 0, WALK FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x > 30
value = 21020

[State 0, WALK BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x < 30
value = 21021

[State 0, Run FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "FF"
trigger2 = ailevel > 0 && random < (ailevel * 100)
value = 21100

[State 0, Run BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "BB"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x < 75 && power < 500
value = 21105

[State -1, Susanoo Arrow]
type = ChangeState
Triggerall = power >= 1000 && !numhelper(22650)
trigger1 = ailevel = 0 && command = "x"
trigger2 = ailevel > 0 && random < (ailevel * 100)*3
trigger2 = P2BodyDist X > 100
value = 21600

[State -1, Amaterasu]
type = ChangeState
Triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "y"
trigger2 = RoundState = 2 && ailevel > 0 && random < (ailevel * 100)*1.5
value = 21700

[State -1, Sword of Kagutsuchi]
type = ChangeState
Triggerall = power >= 2000
trigger1 = ailevel = 0 && command = "z"
trigger2 = RoundState = 2 && ailevel > 0 && random < (ailevel * 100)*5
trigger2 = P2BodyDist X < 150
value = 21800

[State -1, A]
type = ChangeState
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 120
value = 21200

[State -1, B]
type = ChangeState
trigger1 = ailevel = 0 && command = "b"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 130
value = 21300

[State -1, C]
type = ChangeState
trigger1 = ailevel = 0 && command = "c"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 160
value = 21400

[State -1, Power Charge]
type = ChangeState
triggerall = power < powermax
trigger1 = ailevel = 0 && command != "holddown" && command = "s"
trigger2 = ailevel > 0 && random < (ailevel * 100)*((powermax-power)/1000)
trigger2 = P2BodyDist X >= 50
value = 21500
