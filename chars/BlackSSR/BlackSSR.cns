; Change Pallete
[State 0]
type = null
trigger1 = var(55) = 13
trigger1 = var(55) := 1
trigger2 = var(55) = 1
trigger2 = ifelse(teamside=2,command = "fwd",command = "back")
trigger2 = var(55) := 13

[State 0]
type = varadd
triggerall = var(13) > 1
trigger1 = command = "fwd" && teamside = 1
trigger2 = command = "back" && teamside = 2
var(55) = 1

[State 0]
type = varadd
triggerall = var(13) > 1
trigger1 = command = "back" && teamside = 1
trigger2 = command = "fwd" && teamside = 2
var(55) = -1

[State 0]
type = PlaySnd
triggerall = var(13) > 1
trigger1 = command = "fwd"
trigger2 = command = "back"
value = 7,0
abspan = 0

[State 0]
type = PlaySnd
trigger1 = var(13) < 1
value = 7,ifelse(ailevel != 0,-1,1)
abspan = 0
persistent = 0

[State 0]
type = VarSet
trigger1 = command = "up" || command = "down" || command = "s" 
trigger2 = ailevel != 0
var(13) = 0
persistent = 0

[State -2] ; Bar
type=explod
triggerall = var(13) > 1
trigger1=1
anim=9065
id = 9050
bindtime=-1
removetime=1
facing=1-(teamside=2)*2
ontop=1
ownpal=1
scale = const480p(0.7),const480p(1)
pos=ifelse(teamside=1,const480p(-40),const480p(50)),8
postype=p1
ontop = 1
ignorehitpause=1

[State -2] ; Change
type=explod
triggerall = var(13) > 1
trigger1=1
anim=9050
id = 9050
bindtime=-1
removetime=1
facing=1-(teamside=2)*2
ontop=1
ownpal=1
scale = const480p(1),const480p(1)
pos=ifelse(teamside=1,const480p(-20),const480p(30)),8
postype=p1
ontop = 1
ignorehitpause=1

[State -2] ; Ones
type = Explod
triggerall = var(13) > 1
trigger1 = 1
anim = 9051 +(var(55)%10)
id = 9050
bindtime = -1
removetime = 1
facing = 1-(teamside=2)*2
ontop = 1
ownpal = 1
scale = const480p(1),const480p(1)
pos = ifelse(teamside=1,const480p(58),const480p(-48)),8
postype = p1
ontop = 1
ignorehitpause = 1

[State -2] ; Tens
type = Explod
triggerall = var(13) > 1
trigger1 = var(55)>=1
anim = 9051 +((var(55)/10)%10)
id = 9050
bindtime = -1
removetime = 1
facing = 1-(teamside=2)*2
ontop = 1
ownpal = 1
scale = const480p(1),const480p(1)
pos = ifelse(teamside=1,const480p(44),const480p(-35)),8
postype = p1
ontop = 1
ignorehitpause = 1
