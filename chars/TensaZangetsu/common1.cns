; Initialize (at the start of the round)
[Statedef 5900]
type = S

[State 0]
Type = Null
triggerall = time > 0
Trigger1 = RoundNO = 1
Trigger1 = Var(57) := PalNO

[State 5900, 3] ;Change palette
Type = remappal
Trigger1 = 1
Source = 1,1
Dest = 1,Var(57)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = time = 0
value = 0

[State 5900, 1] ;Clear all int variables
type = VarRangeSet
trigger1 = roundsexisted = 0
value = 0

[State 5900, 2] ;Clear all float variables
type = VarRangeSet
trigger1 = roundsexisted = 0
fvalue = 0

[State 5900, 3] ;Intro for round 1
type = ChangeState
trigger1 = roundno = 1
value = 190
