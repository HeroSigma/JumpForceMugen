
;===============================================================================
; ASSIST SYSTEM:
;-------------------------------------------------------------------------------
[Statedef 4000]
type    = A
movetype= I
physics = N
anim = 9999
ctrl = 0

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = 0
y = 0
ignorehitpause = 1

;---------------------------------- Var System

[State 0, Game Start]
type = VarSet
trigger1 = !time 
v = 55
value = cond(roundstate=2,cond(roundno = 1,100,20),255)
ignorehitpause = 1
[State 0, Game Start]
type = VarSet
trigger1 = roundstate = 2
v = 55
value = cond(roundno = 1,100,20)
ignorehitpause = 1
persistent = 0

[State 0, Assist Ready]
type = VarSet
trigger1 = var(55) >= 255
v = 55   
value = 256
[State 0, Assist Cooldown]
type = VarAdd
triggerall = !numhelper(4100) 
triggerall = time
triggerall = timemod = 2,0;3,0
trigger1 = var(55) = [0,255]
v = 55   
value = 1  ;1

[State 0, Summon PLAYER Normal]
type = VarSet
triggerall = root,pos y > -200;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(19) = 0
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel = 0
trigger1 = root,command = "y"
v = 55   
value = -1
ignorehitpause = 1

;IA

[State 0, Summon IA Tokiko Normal]
type = VarSet
triggerall = var(58) = 1
triggerall = root,pos y > -80;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(19) = 0
triggerall = gametime > 500
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
trigger1= root,p2bodydist x = [0,45]
trigger1= enemynear,pos y>= -const(size.height)
trigger1= enemynear,statetype != L
trigger1= enemynear,vel x > -.7
trigger1= root,vel x < 3
v = 55   
value = -1
ignorehitpause = 1

[State 0, Summon IA Papillon Normal]
type = VarSet
triggerall = var(58) = 2
triggerall = root,pos y > -30;root,statetype != A
triggerall = root,movetype != H ;|| root,stateno != [120,155]
triggerall = root,var(19) = 0
triggerall = gametime > 500
triggerall = roundstate = 2
triggerall = var(55) > 255
triggerall = root,ailevel > 0
;trigger1= root,p2bodydist x = [0,55]
trigger1= enemynear,pos y>= -const(size.height)
trigger1= enemynear,statetype = L
trigger1= enemynear,vel x > -.7
trigger1= root,vel x < 3
v = 55   
value = -1
ignorehitpause = 1

