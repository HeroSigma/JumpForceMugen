; Haha hacia P2 - Start
[Statedef 9025]
type    = A
movetype= I
physics = N
juggle  = 1
ctrl = 0
anim = 8110
sprpriority = 3

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
x = helper(9000),pos x
y = -20

[State 0, Turn]
type = Turn
triggerall = p2bodydist x < - 30
trigger1 = time = 0

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
triggerall = time > 1
trigger1 = 1
x = 5

[State 200, 1]
type = HitDef
triggerall = !movecontact
trigger1 = 1
attr = A, SP
animtype  = heavy
damage    = 20,10
guardflag = MA
pausetime = 0,0
sparkno = -1
guard.sparkno = s7000
sparkxy = 0,0
hitsound   = -1
guardsound = -1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = 0,-2
air.velocity = 0,4
Fall = 0
getpower = 0,0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 1
value = S1,20
volume = 999

[State 200, End]
type = Destroyself
trigger1 = time >= 200
trigger2 = frontedgebodydist <= 0
trigger3 = backedgebodydist <= 0

[State 200, End]
type = Changestate
trigger1 = p2bodydist x < 10
value = 9030
