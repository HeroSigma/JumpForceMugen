;===============================================================================
; Puppet 1:
;-------------------------------------------------------------------------------
; Stand
[Statedef 9000]
type    = A
movetype= I
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 8100
sprpriority = 0

;-----------------------
[State 0, ChangeState]
type = Changestate
trigger1 = root,stateno = 21400
value = 9090

[State 0, 2 - 2]
type = ChangeState
trigger1 = root,stateno = 2400 && root,time = 1
value = 9025

[State 0, PosSet]
type = PosSet
trigger1 = 1
y = -20

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30
trigger2 = rootdist x < -40

[State 0, Walk FWD]
type = ChangeState
trigger1 = rootdist x > 40
value = 9020

[State 0, DestroySelf]
type = DestroySelf
trigger1 = time = -1

;-----------------------
[State 0, ChangeState]
type = Changestate
trigger1 = root,var(2) = 0
trigger2 = root,var(3) = 0
value = 3075

;-----------------------
[State 0, ChangeState]
type = Changestate
trigger1 = parent,win
trigger2 = parent,drawgame
trigger3 = parent,lose
value = 9099
