; Kazekage Puppet:
;-------------------------------------------------------------------------------
; Stance
[Statedef 3000]
type    = A
movetype= I
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 3000
sprpriority = 0

[State 200, LOSE, WIN, DEATH]
type = Changestate
trigger1 = root,stateno = [2000,2999]
trigger2 = root,var(2) = 1
trigger3 = root,var(3) = 1
value = 3075

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 200, WALK FWD]
type = Changestate
trigger1 = rootdist x > 30
value = 3020

[State 200, WALK BACK]
type = Changestate
trigger1 = rootdist x < -30
value = 3021

[State 200, WALK DOWN]
type = Changestate
triggerall = root,pos y <= 0
trigger1 = rootdist y > 20
value = 3025

[State 200, LOSE, WIN, DEATH]
type = Changestate
trigger1 = root,stateno = 170 && root,time = 30
trigger2 = root,stateno = 181 && root,time = 30
trigger3 = root,life = 0
value = 3170

[State 200, Combo 1 - 3]
type = Changestate
