triggerall = RoundState = 2 && var(20)
triggerall = StateType = A
triggerall = (p2statetype = S) || (p2statetype = C)|| (p2statetype = A)
triggerall = p2Movetype != H
triggerall = Ctrl
triggerall = p2dist x <= 40 && p2dist y = [-50,50]
trigger1 = Random = [20,40]
value = 640

[State -1,COMBO AIR- 2]
type = changestate
triggerall = RoundState = 2 && var(20)
triggerall = StateType = A
triggerall = (p2statetype = S)|| (p2statetype = A)
triggerall = p2Movetype != H
triggerall = Movetype != H
triggerall = P2stateno!=[5050,5120]
