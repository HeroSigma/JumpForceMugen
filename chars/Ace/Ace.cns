;===============================================================================
; Var List
;-------------------------------------------------------------------------------
;Var(1) = Used for random voices
;Var(2) = Used for random values
;Var(3) = Used for charged attacks
;Var(4) = Used for Air Dash limiter
;Var(5) = Used for OK text in intro
;Var(7) = Boundary Push
;Var(8) = Infinite Void
;Var(10) = Transformations (If character has any)
;Var(11) = HUD position
;Var(12) = RSD
;Var(57) = Palette Selector
;===============================================================================
; FVar List
;-------------------------------------------------------------------------------
;FVar(10) = Combo 1
;FVar(11) = Combo 2
;FVar(12) = Combo 3
;FVar(13) = Down A
;FVar(14) = Down B
;FVar(15) = Down C
;FVar(16) = Forward A
;FVar(17) = Backward A
;FVar(18) = Forward B
;FVar(19) = Backward B
;FVar(20) = Forward C
;FVar(21) = Backward C
;FVar(22) = Air A
;FVar(23) = Air B
;FVar(24) = Air C
;FVar(25) = Air Down A
;FVar(26) = Air Down B
;FVar(27) = Air Down C
;FVar(28) = A+B
;===============================================================================
; FVar List
;-------------------------------------------------------------------------------
;FVar(10) to FVar(30) Combo System
;-------------------------------------------------------------------------------
;===============================================================================
; States List
;------------------------------------------------------------------------------
;State 200-299 (Ground Attacks)
;State 400-499 (Crouch Attacks)
;State 500-599 (Power Charge)
;State 600-699 (Air Attacks)
;State 700-799 (Pop-Ups Lateral/Paletas)
;State 800-899 (HitSparks)
;State 900-989 (Special Button) 
;State 990-999 (Text Explods)
;State 1000-1600 (Specials)
;State 6000 (Guardbreak P2State)
;State 2000-2500 (Supers)
;State 3000-3999 (Ultimate)
;State 4000-4199 (Installs)
;State 6000-6999 (P2States)
;State 7000-7998 (Global FX)
;State 8000-8999 (Install Bar)
;State 9000-9001 (AfterImages)
;State 10000-10000 (P2States FX)
;State 11000-11000 (Clash)
;===============================================================================
; Sounds List
;------------------------------------------------------------------------------
;Group 200 (Melee Attack Movement)
;Group 201 (Melee Hit)
;Group 202 (Sword Attack Movement)
;Group 203 (Sword Hit)
;===============================================================================
; Channel List
;------------------------------------------------------------------------------
;Channel 25 (Ultimate Music)
;Channel 26 (Ultimate Music 2)
;Channel 26 (Ultimate SFX)
;Channel 27 (Secondary Intro SFX)
;Channel 28 (Intro SFX)
;Channel 29 (Secondary Intro Voice)
;Channel 30 (Intro Voices)
;------------------------------------------------------------------------------
[Data]
life = 1000			;Amount of life to start with
attack = 100		;attack power (more is stronger)
defence = 100		;defensive power (more is stronger)
fall.defence_up = 50	;Percentage to increase defense everytime player is knocked down
liedown.time = 60		;Time which player lies down for, before getting up
airjuggle = 15		;Number of points for juggling
sparkno = -1			;Default hit spark number for HitDefs
guard.sparkno = -1	;Default guard spark number
KO.echo = 0			;1 to enable echo on KO
IntPersistIndex = 57	;Variables with this index and above will not have their values
FloatPersistIndex = 40  ;reset to 0 between rounds or matches. There are 60 int variables,
  				;indexed from 0 to 59, and 40 float variables, indexed from 0 to 39.
  				;If omitted, then it defaults to 60 and 40 for integer and float
  				;variables repectively, meaning that none are persistent, i.e. all
  				;are reset. If you want your variables to persist between matches,
  				;you need to override state 5900 from common1.cns.


[Size]
xscale = .95			;Horizontal scaling factor.
yscale = .95			;Vertical scaling factor.
ground.back = 10		;Player width (back, ground)
ground.front = 10		;Player width (front, ground)
air.back = 8		;Player width (back, air)
air.front = 8		;Player width (front, air)
height = 59			;Height of player (for opponent to jump over)
attack.dist = 100		;Default attack distance
proj.attack.dist = 90	;Default attack distance for projectiles
proj.doscale = 0		;Set to 1 to scale projectiles too   
head.pos = 2, -45	;Approximate position of head
mid.pos = -2, -25		;Approximate position of midsection
shadowoffset = 0		;Number of pixels to vertically offset the shadow
draw.offset = 0,0		;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 1.5		;Walk forward
walk.back = -1.5		;Walk backward
run.fwd  = 0		;Run forward (x, y)
run.back = 0	;Hop backward (x, y)
jump.neu = 0,-8.4		;Neutral jumping velocity (x, y)
jump.back = -2.55		;Jump back Speed (x, y)
jump.fwd = 2.5		;Jump forward Speed (x, y)
runjump.back = -2.55,-8.1;Running jump speeds (opt)
runjump.fwd = 4,-8.1	;.
airjump.neu = 0,-8.1	;.
airjump.back = -2.55	;Air jump speeds (opt)
airjump.fwd = 2.5		;.

[Movement]
airjump.num = 1		;Number of air jumps allowed (opt)
airjump.height = 35	;Minimum distance from ground before you can air jump (opt)
yaccel = .44		;Vertical acceleration
stand.friction = .85	;Friction coefficient when standing
crouch.friction = .82	;Friction coefficient when crouching

[Quotes]
victory1 = "I'm gonna make Whitebeard the king."
victory2 = "You may be smoke but I'm fire."
victory3 = "Sorry, I'm not interested in living 1000 years. I just need to live today."
;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...

;---------------------------------------------------------------------------
; Lose by Time Over
; CNS difficulty: basic
[Statedef 170]
type = S
ctrl = 0
anim = 170
velset = 0,0

[State 0, VarSet]
type = VarSet
trigger1 = !time
v = 1
value = cond(random < 500,0,1)

[State 0, Voz]
type = PlaySnd
trigger1 = !time
value = S170,var(1)
[State 0, Voz]
type = PlaySnd
trigger1 = !time
value = S170,var(1)

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1
;---------------------------------------------------------------------------
; Win state decider
; CNS difficulty: basic
[Statedef 180]
type = S

[State 180, 1]
type = ChangeState
trigger1 = Time = 0
value = 181
