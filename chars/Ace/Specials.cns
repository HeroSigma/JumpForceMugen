triggerall = ailevel = 0
triggerall = var(3) >= 40 ;Limite
triggerall = command = "holdup"
trigger1 = time >= 12 && command = "hold_a"
value = 1005
ctrl = 1

[State 0, Normal]
type = ChangeState
triggerall = ailevel = 0
triggerall = var(3) < 40 ;Menor al limite
triggerall = command != "holdup"
