trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist y <= -25
value = 1004
ctrl = 1

[State 0, Charged Up]
type = ChangeState
triggerall = ailevel > 0
triggerall = var(3) >= 40 ;Limite
trigger1 = time >= 12 
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist y <= -25
value = 1005
