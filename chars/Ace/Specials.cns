[State 0,VarSet] ;Para que comience en 0
type = VarSet
trigger1 = !time
v = 3
value = 0
ignorehitpause = 1

[State 0,VarAdd] ;Para que vaya aumentando
type = VarAdd
trigger1 = time >= 12
trigger1 = ailevel = 0 &&command = "hold_a"
trigger2 = ailevel > 0 && time >= 12
trigger2 = numexplod(990)
v = 3
value = 6
ignorehitpause = 1

[State 0, Cargar]
type = Explod
triggerall = ailevel > 0
trigger1 = !time && cond(random<500,1,0)
anim = 9999
ID = 990
pos = 0,0
postype = P1  ;P2, Front, Back, Left, Right
facing = 1
vfacing = 1
bindtime = 0
removetime = -2
scale = 1,1
sprpriority = 3
ownpal = 1
removeongethit = 0
ignorehitpause = 1

[State 0, Normal Up]
type = ChangeState
triggerall = ailevel = 0
triggerall = var(3) < 40 ;Menor al limite
triggerall = command = "holdup"
trigger1 = time >= 12 && command != "hold_a"
value = 1004
ctrl = 1

[State 0, Charged Up]
