;---------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A

[State 0, VelAdd]
type = VelAdd
triggerall = time > 5 
triggerall = Vel X > -3
trigger1 = command = "holdback"
x = -0.50

[State 0, VelAdd]
type = VelAdd
triggerall = time > 5 
triggerall = Vel X < 3
trigger1 = command = "holdfwd"
x = 0.50

[State 50, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 50, 3]
type = ChangeAnim
trigger1 = Vel y > Const720p(-8)
trigger1 = SelfAnimExist(anim + 3)
trigger1 = anim >= 41 && anim <= 43
persistent = 0
value = Anim + 3
