ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos=-1,-41
mid.pos=-1,-25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
