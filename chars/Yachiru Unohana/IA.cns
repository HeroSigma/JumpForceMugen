;===============================================================================
;---------------------------Estados usados Siempre------------------------------
;===============================================================================
[Statedef -3]

[state 0]
type=angledraw
triggerall=(alive)
trigger1=cond(stateno=5000,time<=5,1)
value=cond(stateno=5000,5,cond(vel x!=0,-(atan(vel y/vel x)*(const(size.air.back))/pi),0))
scale=1,1+(sin((time/50.0)*(pi/2))*0.0125)
ignorehitpause=1

[State 0, VarSet]
type = VarSet
trigger1 = var(2) = 1
v = 12    ;fv = 10
value = 1

[State 0, Helper]
type = helper
triggerall = numhelper(7525) = 0
trigger1 = p2stateno = 8170
helpertype = Normal ;Player
name = "1"
ID = 7525
stateno = 7525
pos = 20,0
postype = P1    ;P2, Front, Back, Left, Right
facing = 1
ownpal = 1
size.xscale=.4
size.yscale=.4
[State 0, Helper]
type = helper
triggerall = numhelper(7526) = 0
trigger1 = p2stateno = 8171 || p2stateno= 8176
helpertype = Normal ;Player
name = "1"
ID = 7526
stateno = 7526
pos = 20,0
postype = P1    ;P2, Front, Back, Left, Right
facing = 1
persistent =0
ignorehitpause=1
ownpal = 1
size.xscale=.4
size.yscale=.4

[State 0, P2 - Thrown]
type = Helper
triggerall = p2movetype = H
triggerall = numhelper(8451) = 0
trigger1 = p2stateno = 8450
name = "P2 - Thrown"
ID = 8451
stateno = 8451
pos = 0,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
ignorehitpause = 1

[State 0, P2 - Crash in Wall Impact]
type = Helper
triggerall = numhelper(8460) = 0
trigger1 = p2stateno = 8459
name = "P2 - Crash in Wall Impact"
ID = 8460
stateno = 8460
pos = 0,-0
postype = p2
facing = 1
keyctrl = 0
ownpal = 1
ignorehitpause = 1
