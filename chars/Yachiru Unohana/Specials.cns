trigger1 = time = [0,200]
trigger1 = timemod = 8,0
helpertype = normal
name = "Kunai Explosivo"
ID = 1010
stateno = 1010
pos = 20,-20-random%15
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
size.xscale = .5
size.yscale = .5

[State 200, End]
type = ChangeState
Triggerall = time > 60
trigger1 = ailevel = 0 && command = "a" && power >= 700
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)
value = 1050

[State 0, Cancel]
type = ChangeState
Triggerall = time > 60
trigger1 = ailevel = 0 && command = "SPECIAL 3" && power >= 1000
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2 && (time >= 60)
value = 1200

[State 0, Cancel]
type = ChangeState
Triggerall = time > 60
trigger1 = ailevel = 0 && command = "SPECIAL 4" && power >= 1000
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2 && (time >= 60)
value = 1300

[State 0, Cancel]
type = ChangeState
Triggerall = time > 60
trigger1 = ailevel = 0 && command = "SPECIAL 5" && power >= 1000
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2 && (time >= 60)
value = 1400

[State 200, End]
type = ChangeState
trigger1 = time = 220
value = 0
ctrl = 1

