[Statedef 500]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
sprpriority = 2

[State 0, PowerAdd]
type = PowerAdd
triggerall = time >= 7
trigger1 = 1
value = 10

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 1
value = S0,74
channel = 7
loop = 3

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 3
value = S13,0
volume = 9999999999999999
channel = 8
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 3
value = S13,0
volume = 9999999999999999
channel = 9

[State 0, 0]
type = ChangeAnim
triggerall = facing = 1
trigger1 = Anim != 500
value = 500

[State 0, 1]
type = ChangeAnim
triggerall = facing != 1
trigger1 = Anim != 501
value = 501

[State 0, Explod] ;Aura
type = Explod ;Adiciona um explod (efeito) na tela
trigger1 = time = 0 ;Adiciona assim que o movimento começa
anim = 760 ;ID da animaçăo da aura
ID = 760 ;ID da aura, recomendo o mesmo da animaçăo
pos = -2,-10 ;Posiçăo da aura em X (Horizontal) e Y (Vertical), geralmente é só ajeitar o eixo X para alinhar com o char
postype = p1 ;Aparece no P1, ou seja no char, năo muda isso
facing = 1 ;Sempre virada para o mesmo lado do P1
vfacing = 1 ;Sempre virada para o mesmo lado do P1
bindtime = -1 ;Tempo para mudar o eixo de acordo com o P1, deixa -1
removetime = -1 ;Tempo para remover, deixa -1 pois ela é removida assim que o char sai do movimento
scale = 0.5,0.6 ;Tamanho da aura, se aumentar o valor aumenta o tamanho, se diminuir diminui
ownpal = 1 ;Deixa 1, isso é pra aura ter paleta própria
removeongethit = 1 ;É removida quando o char apanha, deixe sempre como 1
ignorehitpause = 1 ;Ignora os congelamentos de tela
sprpriority = 5 ;Fica acima do char, já que é uma aura
trans = add

