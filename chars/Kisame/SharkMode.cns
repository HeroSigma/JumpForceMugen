; Stand
[Statedef 10000]
type = S
physics = S
ctrl = 0
sprpriority = 0

[State 10000,1 ChangeAnim]
type = ChangeAnim
trigger1 =  Var(9) = 0
Trigger1 = Command!="holdup" && Command!="holddown"
trigger1 = Command!="holdfwd" && Command!="holdback"
triggerall = Anim!= 10000
trigger2 = Var(9)>0
trigger2 = vel x = 0 && Vel y = 0
value = 10000

[State 10000,2 Turn]
type = Turn
triggerall =  Anim = 10000
trigger1 = pos x > enemynear(ifelse((enemynear(0),alive),0,1)), pos x && facing = 1
trigger2 = pos x < enemynear(ifelse((enemynear(0),alive),0,1)), pos x && facing = -1

[State 10000, VelSet]
type = VelSet
trigger1 =  Var(9) = 0
trigger1 = Command!="holdfwd" && Command!="holdback"
x = 0

[State 10000, VelSet]
type = VelSet
trigger1 =  Var(9) = 0
trigger1 = Command!="holdup" && Command!="holddown"
trigger2 = Pos y<=-200
trigger3 = Pos y>=-1
y = 0

[State 1000, AngleDraw]
type = AngleDraw
trigger1 =  Vel x != 0 && Vel y != 0
trigger1 = Anim = 10020
value = ((ATan(vel y/vel x*Cond(vel x<0,1,-1)))*(180.0/PI))

[State 1000, AngleDraw]
type = AngleDraw
trigger1 =  Vel x != 0 && Vel y != 0
trigger1 = Anim = 10021
value = ((ATan(vel y/vel x*Cond(vel x<0,-1,1)))*(180.0/PI))

[State 1000, VelSet]
Type = VelSet
trigger1 =  Var(9) = 0
Trigger1 = Command!="holdup" && Command!="holddown"
trigger1 = Command!="holdfwd" && Command!="holdback"
X = -cos(time*0.05)*0.3
Y = cos(time*0.05)*0.2

;SharK Moves
[State 10000, ]
type = VelSet
trigger1 = Var(9) = 0
trigger1 = command = "holdfwd"
x = 12

[State 10000, ]
type = VelSet
trigger1 = command = "holdback"
x = -12

[State 10000, ]
type = VelSet
trigger1 = Pos y>-200
trigger1 = Var(9) = 0
trigger1 = command = "holdup"
y = -8

[State 10000, ]
type = VelSet
trigger1 = Pos y<0
trigger1 = Var(9) = 0
trigger1 = command = "holddown"
y = 8

[State 10000, ]
type = VelSet
trigger1 = Var(9) = 1
trigger1 = P2bodydist x>20
trigger1 = P2MoveType!=A
trigger1 = random<var(50)*1.1
x = 12
y = P2dist y/5

[State 10000, ]
type = VelSet
trigger1 = Var(9) = 1
trigger1 = P2bodydist x <=20
x = 0
y = 0

[State 10000, ]
type = ChangeAnim
triggerall = Var(9) = 0
triggerall = vel x > 0 && command = "holdfwd"
trigger1 = Anim != 10020 && Anim != 10005
trigger2 = Anim = 10005 && AnimTime = 0
value = 10020

[State 10000, ]
type = ChangeAnim
triggerall = Var(9) = 1
triggerall = Vel x > 0
trigger1 = Anim != 10020 && Anim != 10005
trigger2 = Anim = 10005 && AnimTime = 0
value = 10020


[State 10000, ]
type = ChangeAnim
triggerall = Var(9) = 0
triggerall = vel x < 0 && command = "holdback"
trigger1 = Anim != 10021 && Anim != 10005
trigger2 = Anim = 10005 && AnimTime = 0
value = 10021

[State 10000, ChangeState]
type = ChangeState
trigger1 = command = "a"
trigger1 = Command!="holddown"
trigger1 = Var(9) = 0
trigger2 = var(9) = 1
trigger2 = P2bodydist x<=40
trigger2 = P2dist y>-20
trigger2 = P2movetype!=A
trigger2 = !Win || !Lose|| !Drawgame
trigger2 = Var(3)>=50
trigger2 = random<var(50)*1.1
trigger2 = P2Movetype!=H
trigger2 = P2stateno!=[5000,5201]
value = 10200
ctrl = 0

[State 10000, ChangeState]
type = ChangeState
trigger1 = command = "b"
trigger1 = Command!="holddown"
trigger1 = Var(9) = 0
trigger2 = var(9) = 1
trigger2 = P2bodydist x>=40
trigger2 = P2dist y>-20
trigger2 = P2movetype!=A
trigger2 = !Win || !Lose|| !Drawgame
trigger2 = Var(3)>=80
trigger2 = random<var(50)*1.1
trigger2 = P2Movetype!=H
trigger2 = P2stateno!=[5000,5201]
value = 10240
ctrl = 0

[State 10000, ChangeState]
type = ChangeState
trigger1 = command = "c"
trigger1 = Command!="holddown"
trigger1 = Var(9) = 0
trigger2 = var(9) = 1
trigger2 = P2bodydist x>=60
trigger2 = P2dist y>-20
trigger2 = P2movetype!=A
trigger2 = !Win || !Lose|| !Drawgame
trigger2 = Var(3)>=50
trigger2 = random<var(50)*1.1
trigger2 = P2Movetype!=H
trigger2 = P2stateno!=[5000,5201]
value = 10250
ctrl = 0

[State 10000, ChangeState]
type = ChangeState
trigger1 = command = "hold_s"
triggerall = power<powermax
trigger1 = Command!="holddown"
trigger1 = Var(9) = 0
trigger2 = var(9) = 1
trigger2 = P2bodydist x>=60
trigger2 = P2movetype!=A
