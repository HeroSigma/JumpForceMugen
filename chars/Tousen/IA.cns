[Statedef -3]
[State 0, HELPER ESCALA]
type = Helper
trigger1 = NUMHELPER(999999) = 0
helpertype = normal
name = "HELPER ESCALA"
ID = 999999
stateno = 999999
pos = 9999,9999
postype = P1
facing = 1
keyctrl = 0
ownpal = 1
supermove = 999999
pausemove = 999999
supermovetime = 999999
pausemovetime = 999999

[State 0, Trans]
type = Trans
triggerall = stateno = 2900
trigger1 = numhelper(2950) > 0 && p2bodydist x = [-999999,999999]
stateno = 2925
time = 1
ignorehitpause = 1
trans = add
alpha = 256,0

[State 0, Trans]
type = Trans
trigger1 = numhelper(2950) > 0 && p2bodydist x = [-999999,999999]
stateno = 2925
time = 1
ignorehitpause = 1
trans = add
alpha = 0,256


[State 0, HitOverride]
type = HitOverride
trigger1 = numhelper(2950) > 0 && p2bodydist x = [-999999,999999]
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = 2925
time = 1
ignorehitpause = 0
