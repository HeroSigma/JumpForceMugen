ontop = 1

[State 0, ExplodBindTime]
type = ExplodBindTime
trigger1 = command = "hold_z"
ID = 6035
time = 10

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = !command = "hold_z"
trigger1 = power = powermax
id =  6035

[State 0, EnvShake]
type = EnvShake
trigger1 = timemod = 5,0
time = 5
freq = 44
ampl = -2
phase = 44

[State 0, PowerAdd]
type = PowerAdd
trigger1 = 1
value = Ceil(fvar(0))+(fvar(1))

[State 0, VarAdd]
type = VarAdd
trigger1 = Fvar(0) < 10.0
fv = 0
value = 0.1

[State 0, VarSet]
type = VarSet
trigger1 = Time < 2
fv = 0
value = 0

[State 0, VarSet]
type = VarSet
trigger1 = time > 2
fv = 1
value = 0.1

[State 0, ChangeState]
type = ChangeState
trigger1 = command != "hold_z"
trigger2 = power = powermax
value = 196
ctrl = 0
