;===============================================================================
;----------------------Doppelman------------------------------------------------
;===============================================================================
;-------------------------------------------------------------------------------
; Stand
[Statedef 4000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 4000
sprpriority = 1

[State 0, Trans]
type = Trans
trigger1 = 1
trans = Sub

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 200, WALK FWD]
type = ChangeState
Triggerall = root,stateno = 400
trigger1 = root,ailevel = 0 && (ifelse(facing = root,facing,root,command = "holdfwd",root,command = "holdback"))
trigger2 = root,ailevel > 0 && p2bodydist x > 60 && random < (root,ailevel * 100)/2
value = 4020

[State 200, WALK BACK]
type = ChangeState
Triggerall = root,stateno = 400
trigger1 = root,ailevel = 0 && (ifelse(facing = root,facing,root,command = "holdback",root,command = "holdfwd"))
value = 4021

[State 200, Belly Smash]
type = ChangeState
Triggerall = root,stateno = 400
Triggerall = power >= 1000
trigger1 = root,ailevel = 0 && (ifelse(facing = root,facing,root,command  = "SPECIAL 1",root,command = "SPECIAL 2"))
trigger2 = root,ailevel > 0 && p2bodydist x = [100,200]
trigger2 = random < (root,ailevel * 100)/6
trigger3 = root,ailevel > 0 && p2bodydist x = [50,100]
trigger3 = random < (root,ailevel * 100)/8
value = 4500

[State 200, Kage Kakumei]
type = ChangeState
Triggerall = root,stateno = 400
Triggerall = power >= 1000
trigger1 = root,ailevel = 0 && (ifelse(facing = root,facing,root,command  = "SPECIAL 2",root,command = "SPECIAL 1"))
trigger2 = root,ailevel > 0 && p2bodydist x < 60
trigger2 = random < (root,ailevel * 100)/6
value = 4600

[State 200, Brick Bat]
type = ChangeState
Triggerall = root,stateno = 400
Triggerall = power >= 1000
trigger1 = root,ailevel = 0 && (ifelse(facing = root,facing,root,command  = "SPECIAL 3",root,command = "SPECIAL 4"))
trigger2 = root,ailevel > 0 && p2bodydist x = [50,100]
trigger2 = random < (root,ailevel * 100)/6
trigger3 = root,ailevel > 0 && p2bodydist x = [100,150]
trigger3 = random < (root,ailevel * 100)/8
value = 4700

[State 200, Bat Tornado]
type = ChangeState
Triggerall = root,stateno = 400
Triggerall = power >= 1000
trigger1 = root,ailevel = 0 && (ifelse(facing = root,facing,root,command  = "SPECIAL 4",root,command = "SPECIAL 3"))
trigger2 = root,ailevel > 0 && p2bodydist x < 60
trigger2 = random < (root,ailevel * 100)/6
value = 4800

[State 200, A]
type = ChangeState
Triggerall = root,stateno = 400
trigger1 = root,ailevel = 0 && root,command  = "a"
trigger2 = root,ailevel > 0 && p2bodydist x < 60 && random < (root,ailevel * 100)/4
value = 4200

[State 200, B]
type = ChangeState
Triggerall = root,stateno = 400
trigger1 = root,ailevel = 0 && root,command  = "b"
trigger2 = root,ailevel > 0 && (p2bodydist x = [-50,100]) && random < (root,ailevel * 100)/8
value = 4300

[State 200, End]
type = ChangeState
trigger1 = root,stateno != 400
value = 4002
