;-------------------------------------------------------------------------------
; CGL
[Statedef 4005]
type    = A
movetype= I
physics = N
sprpriority = 0

[State 0, BindToParent]
type = BindToParent
trigger1 = 1
pos = 0,0

[State 0, PalFXWiz]
type = PalFX
trigger1 = 1
time = 9999999999
add = -20,-100,0
mul = 550,500,500
color = 0

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = Parent,anim
elem = Parent,animelemno(0)

[State 0, Trans]
type = Trans
trigger1 = 1
trans = Add

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 0, Turn]
type = Turn
trigger1 = facing != parent,facing

[State 3000, SuperPause]
type = SuperPause
triggerall = parent,time = 1
Trigger1 = parent,stateno = 4500
Trigger2 = parent,stateno = 4600
Trigger3 = parent,stateno = 4700
Trigger4 = parent,stateno = 4800
time = 29
movetime = 29
anim = -1
sound = -1
pos = 32,-80
darken = 0
unhittable = 1

[State 200, End]
type = Destroyself
trigger1 = parent,stateno = 4002 && parent,animtime = 0
trigger2 = parent,stateno = 4701
trigger3 = parent,stateno = 4801
;-------------------------------------------------------------------------------
; Ojos
[Statedef 4010]
type    = A
movetype= I
physics = N
sprpriority = 3

[State 0, BindToParent]
type = BindToParent
trigger1 = 1
pos = 0,0

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = Parent,anim+10
elem = Parent,animelemno(0)

[State 0, Trans]
type = Trans
trigger1 = 1
trans = Add

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 0, Turn]
type = Turn
trigger1 = facing != parent,facing

[State 3000, SuperPause]
type = SuperPause
triggerall = parent,time = 1
Trigger1 = parent,stateno = 4500
Trigger2 = parent,stateno = 4600
Trigger3 = parent,stateno = 4700
Trigger4 = parent,stateno = 4800
time = 29
movetime = 29
anim = -1
sound = -1
pos = 32,-80
darken = 0
unhittable = 1

[State 200, End]
type = Destroyself
trigger1 = parent,stateno = 4002 && parent,animtime = 0
trigger2 = parent,stateno = 4701
trigger3 = parent,stateno = 4801
