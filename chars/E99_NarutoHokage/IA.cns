; Sonidos Comunes:
;-------------------------------------------------------------------------------
[State 0, Run]
type = PlaySnd
triggerall = stateno = 11060||stateno = 11070
trigger1 = time = 1
value = S60,0
volume = 50

[State 0, Golpeado]
type = PlaySnd
triggerall = stateno != [10000,10999] ; Kurama
triggerall = stateno != [1600,1651] ; Doton
trigger1 = movetype=H && (stateno!=[0,155]) && !time && HitOver=0 && random%3=0
value = 5000,ifelse(random < 500,0,ifelse(random < 500,1,ifelse(random < 500,2,3)))

[State 0, Solucion Stand Aire]
type = ChangeState
