trigger4 = (stateno = 600||stateno = 610||stateno = 620) && movecontact
trigger5 = (stateno = 350||stateno = 618) && movecontact
helpertype = normal
name = "Helper de Conexiones"
ID = 700
stateno = 700
pos = 999999,999999
postype = p1

