ignorehitpause = 1

[State 0, Width]
type = Width
trigger1 = stateno != 10002
trigger1 = stateno != 10001
trigger1 = stateno = [10000,11000]
trigger2 = stateno = 10001 && time >= 50
trigger3 = stateno = 10002 && time < 25
edge = 20,20
player = 20,20
ignorehitpause = 1

