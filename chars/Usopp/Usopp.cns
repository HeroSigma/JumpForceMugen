trigger3 = enemy,name = "Shanks" && time < 240
trigger4 = enemy,name = "Smoker" && time < 420
flag = roundnotover

[State 0, AssertSpecial]
type = AssertSpecial
triggerall = enemy,name != "Luffy"
triggerall = enemy,name != "Perona"
triggerall = enemy,name != "Shanks"
triggerall = enemy,name != "Smoker"
trigger1 = fvar(1) = 0 && time < 120
trigger2 = fvar(1) = 1 && time < 420
trigger3 = fvar(1) = 2 && time < 180
trigger4 = fvar(1) = 3 && time < 360
trigger5 = fvar(1) = 4 && time < 180
trigger6 = fvar(1) = 5 && time < 180
flag = roundnotover

[State 0, ChangeAnim]
