;===============================================================================
; Stand
;===============================================================================
[Statedef 0]
Type 		= S
Physics 		= S
SprPriority 		= 1

[State 0, 1]
Type 		= ChangeAnim
Trigger1 		= (Anim != 0 && Anim != 5 && Anim != 2000 && Anim != 2005 && Anim != 11000 && Anim != 11005 && Anim != 13000 && Anim != 13005 && Anim != 15000 && Anim != 15005 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
Trigger2 		= (Anim = 5 || Anim = 2005 || Anim = 11005 || Anim = 13005|| Anim = 15005 || Anim = 17005 || Anim = 19005) && !AnimTime
Value 		= 0

[State 0, 2]
Type 		= VelSet
Trigger1 		= !Time
Y 		= 0
[State 0, 3]
Type 		= VelSet
Trigger1 		= ABS (Vel X) < 2
Trigger2 		= Time = 4
X 		= 0

[State 0, 5]
Type 		= ChangeState
Trigger1 		= !Alive
Value 		= 5050

[State 0, 4]
Type 		= DestroySelf
Trigger1 		= IsHelper
;===============================================================================
; Stand to Crouch
;===============================================================================
[Statedef 10]
Type    		= C
Physics 		= C
Anim 		= 10

[State 10, 1]
Type 		= VelMul
Trigger1 		= !Time
X 		= 0.75

[State 10, 2]
Type 		= ChangeState
Trigger1 		= !AnimTime
Value 		= 11
;===============================================================================
; Crouching
;===============================================================================
[Statedef 11]
Type   		= C
Physics 		= C
SprPriority 		= 0
Anim 		= 11

[State 11, 1]
Type 		= ChangeAnim
Trigger1 		= Anim = 6
Value 		= 6

[State 11, 2]
Type 		= ChangeAnim
Trigger1 		= (Anim != 11 && Anim != 6 && Anim != 2011 && Anim != 2006 && Anim != 11011 && Anim != 11006 && Anim != 13011 && Anim != 13006 && Anim != 15011 && Anim != 15006 && Anim != 17011 && Anim != 17006 && Anim != 19011 && Anim != 19006)
Trigger2 		= (Anim = 6 || Anim = 2006 || Anim = 11006 || Anim = 13006|| Anim = 15006 || Anim = 17006 || Anim = 19006) && !AnimTime
Value 		= 11
;===============================================================================
; Crouch to Stand
;===============================================================================
[Statedef 12]
Type    		= S
Physics 		= S
Anim 		= 12

[State 12, 1]
Type 		= ChangeState
Trigger1 		= !AnimTime
Value 		= 0
;===============================================================================
; Walk
;===============================================================================
[Statedef 20]
Type    		= S
Physics 		= S
SprPriority 		= 0

[State 20, 1]
Type 		= VelSet
Trigger1 		= (!AiLevel) && (Command = "holdfwd")
Trigger2 		= (AiLevel) && P2BodyDist X = [20,100]
X 		= Const(Velocity.Walk.Fwd.X)
[State 20, 2]
Type 		= VelSet
Triggerall		= Time >= 3
Trigger1 		= (!AiLevel) && (Command = "holdback") 
Trigger2 		= (AiLevel) && P2BodyDist X = [-100,-20]
X 		= Const(Velocity.Walk.Back.X)

[State 20, 3]
Type 		= ChangeAnim
Triggerall 		= Vel X > 0
Trigger1 		= (Anim != 20 && Anim != 5 && Anim != 2020 && Anim != 2005 && Anim != 11020 && Anim != 11005 && Anim != 13020 && Anim != 13005 && Anim != 15020 && Anim != 15005 && Anim != 17020 && Anim != 17005 && Anim != 19020 && Anim != 19005)
Trigger2 		= (Anim = 5 || Anim = 2005 || Anim = 11005 || Anim = 13005 || Anim = 15005 || Anim = 17005 || Anim = 19005) && !AnimTime
Value 		= 20
[State 20, 4]
Type 		= ChangeAnim
Triggerall 		= Vel X < 0
Trigger1 		= (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005 && Anim != 11021 && Anim != 11005 && Anim != 13021 && Anim != 13005 && Anim != 15021 && Anim != 15005 && Anim != 17021 && Anim != 17005 && Anim != 19021 && Anim != 19005)
Trigger2 		= (Anim = 5 || Anim = 2005 || Anim = 11005 || Anim = 13005 || Anim = 15005 || Anim = 17005 || Anim = 19005) && !AnimTime
Value 		= 21

[State 12, 1]
Type 		= ChangeState
Trigger1 		= (AiLevel) && (P2BodyDist X = [-10, 10])
Value 		= 0
;===============================================================================
; Jump Start
;===============================================================================
[Statedef 40]
Type 		= S
Physics 		= S
SprPriority 		= 1
Ctrl 		= 0
Anim 		= 40

[State 40, 1]
Type 		= VarSet
Trigger1 		= !Time
Sysvar(1) 		= 0
[State 40, 2]
Type 		= VarSet
Trigger1 		= (!AiLevel) && Command = "holdfwd"
Trigger2 		= (AiLevel) && P2BodyDist X >= 20
Sysvar(1) 		= 1
[State 40, 3]
Type 		= VarSet
Trigger1 		= (!AiLevel) && Command = "holdback"
Trigger2 		= (AiLevel) && P2BodyDist X <= -20
Sysvar(1) 		= -1

[State 40, 4]
Type 		= VelSet
Trigger1 		= !AnimTime
X 		= Ifelse(Sysvar(1) = 0, Const(Velocity.jump.neu.x), Ifelse(Sysvar(1) = 1,  Const(Velocity.jump.fwd.x), Const(Velocity.jump.back.x)))
Y 		= Const(Velocity.jump.y)
[State 40, 5]
Type 		= VelSet
Trigger1 		= !AnimTime
Trigger1 		= Sysvar(1) = 1
Trigger1 		= PrevStateno = 100
X 		= Const(Velocity.runjump.fwd.x)

[State 40, 6]
Type 		= ChangeState
Trigger1 		= !AnimTime
Value 		= 50
Ctrl 		= 1
;===============================================================================
; AirJump Start
;===============================================================================
[Statedef 45]
Type 		= A
Physics 		= N
VelSet 		= 0, 0
Ctrl 		= 0

[State 45, 1]
Type 		= ChangeAnim
Trigger1 		= SelfAnimExist(44)
Value 		= 44
[State 45, 2]
Type 		= ChangeAnim
Trigger1 		= !SelfAnimExist(44)
Value 		= 41

[State 45, 3]
Type 		= VarSet
Trigger1 		= !Time
Sysvar(1) 		= 0
[State 45, 4]
Type 		= VarSet
Trigger1 		= Command = "holdfwd"
Sysvar(1) 		= 1
[State 45, 5]
Type 		= VarSet
Trigger1 		= Command = "holdback"
Sysvar(1) 		= -1

[State 45, 6]
Type 		= VelSet
Trigger1 		= Time = 2
X 		= Ifelse(Sysvar(1) = 0, Const(Velocity.airjump.neu.x), Ifelse(Sysvar(1) = 1, Const(Velocity.airjump.fwd.x), Const(Velocity.airjump.back.x)))
Y 		= Const(Velocity.airjump.y)

[State 45, 7]
Type 		= ChangeState
Trigger1 		= Time = 2
Value 		= 50
Ctrl 		= 1
