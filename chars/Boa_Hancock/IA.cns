[State Stand Air - Fix]
Type 		= ChangeState
Triggerall 		= (StateNo = 0 || StateNo = 20)
Trigger1 		= Pos y < 0
Value 		= 50
Ctrl 		= 1

[State Pallete]
Type 		= RemapPal
Trigger1 		= 1
Source 		= 1, 1
Dest 		= 1, Var(55)
IgnoreHitPause 	= 1

[State StopAfterImage]
Type 		= AfterImageTime
Trigger1 		= StateNo != 70
Trigger1 		= StateNo != 80
Trigger1 		= StateNo != 350
Trigger1 		= StateNo != 1350
Trigger1 		= StateNo != [3000, 3002]
Time 		= 1
IgnoreHitPause 	= 1

[State CtrlSet]
Type 		= CtrlSet
Trigger1 		= (!AiLevel) && (PrevStateNo = [401, 404]) && (Time >= 5)
Trigger2 		= (AiLevel) && (PrevStateNo = [401, 404]) && (Time >= 0)
Value 		= 1

[State Power]
Type 		= PowerAdd
Trigger1 		= (StateNo != [170, 199]) && (StateNo != [200, 1500])
Value 		= Cond((MoveType = H || StateType = L), 3, 1)

[State NotHitBy]
Type 		= NotHitBy
Trigger1 		= StateNo = [60, 75]
Trigger2 		= StateNo = 350 && Vel Y > 5
Value 		= SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT

[State RemoveExplod]
Type 		= RemoveExplod
Trigger1		= StateNo != 350
Trigger2		= MoveType = H
ID 		= 7017
[State RemoveExplod]
Type 		= RemoveExplod
Trigger1		= StateNo != 500
Trigger2		= MoveType = H
ID 		= 530
[State RemoveExplod]
Type 		= RemoveExplod
Trigger1		= StateType = L || MoveType = H || StateNo = 500 || (StateNo = [5000,5150])
ID 		= 755
[State 0, RemoveExplod]
Type 		= RemoveExplod
Trigger1		= StateNo != 901
Trigger2		= MoveType = H
ID 		= 905
[State 0, RemoveExplod]
Type 		= RemoveExplod
Trigger1		= StateNo != 901
Trigger2		= MoveType = H
ID 		= 906
[State Anti-Bug]
type 		= PosSet
Trigger1 		= Pos Y > 50
Trigger2 		= (StateNo = [405,408]) && Pos Y > 0
Trigger3 		= (PrevStateNo = [405,408]) && Pos Y > 0
Y 		= 0

