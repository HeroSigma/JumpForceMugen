[Statedef -1]

;Moviments

[State -1, Dash Forward]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != C) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command = "ff")
Trigger2 		= (AiLevel)&& Cond((Power >= (PowerMax / 2)), (Random < (AiLevel * 100) * 10), (Random < (AiLevel * 100) / 15)) && (FrontEdgeBodyDist > 50 && (P2BodyDist X >= 50 && (P2BodyDist Y = [-30,30])) && !NumHelper(117) && Enemy, MoveType != A)
Value 		= 60
[State  -1, Dash Backward]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != C) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command = "bb")
Trigger2 		= (AiLevel) && Random < (AiLevel * 100) * 5 && (BackEdgeBodyDist > 50 && (EnemyNear, P2BodyDist X = [-5, 50]) && (P2BodyDist Y = [-20,20]) && !NumHelper(117) && (EnemyNear, MoveType = A))
Value 		= Ifelse((Pos Y != 0), 75, 70)
[State  -1, IA Guard]
Type		= ChangeState
Triggerall		= Ctrl && (AiLevel) && (RoundState = 2)
Trigger1		= InGuardDist && Random < (AiLevel * 100) || (P2BodyDist X < 50 && (EnemyNear, MoveType = A)) || (Enemy,NumProj > 0)
Value		= Cond(StateType = A, 132, Cond(StateType = C, 131, Cond(StateType = S, 130, 130)))
[State  -1, Super Jump]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command = "s_jump")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) / 3) && (P2BodyDist X != [-15,15]) && P2BodyDist Y < -75 && P2MoveType != A
Value 		= 80
[State  -1, Walk]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = S) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command = "fwd") || (!AiLevel) && (Command = "back")
Trigger2		= (AiLevel) && ((Random < (AiLevel * 100)) && (P2BodyDist X != [-10, 10]) && EnemyNear, MoveType != A)
Value 		= 20

;Basics_Atacks

[State -1, A]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = S) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command != "spc1" && Command != "spc2" && Command != "holddown" && Command = "a")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 30 && ((EnemyNear, P2BodyDist X <= 10) && (P2BodyDist Y = [-5, 15])) && !Var(6))
Value 		= 200
[State -1, Down A]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command = "holddown" && Command = "a")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) && (P2BodyDist X <= 10 && (P2BodyDist Y = [-5, 15])) && !Var(6))
Value 		= 230
[State -1, Air A]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = A) && (RoundState = 2) && (Alive) && PrevStateNo != 250
Trigger1 		= (!AiLevel) && (Command = "a")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 20 && ((P2BodyDist X = [-5,30]) && (P2BodyDist Y = [-10, 10])) && !Var(6))
Value 		= 250
[State -1, B]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = S) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command != "spc3" && Command != "spc4" && Command != "holddown" && Command = "b")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 30 && (P2BodyDist X <= 30 && (P2BodyDist Y = [-5, 15])) && !Var(6))
Value 		= 300
[State -1, Down B]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && (Alive)
Trigger1 		= (!AiLevel) && (Command = "holddown" && Command = "b")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) / 10 && (P2BodyDist X <= 10 && (P2BodyDist Y = [-5, 20])) && !Var(6))
Value 		= 330
[State -1, Air B]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = A) && (RoundState = 2) && (Alive) && Pos Y <= -25
Trigger1 		= (!AiLevel) &&  (Command = "b")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 30 && ((P2BodyDist X = [-10, 10]) && P2BodyDist Y > 5)   && Pos Y <= -50 && !Var(6))
Value 		= 350
[State -1, Pistol Kiss]
Type 		= ChangeState
Triggerall 		= Ctrl && (RoundState = 2) && (Alive) && Power >= (PowerMax / 15)
Trigger1 		= (!AiLevel) && (Command != "spc5" && Command != "spc6" && Command = "c")
Trigger2		= (AiLevel) && (Random < (AiLevel * 100) / 30) && (((P2BodyDist X >= 10) && (P2BodyDist Y = [-5,5])) && (P2BodyDist X != [-10,10]) && !Var(6) && (PrevStateNo != [400, 408]))
Trigger3		= (AiLevel) && (Random < (AiLevel * 100) / 40) && (P2BodyDist X = [0 + (P2Dist Y / 1),100 + (P2Dist Y / 1)]) && (P2BodyDist X != [-10,10]) && !Var(6) && (PrevStateNo != [400, 408])
Trigger4 		= (AiLevel) && (Random < (AiLevel * 100) / 40) && (P2BodyDist Y <= -20 && (P2BodyDist X = [5 - (P2Dist Y / 5), 50 - (P2Dist Y)])) && (P2BodyDist X != [-10,10]) && !Var(6) && (PrevStateNo != [400, 408])
Value 		= Ifelse((Pos Y < 0), 405, 400)
[State -1, Power Charge]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = S) && (RoundState = 2) && (Alive) && (Power != PowerMax)
Trigger1 		= (!AiLevel) && (Command = "s")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 5) && (P2BodyDist X >= 75 && P2MoveType != A)
Value 		= 500

;Skills

[State -1, Hancock Pose]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = S) && (RoundState = 2) && Power >= (PowerMax / 6)
Trigger1 		= (!AiLevel) && (Command = "spc1")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) && ((P2BodyDist X = [0,20]) && (P2BodyDist Y = [-15,15])) && !Var(6))
Value 		= 1000
[State -1, Charm]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && Power >= (PowerMax / 6)
Trigger1 		= (!AiLevel) && (Command = "spc2")
Trigger2 		= (AiLevel) && Cond((EnemyNear, MoveType = A), (Random < (AiLevel * 100) * 10), (Random < (AiLevel * 100) / 20)) && ((P2BodyDist X = [0, 65]) && (P2BodyDist Y = [-15,15])) && !Var(6) && (P2StateNo != 1207 && P2StateNo != 1560 && P2StateNo != 1565)
Value 		= 1100
[State -1, Up Pistol Kiss]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && Power >= (PowerMax / 3)
Trigger1 		= (!AiLevel) && (Command = "spc3")
Trigger2 		= (AiLevel) && ((Random < (AiLevel * 100) * 5) && ((P2BodyDist X = [-15, 15]) && (P2BodyDist Y <= -100)) && PrevStateNo != 1300)
Value 		= 1200
[State -1, Salome]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType = S) && (RoundState = 2) && Power >= (PowerMax / 4) && !NumHelper(1115)
Trigger1 		= (!AiLevel) && (Command = "spc4")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) / 20) && ((P2BodyDist X = [0,30]) && (P2BodyDist Y = [-15,15])) && !Var(6)
Value 		= 1300
[State -1, Slave Arrow]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != C) && (RoundState = 2) && Power >= (PowerMax / 2) && (PrevStateNo != [1402, 1403])
Trigger1 		= (!AiLevel) && (Command = "spc5")
Trigger2 		= (AiLevel) && ((Random < (AiLevel * 100) * 15) && (P2BodyDist Y >= 0 && Cond(P2BodyDist X <= 250,(P2BodyDist X = [90 + (P2Dist Y / 1), 190 + (P2Dist Y)]), P2BodyDist Y >= 75)) && !Var(6) && (PrevStateNo != 220 && PrevStateNo != 320 && (PrevStateNo != [1400,1403])))
Value 		= Ifelse((Pos Y < 0), Cond(P2StateNo = 1565, 1403, 1402), Cond(P2StateNo = 1565, 1401, 1400))
[State -1, Mero Mero Mellow]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && Power >= (PowerMax / 3)
Trigger1 		= (!AiLevel) && (Command = "spc6")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 10) && ((((P2BodyDist X = [0, 100]) && (P2BodyDist Y = [-15,15]) && (P2StateNo != 1560 && P2StateNo != 1565 && (PrevStateNo != 220 && PrevStateNo != 320 && PrevStateNo != 1500) && !Var(6)))))
Value 		= 1500
[State -1, Perfume Femur]
Type 		= ChangeState
Triggerall 		= Ctrl && (StateType != A) && (RoundState = 2) && Power = PowerMax && P2StateNo != 1565
Trigger1 		= (!AiLevel) && (Command = "ult")
Trigger2 		= (AiLevel) && (Random < (AiLevel * 100) * 25) && (P2BodyDist X = [-5,100]) && (P2BodyDist Y = [-15, 15]) && P2StateType != L && (PrevStateNo != 220 || PrevStateNo != 320) && (P2StateNo != [5080,5150])
Value 		= 3000

