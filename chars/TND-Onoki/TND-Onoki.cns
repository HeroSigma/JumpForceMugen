; Introduction
; CNS difficulty: basic
[Statedef 190]
type = S
ctrl = 0
anim = 190
velset = 0,0

[State 190, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
trigger1 = RoundState = 0
value = 190

[State 190, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 0, Posset]
type = Posset
trigger1 =time=0
y = screenpos y - 500

[State 0, VelAdd]
type = VelAdd
trigger1 = time>2
y = .04

[State 0, PlaySnd]
type = PlaySnd
trigger1 =time=20
value = S15,8
volume = 0
channel = -1


[State 0, ScreenBound]
