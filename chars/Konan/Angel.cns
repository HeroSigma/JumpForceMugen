;-------------------------------------------------------------------------------
; Susanoo Perfect - Stance
[Statedef 39001]
type = S
physics = S
ctrl = 0
sprpriority = 0

[State 0, Helper Tiempo]
type = Helper
trigger1 = prevstateno = 39000 && time = 0
helpertype = normal
name = "Helper Tiempo"
ID = 39100
stateno = 39100
pos = 0,0
postype = p1

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 10000,1 ChangeAnim]
type = ChangeAnim
Trigger1 = Command!="holdup" && Command!="holddown"
trigger1 = Command!="holdfwd" && Command!="holdback"
triggerall = Anim!= 39001
value = 39001

[State 10000,2 Turn]
type = Turn
triggerall =  Anim = 39001
trigger1 = pos x > enemynear(ifelse((enemynear(0),alive),0,1)), pos x && facing = 1
trigger2 = pos x < enemynear(ifelse((enemynear(0),alive),0,1)), pos x && facing = -1

[State 10000, VelSet]
type = VelSet
trigger1 = Command!="holdfwd" && Command!="holdback"
x = 0

[State 10000, VelSet]
type = VelSet
trigger1 = Command!="holdup" && Command!="holddown"
trigger2 = Pos y<=-110
trigger3 = Pos y>=-1
y = 0

[State 1000, AngleDraw]
type = AngleDraw
trigger1 =  Vel x != 0 && Vel y != 0
trigger1 = Anim = 39020
value = ((ATan(vel y/vel x*Cond(vel x<0,1,-1)))*(180.0/PI))

[State 1000, AngleDraw]
type = AngleDraw
trigger1 =  Vel x != 0 && Vel y != 0
trigger1 = Anim = 39021
value = ((ATan(vel y/vel x*Cond(vel x<0,-1,1)))*(180.0/PI))

[State 1000, VelSet]
Type = VelSet
Trigger1 = Command!="holdup" && Command!="holddown"
trigger1 = Command!="holdfwd" && Command!="holdback"
X = -cos(time*0.05)*0.3
Y = cos(time*0.05)*0.2

;SharK Moves
[State 10000, ]
type = VelSet
trigger1 = command = "holdfwd"
x = 4

[State 10000, ]
type = VelSet
trigger1 = command = "holdback"
x = -4

[State 10000, ]
type = VelSet
trigger1 = Pos y>-110
trigger1 = command = "holdup"
y = -4

[State 10000, ]
type = VelSet
trigger1 = Pos y<0
trigger1 = command = "holddown"
y = 4

[State 10000, ]
type = ChangeAnim
triggerall = vel x > 0 && command = "holdfwd"
trigger1 = Anim != 39020 && Anim != 39005
trigger2 = Anim = 39005 && AnimTime = 0
value = 39020

[State 10000, ]
type = ChangeAnim
triggerall = vel x < 0 && command = "holdback"
trigger1 = Anim != 39021 && Anim != 39005
trigger2 = Anim = 39005 && AnimTime = 0
value = 39021

[State 0, Susanoo Cataclism]
type = ChangeState
triggerall = Pos y>-20  
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,250]
value = 39500

[State 0, Susanoo Cataclism]
type = ChangeState
triggerall = Pos y<-20  
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,250]
value = 1400

[State 0, Susanoo Storm]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 3"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,250]
value = 39600

[State 0, Chibaku Tensei]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 5"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,250]
value = 39700

[State 0, Susanoo Perfect A]
type = ChangeState
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 100
value = 39200

[State 0, Susanoo Perfect B]
type = ChangeState
trigger1 = ailevel = 0 && command = "b"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 100
value = 39300

[State 0, Susanoo Perfect C]
type = ChangeState
trigger1 = ailevel = 0 && command = "c"
trigger2 = ailevel > 0 && random < (ailevel * 100) && p2bodydist x < 100
value = 39400

[State 0, Power Charge]
type = ChangeState
Triggerall = power < 3000
trigger1 = ailevel = 0 && command = "s"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 100
value = 39501

[State 200, End]
type = ChangeState
trigger1 = numhelper(39100) = 0 || roundstate != 2
value = 39800

[State 200, End]
type = ChangeState
trigger1 = !alive
value = 5050
