yscale = .7
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 20
attack.dist = 160
proj.attack.dist = 12
proj.doscale = 0
head.pos = 3,-35
mid.pos = 1,-20

[velocity]
walk.fwd = 3
walk.back = -3
run.fwd = 4,0
run.back = -2.5,-3
jump.fwd = 2,0
jump.back = -2,0
jump.neu = 0,-4

[movement]
airjump.num = 0
airjump.height = 0
yaccel = .3
stand.friction = .85
crouch.friction = .82

;--------------------------------------------------
; Quotes
[Quotes]
victory1 = "?"
victory2 = "?"
victory3 = "?"
victory4 = "?"
victory5 = "?"

