;--------------------------------------------------
; var list

; - var(55) = Palette Changer
; - fvar(0) = ?
; - fvar(00) = ?

;--------------------------------------------------
; Basic Stats
[data]
life = 1000
power = 3000
attack = 100
defence = 100
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
ko.echo = 0
intpersistindex = 0
floatpersistindex = 40

[size]
