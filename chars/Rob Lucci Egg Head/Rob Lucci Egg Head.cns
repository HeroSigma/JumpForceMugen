;-------------------------------------------------------------------------------
; Abrigo
[Statedef 192]
type    = A
movetype= I
physics = N
ctrl = 0
Velset = 0,.75*Helper(999999),Fvar(16)
anim = 192
sprpriority = 0

[State 0, VarAdd]
type = VarAdd
trigger1 = time >= 15
v = 1
value = 25

[State 0, Trans]
type = Trans
trigger1 = time >= 15
trans = addalpha
alpha = 256-var(1),0+var(1)

[State 200, End]
type = Destroyself
trigger1 = var(1) >= 256
;-------------------------------------------------------------------------------
; Hato Start
[Statedef 193]
type    = A
movetype= I
physics = N
anim = 193
sprpriority = 3

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = -6*Helper(999999),Fvar(16),-42*Helper(999999),Fvar(16)

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = root,anim = 191
value = Anim
elem = 1

[State 200, End]
type = ChangeState
trigger1 = root,stateno = 191 && root,time = 100
value = 194
;-------------------------------------------------------------------------------
; Hato Fin
