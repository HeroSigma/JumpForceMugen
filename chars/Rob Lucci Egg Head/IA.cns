[Statedef -2]

[State 0, VarSet] ; Zoan No Hold
type = VarSet
trigger1 = 1
Fv = 28
value = 1  ; 0 = Hold // 1 = No Hold

[State 0, VarAdd] ; Air Bachi Limite
type = VarAdd
