; HITA_FALL (knocked up, falling)
[Statedef 5050]
type    = A
movetype= H
physics = N

[State 0, VarSet]
type = VarSet
trigger1 = !time
fv = 20
value = 0.5
ignorehitpause = 1

[State 0, VarSet]
type = Varadd
trigger1 = 1
fv =20
value = sin(gametime*0.5)*0.4
ignorehitpause = 1

[State 0, VarSet]
type = Varset
