; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 0
id = 9022
ignorehitpause = 1
;persistent =

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = var(13) > 0
trigger1 = time = 0
id = 6650
ignorehitpause = 1
;persistent =

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = var(13) > 0
trigger1 = time = 0
id = 6666
ignorehitpause = 1
;persistent =

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = var(13) > 0
trigger1 = time = 0
id = 6667
ignorehitpause = 1
;persistent =

[State 0, RemoveExplod]
