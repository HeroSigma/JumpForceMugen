triggerall = var(13) > 0
trigger1 = time = 0
id = 667
ignorehitpause = 1
;persistent =

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = var(13) > 0
trigger1 = time = 0
id = 6670
ignorehitpause = 1
;persistent =

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = 1
id = 6667
ignorehitpause = 1
;persistent =

[State 0, DestroySelf] ; Anti Bugs
type = DestroySelf
trigger1 = ishelper

[State 0, 1]
type = ChangeAnim
triggerall = anim != 1
trigger1 = Anim != 0+var(11) && Anim != 5+var(11)
trigger2 = Anim = 5+var(11) && AnimTime = 0
value = 0+var(11)

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = var(6) = 1
triggerall = var(13) = 0
triggerall = var(14) = 0
triggerall = var(16) = 0
triggerall = roundstate >= 2
triggerall = anim != 1
trigger1 = random < 5
value = 1

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = var(6) = 1
triggerall = var(13) = 0
triggerall = var(14) = 0
triggerall = var(16) = 0
triggerall = anim = 1
trigger1 = animtime = 0
value = 0

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
