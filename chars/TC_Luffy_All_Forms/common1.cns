; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40+var(11)
ctrl = 0
sprpriority = 1

[State 0, RemoveExplod]
type = RemoveExplod
triggerall = var(13) > 0
trigger1 = time = 0
id = 6650
ignorehitpause = 1
;persistent =

