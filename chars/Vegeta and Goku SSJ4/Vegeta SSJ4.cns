Triggerall = MoveContact
trigger1 = ailevel = 0 && Command = "a" && Command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && MoveHit && random < (ailevel * 100)/12
value = 680

[State 0, Chain]
type = ChangeState
