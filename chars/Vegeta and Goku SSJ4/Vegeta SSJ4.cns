Triggerall = movecontact
trigger1 = ailevel = 0 && Command = "holddown" && command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/7
value = 660

[State 0, Chain]
type = ChangeState
