TriggerAll = AnimElemTime(10)>=0
Trigger1 = MoveHit >= 1
value = 1302
ctrl = 0
IgnoreHitPause = 0

[State -1,SUPER1]
Type = ChangeState
TriggerALL = Power >= 1500
TriggerAll = AnimElemTime(8)>=0
Triggerall = MoveContact
Trigger1 = Command = "SUPER1"
trigger2 = RoundState = 2 && AiLevel > 0 && (Random<(AILevel*100)/12)
trigger2 = P2BodyDist X > 30
value = 1605

[State -1,SPECIAL 3]
type = ChangeState
TriggerALL = Power >= 1000
TriggerAll = AnimElemTime(8)>=0
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 3"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/15
trigger2 = P2BodyDist X > 30
value = 1205

[State -1,SPECIAL 5]
type = ChangeState
TriggerALL = Power >= 1500
TriggerAll = AnimElemTime(8)>=0
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 5"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/14
trigger2 = P2BodyDist X > 30
value = 1405

[State -1,SPECIAL 6]
type = ChangeState
TriggerALL = Power >= 1500
TriggerAll = AnimElemTime(8)>=0
Triggerall = MoveContact
Trigger1 = Command = "SPECIAL 6"
trigger2 = RoundState = 2 && AiLevel > 0 && Random<(ailevel * 100)/20
trigger2 = P2BodyDist X > 30
value = 1505

[State 0, Chain - B + C]
type = ChangeState
TriggerALL = Power >= 500
TriggerAll = AnimElemTime(8)>=0
Triggerall = MoveContact
trigger1 = Ailevel = 0 && Command = "b" && Command = "c"
trigger2 = p2bodydist x = [30,50]
trigger2 = roundstate = 2 && ailevel > 0 && random<(ailevel * 100)/12
value = 770

[State 0,End]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1
