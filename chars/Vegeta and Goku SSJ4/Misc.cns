;-------------------------------------------------------------------------------
; P2 - Thrown
[statedef 8210]
type = U
movetype = H
physics = N
anim = 5050+(var(10))
ctrl = 0
velset = 0, 0
sprpriority = 1
facep2 = 1

[state 0,velset]
type = velset
trigger1 = time >= 0
;x = enemy, const(velocity.run.back.x) * 2.5
x = -15
y = 0
ignorehitpause = 1

[state 0,posset]
type = posset
trigger1 = pos y >= 0
y = 0

[state 0,playerpush]
type = playerpush
trigger1 = 1
value = 0

[state 0,changestate]
type = changestate
trigger1 = backedgebodydist <= 5
value = 8211
