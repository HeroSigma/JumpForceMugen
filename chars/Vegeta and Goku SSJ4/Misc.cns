;-------------------------------------------------------------------------------
; P2 - Thrown Mid
[Statedef 8220]
type = A
movetype = H
physics = N
juggle = 1
;velset = -12,0
ctrl = 0
sprpriority = 1
Facep2 = 1

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = 5050+var(10)
elem = 1

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
value = -atan (vel y / vel x) * 180 / PI
ignorehitpause = 1

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,AA,AP,AT
time = 5

[State 0, Gravity]
type = Gravity
trigger1 = 1

[State 5050, 5]
type = SelfState
TRIGGERALL = Time >= 20
TRIGGERALL=Vel Y > -1
TRIGGERALL=alive
TRIGGERALL=CanRecover
trigger1 = Command = "recovery"
value = 5210

[State 200, End]
type = ChangeState
trigger1 = backedgebodydist < 5
trigger1 = Pos Y <= -2
value = 8224

[State 200, End]
type = ChangeState
trigger1 = Time = 25
value = 8225

[State 200, End]
type = ChangeState
trigger1 = Pos Y >= -0
value = 8223
