[State 0, Jump]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
TriggerALL = StateType != A
TriggerALL = Ctrl
Trigger1 = p2bodydist x > 350 && random < 100
value = 40

[State 0, Run]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
TriggerALL = StateType != A
TriggerALL = Ctrl
triggerall = stateno != 100
Trigger1 = p2bodydist x > 100 && random < 100
value = 100

[State 0, Run FIN]
type = ChangeState
TriggerALL = AILevel > 0 && stateno = 100
Trigger1 = p2bodydist x < 50 && random < 400
value = 103

[State 0, Run Atras]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
triggerall = statetype != A
triggerall = stateno != 100 && stateno !=103
triggerall = ctrl
trigger1 = p2bodydist x < 100 && random < 50
value = 102

[State 0, Air Dash Forward]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
triggerall = stateno != [100,103]
TriggerALL = StateType = A
TriggerALL = Ctrl
Trigger1 = p2bodydist x > 100 && random < 100
value = 110

[State 0, Air Dash Back]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
triggerall = stateno != [100,110]
TriggerALL = StateType = A
TriggerALL = Ctrl
Trigger1 = p2bodydist x < 100 && random < 50
value = 115

[State 0, Guard]
type = ChangeState
TriggerALL = AILevel > 0 && RoundState = 2
TriggerALL = Random<(AILevel*100)
TriggerALL = Ctrl
TriggerALL = P2BodyDist X > -5
triggerall = numhelper(520) = 0
Trigger1 = (P2BodyDist X<50&&P2MoveType=A)||(Enemy,NumProj>0)
Trigger2 = ((P2BodyDist X=[-15,100])&&P2MoveType=A)||(Enemy,StateNo=[1000,2000])
value = ifelse(statetype = A,132,130)

[State 0, Guard]
type = assertspecial
trigger1 = ailevel > 0 && roundstate = 2
flag = nostandguard
flag2 = nocrouchguard
flag3 = noairguard
ignorehitpause = 1
