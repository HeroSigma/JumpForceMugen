yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos=-1,-41
mid.pos=-1,-25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 1
walk.back = -1
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0,-6
airjump.back = -3
airjump.fwd = 3
[Movement]
