;===========================================================================
;-----------------| Hitto by Yukino Usagi (Edit by Blue) |------------------
;===========================================================================

; var(2) = common and AI
; var(5) = Time frac Fx trans
; var(6) = Angle Draw
; var(7) = Time Release
; var(8) = Dash count
; var(9) = Dead Blow FX condition count
; var(13) = Dead Blow damage count
; var(15) = Icy Glare trigger count
; var(16) = Ice spead control
; var(19) = Sound Random

;===========================================================================

[Data]
life = 1000
power = 3000
attack = 100
defence = 100
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 50
FloatPersistIndex = 40

[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 60
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = 2, -50
mid.pos = 2, -30
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 1.4
walk.back = -1.4
run.fwd  = 9
run.back = -9
jump.neu = 0,-6.75
jump.back = -4
jump.fwd = 4
runjump.back = -6
runjump.fwd = 6
airjump.neu = 0,-8.5
airjump.back = -2.55
airjump.fwd = 2.5

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

;---------------------------------------------------------------------------

[Quotes]
Victory0 = "Mission complete."
Victory1 = "Target eliminated."
Victory2 = "I'll be back... To visit your grave, that is..."
Victory3 = "You seem to be improving as well. However, is not enough to beat me."
	
