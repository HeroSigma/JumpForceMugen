[State -1, Crouching Light Punch]
type = ChangeState
value = 2000
triggerall = ailevel > 0 && roundstate = 2
triggerall = power >= 500
trigger1 = statetype = S && enemy,statetype = A && (p2dist x = [20,100])&& enemy,movetype = A
trigger1 = ctrl
[State 0, Katsu]
type = ChangeState
triggerall = numhelper(1150)
triggerall = helper(1150),stateno = 1155
triggerall = numhelper(1150) > 0
Triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
trigger1 = random < (ailevel * 100)/100
value = 800
;===========================================================================
;SUPERS:
;===========================================================================
[State 0, Autodestruction]
type = ChangeState
Triggerall = life <= lifemax/4
triggerall = power >= 3000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
trigger1 = p2bodydist x >= 100 && p2movetype = A
trigger1 = random < (ailevel * 500)
trigger2 = p2bodydist x < 75
trigger2 = random < (ailevel * 100)*2
