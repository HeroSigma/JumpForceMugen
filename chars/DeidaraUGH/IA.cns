;===============================================================================
; INTELIGENCIA ARTIFICIAL:
;===============================================================================
[Statedef -2]
;===========================================================================
;Basic:
;===========================================================================
[State 0, Guard]
type = ChangeState
triggerall = enemy,hitdefattr != SCA,NT,ST,HT
triggerall = enemy,statetype != L
triggerall = (enemy,stateno != 5100||enemy,stateno != 5101||enemy,stateno != 5110) 
triggerall = (ailevel >0)&& (roundstate = 2)&&(ctrl)
triggerall = Cond(ailevel < 7,random%150<ailevel,1)
trigger1 =(inguarddist&&(p2movetype=A))|| (enemy,numproj > 0)
value = 120

[State 0, Run Atras]
type = ChangeState
triggerall = stateno != 60
triggerall = stateno != 65
triggerall = stateno != 70
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100
trigger1 = random < (ailevel * 100)/4
value = 70


[State -1, Crouching Light Punch]
type = ChangeState
value = 121212
triggerall = ailevel > 0 && roundstate = 2
triggerall = power >= 700
trigger1 = statetype = S && Cond(numhelper(121213)=0,random < 20,random<280)
trigger1 = ctrl

[State -1, Fly]
type = ChangeState
value = 6365
triggerall = ailevel >0 && roundstate = 2
trigger1 = (Stateno = 1800||Stateno =1900) && prevstateno = 3200
[State -1, Fly]
type = ChangeState
value = 3200
triggerall = ailevel >0 && roundstate = 2&& pos y < -150&& p2dist x = [-50,250]
triggerall = power >= 3000
trigger1 = (Stateno = 1800||Stateno =1900)

[State -1, Fly]
type = ChangeState
value = 1800
triggerall = ailevel >0 && roundstate = 2
triggerall = power >= 3000
trigger1 = statetype = A
trigger1 = ctrl

[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = random <=100
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

[State 0, Guard]
type = assertspecial
trigger1 = ailevel > 0 && roundstate = 2
flag = nostandguard
flag2 = nocrouchguard
flag3 = noairguard
ignorehitpause = 1
;===========================================================================
;Attack Normales:
;===========================================================================
[State 0, A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [0,30]
trigger1 = random < (ailevel * 100)
value = 200

[State 0, B]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [0,30]
trigger1 = random < (ailevel * 100)
