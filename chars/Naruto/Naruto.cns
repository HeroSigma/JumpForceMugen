trigger1 = var(55) := 1
trigger2 = var(55) = 1
trigger2 = ifelse(teamside=2,command = "fwd",command = "back")
trigger2 = var(55) := 13

[State 0, Varadd]
type = Varadd
triggerall = var(13) > 1
trigger1 = command = "fwd" && teamside = 1
trigger2 = command = "back" && teamside = 2
var(55) = 1

[State 0, Varadd]
type = Varadd
triggerall = var(13) > 1
trigger1 = command = "back" && teamside = 1
trigger2 = command = "fwd" && teamside = 2
var(55) = -1

[State 0, PlaySnd]
type = PlaySnd
triggerall = var(13) > 1
trigger1 = command = "fwd"
trigger2 = command = "back"
value = S7,0
volume = 999

[State 0, PlaySnd]
type = PlaySnd
trigger1 = var(13) < 1
value = S7,ifelse(ailevel != 0,-1,1)
volume = 999
persistent = 0

[State 0, VarSet]
type = VarSet
trigger1 = command = "up" || command = "down" || command = "s" 
trigger2 = ailevel != 0
var(13) = 0

[State 0, Bar]
type = Explod
triggerall = var(13) > 1
trigger1 = 1
anim = 9065
id = 9050
bindtime = -1
removetime = 1
facing = 1-(teamside = 2)*2
ontop = 1
ownpal = 1
scale = const480p(0.7)*Helper(999999),Fvar(16),const480p(1)*Helper(999999),Fvar(16)
pos = ifelse(teamside=1,const480p(-40),const480p(50))*Helper(999999),Fvar(16),8*Helper(999999),Fvar(16)
postype = p1
ontop = 1
ignorehitpause = 1

[State 0, Change]
