;===================================================================================
;---------------- Constantes y Ataques normales-------------------------------------
;===================================================================================

;Var List:

; - Var(2) = Sennine Mode || KCM || Bijuu Mode || Ashura
; - Var(4) = Armor Break
; - Var(5) = Limitador Air Jump
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(10) = Apariencia Transformaciones
; - Var(11) = Golpeado Transformaciones
; - Var(12) = Oscurecer Pantalla
; - Var(14) = Specials Transformaciones
; - Var(15) = Supers Transformaciones
; - FVar(16) = ESCALA

[Data]
life = 2000
power = 3000
attack = 100
defence = 100
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
IntPersistIndex = 0
FloatPersistIndex = 0

[Size]
xscale = 1
yscale = 1
ground.back = 10
ground.front = 10
air.back = 10
air.front = 10
height = 40
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 1
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82
;===============================================================================
; Gudodama:
;-------------------------------------------------------------------------------
[Statedef 1]
type    = A
movetype= I
physics = N
anim = 2
sprpriority = -1

[State 0, FX]
type = Explod
trigger1 = numexplod(3) = 0
anim = 3
ID = 3
pos = 0*Helper(999999),Fvar(16),0*Helper(999999),Fvar(16)
postype = p1
Bindtime = -1
sprpriority = -1
ontop = 0
ownpal = 1
Removetime = -1
Trans = Add
supermovetime = 99999999

[State 0, FX]
type = Explod
trigger1 = numexplod(4) = 0
anim = 3
ID = 4
pos = 0*Helper(999999),Fvar(16),0*Helper(999999),Fvar(16)
postype = p1
Bindtime = -1
sprpriority = -1
ontop = 0
ownpal = 1
Removetime = -1
Trans = Sub
supermovetime = 99999999

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = root,stateno = 170 && root,time >= 5
trigger2 = root,stateno = 30003 && root,time < 6
trigger3 = root,stateno = 17660 && root,time = [42,198]
trigger4 = root,stateno = 17191 && root,time = [0,50]
trigger5 = root,stateno = 30101
flag = Noshadow
flag2 = Invisible

[State 0, BindToRoot] ; Normal
type = BindToRoot
trigger1 = 1
pos = -4*Helper(999999),Fvar(16),-40*Helper(999999),Fvar(16)

[State 0, BindToRoot] ; Crouch // Run
type = BindToRoot
trigger1 = root,stateno = [10,12]
trigger2 = root,stateno = [17060,17070]
pos = -4*Helper(999999),Fvar(16),-30*Helper(999999),Fvar(16)

[State 0, BindToRoot] ; Win
type = BindToRoot
trigger1 = root,stateno = 17181
pos = -2*Helper(999999),Fvar(16),-40*Helper(999999),Fvar(16)

[State 0, SprPriority]
type = SprPriority
trigger1 = var(1) = 1
value = 4

[State 0, SprPriority]
type = SprPriority
trigger1 = var(1) = 0
value = -1

[State 0, ModifyExplod]
type = ModifyExplod
trigger1 = var(1) = 1
Id = 3
sprpriority = 3
Trans = add
scale = 1*Helper(999999),Fvar(16),1*Helper(999999),Fvar(16)

[State 0, ModifyExplod]
type = ModifyExplod
trigger1 = var(1) = 0
Id = 3
sprpriority = -1
Trans = add
scale = 1*Helper(999999),Fvar(16),1*Helper(999999),Fvar(16)

[State 0, ModifyExplod]
type = ModifyExplod
trigger1 = var(1) = 1
Id = 4
sprpriority = 3
Trans = Sub
scale = 1*Helper(999999),Fvar(16),1*Helper(999999),Fvar(16)

[State 0, ModifyExplod]
type = ModifyExplod
trigger1 = var(1) = 0
Id = 4
sprpriority = -1
Trans = Sub
scale = 1*Helper(999999),Fvar(16),1*Helper(999999),Fvar(16)

[State 0, ModifyExplod]
type = ModifyExplod
trigger1 = root,stateno = 170 && root,time >= 5
ID = 3
scale = 0,0

[State 0, ModifyExplod]
type = ModifyExplod
trigger1 = root,stateno = 170 && root,time >= 5
trigger2 = root,stateno = 30020 && root,time < 6
trigger3 = root,stateno = 17660 && root,time = [42,198]
trigger4 = root,stateno = 17191 && root,time = [0,50]
trigger5 = root,stateno = 30101
ID = 4
scale = 0,0

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = root,var(2) != 4
trigger2 = numhelper(17750) = 1
trigger3 = root,stateno = 33001 && root,time = 50
trigger4 = root,stateno = 40001 && root,time = 155
trigger5 = root,stateno = 17660 && root,time = [42,198]
trigger6 = root,stateno = 17191 && root,time = [0,50]
trigger7 = root,stateno = 30101
id = 3

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = root,var(2) != 4
trigger2 = numhelper(17750) = 1
trigger3 = root,stateno = 33001 && root,time = 50
trigger4 = root,stateno = 40001 && root,time = 155
trigger5 = root,stateno = 17660 && root,time = [42,198]
trigger6 = root,stateno = 17191 && root,time = [0,50]
trigger7 = root,stateno = 30101
id = 4

[State 200, End]
type = Destroyself
trigger1 = root,var(2) != 4
trigger2 = numhelper(17750) = 1
trigger3 = root,stateno = 33001 && root,time = 50
trigger4 = root,stateno = 40001 && root,time = 155
