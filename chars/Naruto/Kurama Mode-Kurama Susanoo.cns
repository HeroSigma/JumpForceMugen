;===============================================================================
;-------------------------------KURAMA MODE-------------------------------------
;===============================================================================
;-------------------------------------------------------------------------------
; Stance
[Statedef 33000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 9999
sprpriority = 0

[State 0, Kurama ADD]
type = Helper
trigger1 = !time
helpertype = normal
name = "Kurama ADD"
ID = 330000
stateno = 330000
pos = 0,0
facing = 1
postype = p1
ownpal = 1
size.xscale = .8*Helper(999999),Fvar(16)
size.yscale = .8*Helper(999999),Fvar(16)
ignorehitpause = 1

[State 0, Kurama SUB]
type = Helper
trigger1 = !time
helpertype = normal
name = "Kurama SUB"
ID = 330005
stateno = 330005
pos = 0,0
facing = 1
postype = p1
ownpal = 1
size.xscale = .8*Helper(999999),Fvar(16)
size.yscale = .8*Helper(999999),Fvar(16)
ignorehitpause = 1

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 0, Run FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "FF"
trigger2 = ailevel > 0 && random < (ailevel * 100)/8
trigger2 = p2bodydist x > 200
value = 33100

[State 0, Run BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "BB"
trigger2 = ailevel > 0 && random < (ailevel * 100)/8
trigger2 = p2bodydist x < 100 && p2movetype = A
value = 33105

[State 0, Walk FWD]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdfwd"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 50
value = 33020

[State 0, Walk BACK]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdback"
trigger2 = ailevel > 0 && random < (ailevel * 100)/6
trigger2 = p2bodydist x < 50 && p2movetype = H
value = 33021

[State 0, Jump]
type = ChangeState
trigger1 = ailevel = 0 && command = "holdup"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x < 100 && p2movetype = A
value = 33040

[State 0, Cho Oodama Rasengan]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x < 100
trigger2 = p2bodydist y < -50
value = 33600

[State 0, Angry Roar]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 2"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x < 50
value = 33700

[State 0, Rasen Shuriken]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 3"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x >= 200
value = 33800

[State 0, Beast Drop]
type = ChangeState
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 4"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x = [100,200]
value = 33900

[State 0, Renzoku Bijuudama]
type = ChangeState
triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 5"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x = [75,150]
value = 34000

[State 0, Kage Bunshin no Jutsu]
type = ChangeState
triggerall = numhelper(42000) = 0
triggerall = power >= 2000
trigger1 = ailevel = 0 && command = "SPECIAL 6"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [200,400]
value = 34001

[State 0, Bijuudama]
type = ChangeState
triggerall = var(2) = 3
triggerall = power >= 3000
trigger1 = ailevel = 0 && command = "SUPER1"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [100,300]
value = 34100

[State 0, Ultra Rasen Shuriken]
type = ChangeState
triggerall = var(2) = 4
triggerall = power >= 3000
trigger1 = ailevel = 0 && command = "SUPER1"
trigger2 = ailevel > 0 && random < (ailevel * 100)*1.25
trigger2 = p2bodydist x = [100,300]
value = 34200

[State 0, A]
type = ChangeState
trigger1 = ailevel = 0 && command = "a"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x < 50
trigger2 = p2bodydist y < -100
value = 33200

[State 0, B]
type = ChangeState
trigger1 = ailevel = 0 && command = "b"
trigger2 = ailevel > 0 && random < (ailevel * 100)
trigger2 = p2bodydist x < 50
trigger2 = p2bodydist y > -200
value = 33300

[State 0, C]
type = ChangeState
trigger1 = ailevel = 0 && command = "c"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x < 100
trigger2 = p2bodydist y > -75
value = 33400

[State 0, FIN]
type = ChangeState
trigger1 = ailevel = 0 && command = "holddown" && command = "s"
trigger2 = ailevel > 0 && random < (ailevel * 100)/50
trigger2 = p2bodydist x >= 100
value = 33002

[State 0, Power Charge]
type = ChangeState
Triggerall = power < 3000
trigger1 = ailevel = 0 && command = "s"
trigger2 = ailevel > 0 && random < (ailevel * 100)/4
trigger2 = p2bodydist x > 100
value = 33500

[State 200, End]
type = ChangeState
trigger1 = numhelper(33080) = 0
value = 33002
