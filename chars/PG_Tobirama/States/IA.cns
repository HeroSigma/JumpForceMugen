[State -2 Jump Up]
type = ChangeState
Triggerall = numhelper(700) = 0
Triggerall = numhelper(1050) = 0
Triggerall = numhelper(1550) = 0
Triggerall = numhelper(2050) = 0
Triggerall = numhelper(2550) = 0
Triggerall = numhelper(3540) = 0
Triggerall = numhelper(4050) = 0
Triggerall = numhelper(4055) = 0
Triggerall = numhelper(4060) = 0
Triggerall = numhelper(4065) = 0
Triggerall = numhelper(4450) = 0
Triggerall = ailevel > 0 && roundstate = 2
Triggerall = ctrl
Triggerall = statetype != A
trigger1 = P2dist y <= -30
trigger1 = random = [0,300]
value = 40

[State -2 Hiraishin Quick Kick]
type = ChangeState
Triggerall = RoundState = 2 && ailevel > 0
Triggerall = StateType = A
Triggerall = P2BodyDist X >= 150
Triggerall = ctrl
trigger1 = Random = [100,140]
value = 650

[State -2 Hiraishin Move]
type = ChangeState
Triggerall = RoundState = 2 && ailevel > 0
Triggerall = StateType = A
Triggerall = ctrl
trigger1 = Random = [700,800]
value = 750

[State -2 Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

[State -2 Power Charge]
type = ChangeState
Triggerall = numhelper(700) = 0
Triggerall = numhelper(1050) = 0
