

;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                      SELECIONAR PALETA 
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 256]
physics = N
anim = 256
velset=0,0
sprpriority=99999

[State 256, PosSet]
type = PosSet
trigger1 =!time
x = root,facing*-80  ;POSIcao x ENTRE OS CURSORES
y = 20               ;POSIcao Y ENTRE OS CURSORES
ignorehitpause = 1

[State 256, AS]
type=assertspecial
trigger1=1
flag=intro
flag2=noshadow

[State 256, Reset]
type=varset
trigger1=!time
var(29)=700          ;TEMPO PRA ESCOLHER A COR

[State 256, Pal]
type=varset
trigger1=!time
var(27)=root,palno

[State 256, Varset]
type=varset
trigger1=var(27)<1||var(27)>5 ;QUANTIDADE DE CORES
var(27)=1+(var(27)<1)*86

[State 256, PlaySnd]
type = PlaySnd
trigger1 =var(33)=2
value = S256,0        ;SOM DO CURSOR
volume = 999999999
channel = 20

[State 256, PlaySnd]
type = PlaySnd
triggerall=ishelper(256)
trigger1=root,command="a"||root,command="b"||root,command="c"||root,command="x"||root,command="y"||root,command="z"||root,command="s"||roundstate=2
trigger2=var(29)<=5
value = S256,1        ;SOM QUE SELECIONA A COR
volume = 999999999
channel = 20
persistent =0


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                             Comando que Seleciona a Cor 
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[State 256, Countdown]
type = VarAdd
trigger1 =1
var(29)=-1

[State 256, Countdown]
type = VarAdd
trigger1=!var(33)&&var(29)<150
trigger1=root,command="holdup"||root,command="holddown"||root,command="holdback"||root,command="holdfwd"
var(29)=25

[State 256, Varadd]
type=varadd
trigger1=!var(33)
trigger1=root,command="holdup"||root,command="holddown"||root,command="holdback"||root,command="holdfwd"
var(27)=1-(root,command="holddown"||root,command="holdback"&&facing=1||root,command="holdfwd"&&facing=-1)*2

[State 256, Varadd]
type=varadd
trigger1=(root,command="holdup"||root,command="holddown"||root,command="holdback"||root,command="holdfwd")&&!var(33)||var(33)
var(33)=1

[State 256, Varset]
type=varset
trigger1=!time||var(33)>=17
var(33)=0

;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                             Comando que Seleciona a Cor 
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[State 256, End]
type=destroyself
triggerall=ishelper(256)
trigger1=root,command="a"||root,command="b"||root,command="c"||root,command="x"||root,command="y"||root,command="z"||root,command="s"||roundstate=2
trigger2=var(29)<=0
trigger3=root,AILevel


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
                                                          [Statedef -2]
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================



;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                    Selecionar Cores 
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[state -2, No Clones]
type = remappal
triggerall=numenemy && (var(27)=[1,87])
trigger1=var(28)&&!numhelper(256)&&matchno=1&&roundno=1
trigger1=enemy,authorname="Infinite"&&enemy,name="Andy Bogard"&&enemy,var(27)=var(27)
source = 1, 1
dest = 1, Ifelse(teamside!=1 && enemynear,Numhelper(256)=0,enemy,var(27)+teamside,var(27))
ignorehitpause = 1

[state -2, Palette]
type = varset
trigger1 = numhelper(256)
trigger1=helper(256),var(27)=[1,87]
var(27)= helper(256),var(27)
ignorehitpause = 1

[state -2, Palette Selection]
type = remappal
trigger1 = numhelper(256)
trigger1=helper(256),var(27)=[1,87]
source = 1, 1
dest = 1, var(27)
ignorehitpause = 1

[state -2, Continue Palette]
type = remappal
trigger1=var(28)&&matchno>1
source = 1, 1
dest = 1, var(27)
ignorehitpause = 1


