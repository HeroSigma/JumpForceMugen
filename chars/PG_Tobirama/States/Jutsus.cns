; Suiryudan no Jutsu
[Statedef 1000]
type = S
movetype = A
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 1000
poweradd = -1000
sprpriority = 2

[state 20]
type = PlaySnd
trigger1 = animelem = 2
value = s0,1+(random%3)
volume = 200

[State 1000]
type = PlaySnd
trigger1 = time = 0
value = S0,13
volume = 999
[State 1000]
type = PlaySnd
trigger1 = time = 0
value = S0,13
volume = 999

[State 1000]
type = PlaySnd
trigger1 = time = 30
value = S0,14
volume = 999
[State 1000]
type = PlaySnd
trigger1 = time = 30
value = S0,14
volume = 999

[State 1000]
type = PlaySnd
trigger1 = animelem = 2
value = S4,13
volume = 50

[State 1000]
type = SuperPause
Triggerall = var(10) = 0
trigger1 = time = 0
time = 30
movetime = 30
sound = S950,1
anim = s7400
sound = -1
pos = 0,-40
darken = 0
unhittable = 1

[State 1000]
type = SuperPause
Triggerall = var(10) = 1
trigger1 = time = 0
time = 30
movetime = 30
sound = S950,2
anim = s7400
sound = -1
pos = 0,-40
darken = 0
unhittable = 1

[State 1000]
type = Varset
trigger1 = time = 0
v = 12
value = -100

[State 1000]
type = VarAdd
trigger1 = time >= 15 && Var(12) < 0
v = 12
value = 6

[State 1000]
type = BGPalFX
trigger1 = Time > 0
time = 1
add = Var(12),Var(12),Var(12)

[State 1000]
type = Helper
trigger1 = time = 30
helpertype = normal
name = "Suiryudan"
ID = 1050
stateno = 1050
pos = 50,5
postype = p1
facing = 1
ownpal = 1

[State 1000]
type = ChangeAnim
trigger1 = time > 30 && numhelper(1050) > 0
value = 1000
elem = 3

[State 1000, End]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1

