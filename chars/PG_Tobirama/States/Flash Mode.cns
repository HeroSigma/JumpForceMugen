; Flash Ground
[Statedef 1901]
type    = S
movetype= I
physics = S
ctrl = 0
velset = 0,0
anim = 9999
poweradd = 0

[State 1901, NotHitBy]
type = NotHitBy
trigger1 = !time
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1

[State 1901, PosSet]
type = PosSet
trigger1 = 1
y = 0
ignorehitpause = 1

[State 1901, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noautoturn

[State 1901, LifeAdd]
type = LifeAdd
Triggerall = life < lifemax
trigger1 = time = 0
value = 3
ignorehitpause = 1

[State 1901, Helper]
type = Helper
trigger1 = time = 0
helpertype = normal 
name = "Flash Spark I"
ID = 850
stateno = ifelse(random > 500,850,860)
pos = -3,-40
postype = p1   
facing = 1
keyctrl = 0
ownpal = 1

[State 1901, PosAdd]
type = PosAdd
trigger1 = time = 7
x = p2dist x + 150 +random%100
y = 0

[State 1901, Turn]
type = Turn
trigger1 = time = 7
trigger1 = p2dist x < 0

[State 1901, Helper]
type = Helper
trigger1 = time = 8
helpertype = normal 
name = "Flash Spark III"
ID = 870
stateno = 870
pos = -3,-40
postype = p1    
facing = 1
keyctrl = 0
ownpal = 1

[State 1901, ChangeState]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1

