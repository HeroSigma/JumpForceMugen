; Flash Mode Start
[Statedef 1900]
type    = S
movetype= I
physics = S
ctrl = 0
velset = 0,0
anim = 1900
poweradd = -1000
sprpriority = 2

[State 1900, SuperPause]
type = SuperPause
trigger1 = time = 0
time = 30
movetime = 30
anim = -1
sound = -1
pos = 0,-35
darken = 0
unhittable = 1

[State 1900, Helper]
type = Helper
trigger1 = !time
helpertype = Normal
name = "Timer"
ID = 1960
stateno = 1960
pos = 999,999
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
supermove = 9999999999
pausemove = 9999999999
supermovetime = 999999
pausemovetime = 999999

[State 1900, Helper]
type = Helper
trigger1 = animelemtime(2) = 0
helpertype = normal
name ="efect I"
ID = 1920
stateno = 1920
pos = 0,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
supermove = 9999999999999
pausemove = 9999999999999
supermovetime = 999999999
pausemovetime = 999999999

[State 1900, VarSet]
type = Varset
trigger1 = time = 0
v = 12
value = -100

[State 1900, VarAdd]
type = VarAdd
trigger1 = time >= 20 && Var(12) < 0
v = 12
value = 5

[State 1900, BGPalFX]
type = BGPalFX
trigger1 = Time > 0
time = 1
add = Var(12),Var(12),Var(12)

[State 1900]
type = PlaySnd
trigger1 = time = 0
value = S2,1
volume = 999
[State 1900]
type = PlaySnd
trigger1 = time = 0
value = S2,1
volume = 999

[State 1900, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S2,2
volume = 999

[State 1900, Explod]
type = Explod
trigger1 = time = 0
anim = 1901
ID = 1900
pos = 0,-40
postype = p1
facing = ifelse(random < 500,1,-1)
vfacing = 1
bindtime = -1
vel = -.5,-1.5
removetime = -2
scale = .8,.8
sprpriority = 3
ontop = 0
ownpal = 1
trans = addalpha
alpha = 200,256
supermove = 9999999999999999
pausemove = 9999999999999999
supermovetime = 999999999999
pausemovetime = 999999999999

[State 1900, Explod]
type = Explod
trigger1 = time = 0
anim = 7453
ID = 1900
pos = 0,0
postype = p1
facing = 1
vfacing = 1
bindtime = -1
removetime = -2
scale = .6,.6
sprpriority = 3
ontop = 0
ownpal = 1
removeongethit = 0
