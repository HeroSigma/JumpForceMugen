; Effect I
[StateDef 1920]
type = S
movetype= H
physics = S
velset = 0,0
ctrl = 0
anim = parent,anim
poweradd = 0
sprpriority = 3

[State 1920, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1

[State 1920, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 1920, ChangeAnim]
type = ChangeAnim
trigger1 = 1
value = 1900
elem = 1
ignorehitpause = 1

[State 1920, AngleDraw]
type = AngleDraw
trigger1 = 1
value = 1
scale = 1+time*.1,1+time*.1
ignorehitpause =1
persistent =1

[State 1920, Trans]
type = Trans
trigger1 =1
trans = addalpha
alpha = 256-time*30,256
ignorehitpause = 1
persistent = 1

[State 1920, Destroyself]
type = Destroyself
trigger1 = Time = 10

