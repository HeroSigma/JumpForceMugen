; Timer
[Statedef 1960]
type    = S
movetype= I
physics = S
velset = 0,0
ctrl = 0
anim = 9999
sprpriority = -1

[State 1960, BindToRoot]
type = BindToRoot
trigger1 = 1
time = 1
pos = 0,0
ignorehitpause = 1

[State 1960, ParentVarSet]
type = ParentVarSet
trigger1 = !time
v = 10
value = 1
ignorehitpause = 1

[State 1960, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = nomusic

[State 1960, VarSet]
type = Varset
