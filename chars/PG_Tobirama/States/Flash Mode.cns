[State 1960, Changestate]
type = Changestate
trigger1 = time >= 3000
trigger2 = roundstate != 2
trigger3 = parent,var(10) = 0
trigger4 = win || lose || drawgame
trigger5 = parent,stateno = 1910
value = 1965

