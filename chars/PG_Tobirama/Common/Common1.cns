trigger1 = AnimTime = 0
value = 0

;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;		                                          Correndo
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 20]
type = S
physics = S
sprpriority = 0

[state 20]
type = PlaySnd
trigger1 = animelem = 2
value = s0,1+(random%3)
volume = 200

[state 20]
type = PlaySnd
trigger1 = timemod=14,0
value = S0,5
volume =255

[state 20]
type = Explod
triggerall = anim = 20
trigger1 = timemod=7,0
anim = 22
pos = -10,0
postype = p1
removetime=-2
facing = -1
vel = -.55,-.25
scale = 0.2,0.2
random = 30,20
sprpriority = 3

[state 20]
type = Explod
triggerall = anim = 21 
trigger1 = timemod=7,0
anim = 22
pos = 10,0
postype = p1
removetime=-2
facing = 1
vel = .55,-.25
scale = 0.2,0.2
random = 30,20
sprpriority = 3

[State 20]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)

[State 20]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)

[State 20]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 20]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                         Jump Start
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 40]
type = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1
facep2 = 1

[State 40]
type = Explod
trigger1 = animelem  = 1
anim = 23
pos = 5,2
postype = p1
facing = 1
scale = 0.5,0.5
sprpriority = 100

[State 40]
type = PlaySnd
trigger1 = time=1
value = S0,0
volume =255

[State 40]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, End]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                          Air Jump Start
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 45]
type = A
physics = N
ctrl = 0
velset = 0,0

[State 45]
type = PlaySnd
trigger1 = animelem = 1
value = S0,0
volume = 200

[State 45]
type = ChangeAnim
trigger1 = SelfAnimExist(44)
value = 44

[State 45]
type = ChangeAnim
trigger1 = !SelfAnimExist(44)
value = 41

[State 45]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45]
type = VelSet
trigger1 = Time = 2
x = ifelse(sysvar(1)=0, const(velocity.airjump.neu.x), ifelse(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, End]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                         Jump Up
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 50]
type = A
physics = A

[State 50]
type = PlaySnd
trigger1 = animelem = 1
value = S0,6
volume = 200

[state 50]
type = PlaySnd
trigger1 = animelem = 2
value = s0,1+(random%3)
volume = 200

[State 50]
type = Explod
trigger1 = animelem  = 1
anim = 24
pos = 0,2
postype = p1
facing = 1
scale = 0.4,0.4
sprpriority = 1

[State 50]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, Base - Dash >>]
type = VelSet
Triggerall = prevstateno = 60
trigger1 = time = 0
x = 2

[State 50, Base - Dash <<]
type = VelSet
Triggerall = prevstateno = 70
trigger1 = time = 0
x = -2

[State 50]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))+var(11)

[State 50, End]
type = ChangeAnim
trigger1 = Vel y > -2
persistent = 0
value = 44


