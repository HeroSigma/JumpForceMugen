; Flash Forward
[Statedef 60]
type = S
movetype = I
physics = S
velset = 0,0
ctrl = 0
anim = ifelse(pos y < 0,101,100)
sprpriority = 2

[State 60]
type = Helper
trigger1 = time = 2
helpertype = normal 
name = "Flash Spark I"
ID = 850
stateno = 850
pos = 20,-35
postype = p1   
facing = 1
keyctrl = 0
ownpal = 1

[State 60]
type = Helper
trigger1 = time = 12
helpertype = normal 
name = "Flash Spark III"
ID = 870
stateno = 870
pos = 4,-35
postype = p1   
facing = 1
keyctrl = 0
ownpal = 1

[State 60]
type = VelSet
trigger1 = animelem = 3
x = 35

[State 60]
type = VelSet
Triggerall = prevstateno = 50||prevstateno = 80
trigger1 = animelem = 3
y = -2

[State 60]
type = VelSet
trigger1 = animelem = 4
x = 2

[State 60]
type = StateTypeSet
trigger1 = pos y < 0
statetype = A
movetype = I
physics = A

[State 60]
type = ChangeState
trigger1 = ifelse(statetype = A,time = 13,animtime = 0)
value = ifelse(statetype = A,50,0)
ctrl = 1

