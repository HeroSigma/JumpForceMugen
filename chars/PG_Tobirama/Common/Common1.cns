;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 5900]
type = S

;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                      SELECIONAR PALETA 
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[State 5900, Palette Selector]
type = VarSet
trigger1 = 1
v = 28
value = 1       ;1 ativa e 0 desativa o Palette Selector na Intro

[State 5900, Pal Selector on]
type=helper
triggerall=var(28)&&!numhelper(256)&&!AILevel&&numenemy
trigger1= roundno = 1 && matchno=1 && !(teammode = simul) && !(enemy, teammode = simul)
trigger2= !var(27)
trigger3=(teammode = turns)
trigger3=!roundsexisted && (enemy,roundsexisted)
id=256
stateno=256
facing=facing
ownpal=1
size.xScale=0.5                   ;TAMANHO X DO CURSOR
size.yScale=0.5                   ;TAMANHO Y DO CURSOR

[state 5900, No Palette selector]
type = remappal
trigger1 = !var(28)
trigger2 = AILevel && !var(27)
source = 1, 1
dest = 1, palno
ignorehitpause = 1

[State 5900, VarSet]
type = VarSet
trigger1 = !time&&!var(26)&&!var(32)
var(32)=Ifelse(palno>=7,1,0)
ignorehitpause =1


[State 5900, Turns Intro]
type = ChangeState
trigger1 = TeamMode = Turns
trigger1 = !RoundsExisted && RoundNo >= 2
value = 6900

[State 5900, Intro Decider]
type = ChangeState
trigger1 = RoundNo = 1
value = 190

[State 5900, End]
type = ChangeState
trigger1 = 1
value = 0

