;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;                                                            Dash Base >> - Run Forward
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

; Run Forward
[Statedef 61]
type    = S
movetype= I
physics = S
velset = 0,0
ctrl = 0
anim = 102
sprpriority = 2

[State 61]
type = PalFX
trigger1 = time=0
time =5
add = 100,100,100
mul = 256,256,256
invertall = 0
color = 0
ignorehitpause = 1
persistent = 1

[State 61]
type = AfterImage
trigger1 =time=2
time = 5
length = 10
palbright = 0,0,0
palcontrast = 50,50,50
paladd=0,0,0
palmul = .90, .90, .90
timegap = 1
framegap = 1
trans = add
ignorehitpause = 1
persistent = 1

[State 61]
type = EnvShake
trigger1 = time = 0
time = 10
freq = 40
ampl = -6
phase = 90
ignorehitpause =1
persistent =  1

[State 61]
type = PlaySnd
trigger1 = time = 0
value = S5,35
volumescale = 999

[State 61]
type = Explod
trigger1 = timemod = 6,0 && time > 5 && pos y = 0
anim = 7022
ID = 61
pos = 0,0
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .35,.35
sprpriority = 3
ontop = 0
ownpal = 1
removeongethit = 1

[State 61]
type = PlaySnd
trigger1 = time = 2
value = S60,1
volume = 0

[State 61]
type = PlaySnd
trigger1 = animelem = 3||animelem = 6
value = S20,1
volume = 999

[State 61]
type = PlaySnd
trigger1 = animelem = 2
value = s0,1+(random%3)
volume = 200

[State 61]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 61]
type = VelSet
trigger1 = time > 2
x = 10
y = ifelse(pos y < 0,.5,0)

[State 61]
type = Gravity
trigger1 = time > 2 && pos y < 0

[State 61]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 61]
type = ChangeState
Triggerall = pos y >= 0
Triggerall = time > 2
trigger1 = command = "up"
value = 40

[State 61]
type = ChangeState
Triggerall = time > 2
trigger1 = pos y > 0
value = 12

; A
[State 61, 14]
type = ChangeState
value = 200
Triggerall = time > 2
trigger1 = command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 100)

; B
[State 61, 15]
type = ChangeState
value = 300
Triggerall = time > 2
trigger1 = command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 100)

; C
[State 61, 16]
type = ChangeState
value = 400
Triggerall = time > 2
trigger1 = command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 100)

[State 61, End]
type = ChangeState
Triggerall = time > 10
trigger1 = ailevel = 0 && command != "holdfwd"
trigger2 = ailevel > 0 && time = 100+random%200
trigger3 = ailevel > 0 && p2bodydist x < 50
trigger4 = roundstate != 2
value = 62


