;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;		                                     Animation Parado
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, StopSnd]
type = StopSnd
trigger1 = time = 0
channel = 10

[State 0]
type = ChangeAnim
trigger1 = Anim != 0 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 0

[State 0]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0]
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time = 4
x = 0

[State 0]
type = ChangeState
trigger1 = !alive
value = 5050
ctrl = 0


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;		                                  Animation Agachado
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 10]
type = C
physics = C
anim = 10

[State 10]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10]
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0

[State 10]
type = ChangeState
trigger1 = AnimTime = 0
value = 11


;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================
;		                                          Crouch
;====================================================================================================================================
;::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;====================================================================================================================================

[Statedef 11]
type = C
physics = C
anim = 11
sprpriority = 0

[State 11]
type = ChangeAnim
trigger1 = anim = 6
value = 6

[State 11]
type = ChangeAnim
trigger1 = Anim != 11 && Anim != 6
trigger2 = Anim = 6 && AnimTime = 0
value = 11

[State 11]
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0


