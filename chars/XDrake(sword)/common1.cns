[State 20, 4]
type = ChangeAnim
triggerall = var(2)<= 1
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 2021 && Anim != 2005)
trigger2 = (Anim = 5 || anim = 2005) && AnimTime = 0
value = 21+var(11)

[State 20, 3]
