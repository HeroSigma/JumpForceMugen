;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0




[State 191, PalFX - CHargue]
type			= PalFX
triggerall		= prevstateno = 3100
trigger1		= time = 0
time			= 25
add			= 10,10,10
;mul			= 20,20,20
sinadd		        = 220,220,220,50
invertall		= 0
ignorehitpause  = 1

[State 0, 1]
type = ChangeAnim
triggerall = var(2) <=1
trigger1 = (Anim != 0 && Anim != 5 && Anim != 2000 && Anim != 2005)
trigger2 = (Anim = 5 || anim = 2005) && AnimTime = 0
value = 0+var(11);ifelse(Var(2) = 1, 2000,0)
[State 0, 1]
type = ChangeAnim
triggerall = var(2) = 2
trigger1 = (Anim != 0 && Anim != 5 && Anim != 4000 && Anim != 4005)
trigger2 = (Anim = 5 || anim = 4005) && AnimTime = 0
value = 0+var(11);ifelse(Var(2) = 1, 2000,0)

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3]
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050

[State 0, DestroySelf]
type = DestroySelf
trigger1 = ishelper

