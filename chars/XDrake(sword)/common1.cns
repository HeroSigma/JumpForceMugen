triggerall = var(2)= 2
triggerall = vel x > 0
trigger1 = (Anim != 20 && Anim != 5 && Anim != 4020 && Anim != 4005)
trigger2 = (Anim = 5 || anim = 4005) && AnimTime = 0
value = 20+var(11)

[State 20, 4]
type = ChangeAnim
triggerall = var(2) = 2
triggerall = vel x < 0
trigger1 = (Anim != 21 && Anim != 5 && Anim != 4021 && Anim != 4005)
trigger2 = (Anim = 5 || anim = 4005) && AnimTime = 0
