trigger1 = Animelem = 4 || Animelem = 7
value = S155,1;S40,2

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S113,0;S1,5

[State 200, End]
type = ChangeState
trigger1 = time > 10
value = 2101
