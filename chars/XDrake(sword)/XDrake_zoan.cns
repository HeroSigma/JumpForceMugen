trigger1 = time < 99
trans = addalpha
alpha = 0+(time*6),256

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow

[State 0, End]
type = Destroyself
trigger1 = time >=30
trigger2 = root,stateno != 23000
;-------------------------------------------------------------------------------