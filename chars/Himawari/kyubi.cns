;------------------------------------
; Kyubi Idle Override
;------------------------------------
[Statedef 0]
type = S
physics = S
sprpriority = 0

; Kyubi Active → use custom idle
[State 0, Kyubi Idle]
type = ChangeAnim
triggerall = var(21) = 1
trigger1 = Anim != 98989
value = 98989

; Normal idle (fallback if not Kyubi)
[State 0, Normal Idle]
type = ChangeAnim
triggerall = var(21) = 0
trigger1 = Anim != 0
value = 0



