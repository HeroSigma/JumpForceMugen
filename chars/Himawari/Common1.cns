trigger1 = time = 2
value = S60,1
volume = 0

[State 61, 6]
type = PlaySnd
trigger1 = animelem = 3||animelem = 6
value = S20,1
volume = 999

[State 61, 7]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 61, 8]
type = VelSet
trigger1 = time > 2
x = 10
y = ifelse(pos y < 0,.5,0)

[State 61, 9]
type = Gravity
trigger1 = time > 2 && pos y < 0

[State 61, 10]
type = PosSet
trigger1 = pos y > 0
y = 0

[State 61, 11]
type = ChangeState
Triggerall = pos y >= 0
Triggerall = time > 2
trigger1 = command = "up"
value = 40

[State 61, 12]
type = ChangeState
Triggerall = time > 2
trigger1 = pos y > 0
value = 12

; A
[State 61, 13]
type = ChangeState
value = 200
Triggerall = time > 2
trigger1 = command = "a"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 100)

; B
[State 61, 14]
type = ChangeState
value = 300
Triggerall = time > 2
trigger1 = command = "b"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 100)

; C
[State 61, 15]
type = ChangeState
value = 400
Triggerall = time > 2
trigger1 = command = "c"
trigger2 = roundstate = 2 && ailevel > 0 && p2bodydist x < 30 && random < (ailevel * 100)

[State 61, 16]
type = ChangeState
Triggerall = time > 10
trigger1 = ailevel = 0 && command != "holdfwd"
trigger2 = ailevel > 0 && time = 100+random%200
trigger3 = ailevel > 0 && p2bodydist x < 50
trigger4 = roundstate != 2
value = 62

