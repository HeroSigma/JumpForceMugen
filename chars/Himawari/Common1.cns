Triggerall = prevstateno = 50||prevstateno = 80
trigger1 = animelem = 2
y = -2

[State 60, 4]
type = VelSet
trigger1 = animelem = 3
x = ifelse(var(21)=1, 4, 2)

[State 60, 5]
type = Explod
trigger1 = time = 2
anim = 9024
ID = 60
pos = -50,-30
postype = p1
facing = 1
vfacing = 1
bindtime = -1
removetime = -2
scale = .5,.5
sprpriority = 1
ontop = 0
ownpal = 1
removeongethit = 1
ignorehitpause = 1
trans = sub

[State 60, 6]
