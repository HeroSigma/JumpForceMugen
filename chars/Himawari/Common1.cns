trigger1 =time=2
time = 5
length = 10
palbright = 0,0,0
palcontrast = 100,100,100
paladd=0,0,0
palmul = .90, .90, .90
timegap = 1
framegap = 1
trans = add
ignorehitpause = 1
persistent = 1

[State 61, 3]
type = EnvShake
trigger1 = time = 0
time = 10
freq = 40
ampl = -6
phase = 90
ignorehitpause =1
persistent =  1

[State 61, 4]
type = Explod
trigger1 = timemod = 6,0 && time > 5 && pos y = 0
anim = 7022
ID = 61
pos = 0,0
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .35,.35
sprpriority = 3
ontop = 0
ownpal = 1
removeongethit = 1

[State 61, 5]
