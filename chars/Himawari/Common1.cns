;===============================================================================
;--------------------------------- Commons -------------------------------------
;-------------------------------------------------------------------------------
;-------------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 2

[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0 && Anim != 5 && Anim != 11000 && Anim != 11005
trigger2 = (Anim = 0 || Anim = 11000 || Anim = 5 || anim = 11005) && AnimTime = 0
value = 0

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 0, 4]
type = NotHitBy
trigger1 = ctrl = 0
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1

[State 0, 5]
type = PlayerPush
trigger1 = ctrl = 0
trigger1 = 1
value = 0

[State 0, 6] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
;-------------------------------------------------------------------------------
;;-------------------------------------------------------------------------------
; Stand to Crouch (Statedef 10)
;-------------------------------------------------------------------------------
[Statedef 10]
type    = C
physics = C
anim = 10
sprpriority = 2

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 11

; Kyubi override: Stand to Crouch
[State 10, Kyubi Stand to Crouch]
type = ChangeAnim
trigger1 = var(21) = 1 && Anim != 98985   ; Kyubi stand-to-crouch animation
value = 98985

; Normal fallback
[State 10, Normal Stand to Crouch]
type = ChangeAnim
trigger1 = var(21) = 0 && Anim != 10
value = 10

;-------------------------------------------------------------------------------
; Crouching (Statedef 11)
;-------------------------------------------------------------------------------
[Statedef 11]
type    = C
physics = C
anim = 11
sprpriority = 2

[State 11, 1]
type = ChangeAnim
trigger1 = anim = 6
value = 6

[State 11, 2]
type = ChangeAnim
trigger1 = Anim != 11 && Anim != 6 && Anim != 11011 && Anim != 11006
trigger2 = (Anim = 6 || anim = 11006) && AnimTime = 0
value = 11

; Kyubi crouch override
[State 11, Kyubi Crouch]
type = ChangeAnim
trigger1 = var(21) = 1 && Anim != 98984   ; Kyubi crouch animation
value = 98984

; Normal crouch fallback
[State 11, Normal Crouch]
type = ChangeAnim
trigger1 = var(21) = 0 && Anim != 11
value = 11

;-------------------------------------------------------------------------------
; Crouch to Stand (Statedef 12)
;-------------------------------------------------------------------------------
[Statedef 12]
type    = S
physics = S
anim = 12
sprpriority = 2

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0

; Kyubi crouch-to-stand override
[State 12, Kyubi Crouch to Stand]
type = ChangeAnim
trigger1 = var(21) = 1 && Anim != 98983  ; Kyubi stand-up animation
value = 98983

; Normal crouch-to-stand fallback
[State 12, Normal Crouch to Stand]
type = ChangeAnim
trigger1 = var(21) = 0 && Anim != 12
value = 12

;-------------------------------------------------------------------------------
; Walk (Statedef 20)
;-------------------------------------------------------------------------------
[Statedef 20]
type    = S
physics = S
sprpriority = 2

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x)+ifelse(var(20) != 0,2,0)

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x)-ifelse(var(20) != 0,2,0)

; Walk forward animation
[State 20, 3]
type = ChangeAnim
trigger1 = vel x > 0 && var(21) = 1 && Anim != 98987   ; Kyubi forward walk/run
value = 98987

[State 20, 4]
type = ChangeAnim
trigger1 = vel x > 0 && var(21) = 0 && Anim != 20       ; Normal forward walk
value = 20

; Walk backward animation
[State 20, 5]
type = ChangeAnim
trigger1 = vel x < 0 && var(21) = 1 && Anim != 98986   ; Kyubi backward walk/run
value = 98986

[State 20, 6]
type = ChangeAnim
trigger1 = vel x < 0 && var(21) = 0 && Anim != 21       ; Normal backward walk
value = 21

;-------------------------------------------------------------------------------
;-------------------------------------------------------------------------------
; Jump Start
[Statedef 40]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 2

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = AnimTime = 0 && prevstateno = 61 && sysvar(1) = 1
x = const(velocity.runjump.fwd.x) + 6
y = const(velocity.jump.y) - 1

[State 40, 6]
type = AfterImage
trigger1 = prevstateno = 61 && time = 2
time = 5
length = 10
palbright = 0,0,0
palcontrast = 100,100,100
paladd=0,0,0
palmul = .90, .90, .90
timegap = 1
framegap = 1
trans = add
ignorehitpause = 1
persistent = 1

[State 40, 7]
type = Explod
trigger1 = prevstateno = 61 && time = 2
anim = 7132
ID = 40
pos = 10,2
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .9,.9
sprpriority = 1
ontop = 0
ownpal = 1
removeongethit = 0
ignorehitpause = 1

[State 40, 8]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

;-------------------------------------------------------------------------------
;-------------------------------------------------------------------------------
; AirJump Start
[Statedef 45]
type    = A
physics = N
ctrl = 0
velset = 0,0
sprpriority = 2

[State 45, 1]
type = PlaySnd
trigger1 = Time = 0
value = S40,2
volume = 200

[State 45, 2]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse(var(21)=1, 98978, ifelse(SelfAnimExist(44),44,41))

[State 45, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 45, 4]
type = VarSet
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 45, 5]
type = VarSet
trigger1 = command = "holdback"
sysvar(1) = -1

[State 45, 6]
type = VelSet
trigger1 = Time = 2
x = ifelse(sysvar(1)=0, const(velocity.airjump.neu.x), ifelse(sysvar(1)=1, const(velocity.airjump.fwd.x), const(velocity.airjump.back.x)))
y = const(velocity.airjump.y)

[State 45, 7]
type = ChangeState
trigger1 = Time = 2
value = 50
ctrl = 1


;-------------------------------------------------------------------------------
; Jump Up
[Statedef 50]
type    = A
physics = A
sprpriority = 2

[State 50, 1]
type = VelSet
Triggerall = prevstateno = 60
trigger1 = time = 0
x = 2

[State 50, 2]
type = VelSet
Triggerall = prevstateno = 70
trigger1 = time = 0
x = -2

[State 50, 3]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 50, 4]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse(var(21)=1, ifelse((vel x)=0, 98981, ifelse((vel x)>0, 98980, 98979)), ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43)))

[State 50, 5]
type = ChangeAnim
trigger1 = Vel y > -2
persistent = 0
value = ifelse(var(21)=1, 98978, 44)

;-------------------------------------------------------------------------------
; Jump Down (empty state for compatibility)
[Statedef 51]
type    = A
physics = A
sprpriority = 2

[State 51, 1]
type = Null
trigger1 = 1

