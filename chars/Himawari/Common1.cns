;-------------------------------------------------------------------------------
; GUARD (start)
[Statedef 120]
type = U
physics = U

[State 120, 1]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse(var(21)=1, 98971, 120 + (statetype = C) + (statetype = A)*2)

[State 120, 2]
type = StateTypeSet
trigger1 = Time = 0 && statetype = S
physics = S

[State 120, 3]
type = StateTypeSet
trigger1 = Time = 0 && statetype = C
physics = C

[State 120, 4]
type = StateTypeSet
trigger1 = Time = 0 && statetype = A
physics = A

[State 120, 5]
type = StateTypeSet
trigger1 = statetype = S && command = "holddown"
statetype = C
physics = C

[State 120, 6]
type = StateTypeSet
trigger1 = statetype = C && command != "holddown"
statetype = S
physics = S

[State 120, 7]
type = ChangeState
trigger1 = AnimTime = 0
value = ifelse(var(21)=1, 98968, 130 + (statetype = C) + (statetype = A)*2)

[State 120, 8]
type = ChangeState
trigger1 = command != "holdback"
trigger2 = !inguarddist
value = ifelse(var(21)=1, 98965, 140)

