;===============================================================================
;--------------------------- Kage Bunshin No Jutsu -----------------------------
;===============================================================================
; Kage Bunshin - Stand
[Statedef 15000]
type = S
physics = S
sprpriority = 2

[State 15000, HitBy]
type = HitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 1
ignorehitpause = 1

[State 15000, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 1
ignorehitpause = 1

[State 15000, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 1
ignorehitpause = 1

[State 15000, PosSet]
type = PosSet
trigger1 = 1
y = 0
ignorehitpause = 1

[State 15000, ChangeState]
type = ChangeState
trigger1 = parent,var(16) <= 0
value = 15001

[State 15000, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = ifelse(parent,var(16) > 0,15800,15001)
time = 99999999999999999999999999999999999999999
ignorehitpause = 1

[State 15000, Turn]
type = Turn
trigger1 = p2bodydist x < -5

[State 15000, ChangeAnim]
type = ChangeAnim
trigger1 = Anim != 0 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 0

[State 15000, VelSet]
type = VelSet
trigger1 = Time = 0
y = 0

[State 15000, VelSet]
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

[State 15000, Bushin Fin]
type = ChangeState
trigger1 = parent,stateno = 170
trigger2 = parent,stateno = 181
trigger3 = parent,life = 0
trigger4 = win || lose || drawgame
value = 15001

[State 15000, Walk]
type = ChangeState
Triggerall = time > 10
trigger1 = p2bodydist x > 50 && random < 700
value = 15020

[State 15000, Teleport]
type = ChangeState
Triggerall = time > 10
trigger1 = p2bodydist x > 150 && random < 700
trigger2 = p2bodydist x <= 50 && enemy,movetype = A
trigger3 = random < 100
value = 15700

[State 15000, Jump Back]
type = ChangeState
Triggerall = time > 10
Triggerall = stateno != 15105
trigger1 = p2bodydist x <= 30 && p2movetype = A
trigger2 = p2bodydist x <= 50 && random <= 200
trigger3 = random < 400
value = 15105

[State 15000, Jump Start]
type = ChangeState
Triggerall = time > 10
Triggerall = p2statetype = A
trigger1 = p2bodydist x < 100
trigger2 = random < 600
value = 15040

[State 15000, Combo 1]
type = ChangeState
Triggerall = StateType = S
trigger1 = random <=20 && time >= 10
trigger2 = p2bodydist x <= 30 && random <=500
value = 15100

[State 15000, Combo 2]
type = ChangeState
Triggerall = StateType = S
trigger1 = random <=20 && time >= 10
trigger2 = p2bodydist x <= 30 && random <=500
value = 15200

[State 15000, Super Dash Punch]
type = ChangeState
Triggerall = parent,power >= 100
Triggerall = StateType = S
Triggerall = (p2statetype = S) || (p2statetype = C)|| (p2statetype = A)
trigger1 = P2BodyDist x >= 110 && Random = [80,90]
trigger2 = Random = [70,80]
value = 15400

[State 15000, Boom Kunai Throw]
type = ChangeState
Triggerall = StateType = S
Triggerall = parent,power >= 50
trigger1 = random <=10 && time >= 8
trigger2 = p2bodydist x >= 70 && random <=20
value = 15500

[State 15000, Power Charge]
type = ChangeState
Triggerall = parent,movetype != H
Triggerall = parent,power < 800
Triggerall = StateType = S
trigger1 = P2BodyDist X > 120 && Random <= 50
trigger2 = Random = [10,20]
trigger3 = parent,movetype != H
value = 15750
