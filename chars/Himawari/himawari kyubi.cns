
;-------------------------------------------------------------------------------
; Himawari Kyubi Mode - Standalone CNS
; Drop this file into your character folder and add to .def:
;   [Files]
;   cns = himawari.cns
;   cns = himawari_kyubi.cns
;
; This file assumes you'll wire inputs in the CMD.
; Kyubi mode flag: var(20) == 1
;-------------------------------------------------------------------------------

;===============================================================================
; GLOBAL / ALWAYS-ON CONTROLLERS
;===============================================================================

[Statedef -3]
; Reset Kyubi flag on round start
[State -3, ResetKyubiOnIntro]
type = VarSet
trigger1 = RoundState = 0
v = 20
value = 0

; Optional: Keep Kyubi after round if you want (commented by default)
;[State -3, PersistKyubi]
;type = VarSet
;trigger1 = 0
;v = 20
;value = Var(20)

;===============================================================================
; TRANSFORMATION
;===============================================================================

; Play this state from CMD (e.g., D,DF,F+z). Sets var(20)=1.
[Statedef 33334]
type    = S
movetype= I
physics = N
velset  = 0,0
ctrl    = 0
anim    = 33334
sprpriority = 4

; --- Optional SFX/FX hooks (uncomment and adjust as needed) ---
;[State 33334, Snd]
;type = PlaySnd
;trigger1 = AnimElem = 1
;value = 0,0

;[State 33334, FX Helper Start]
;type = Helper
;trigger1 = AnimElem = 2
;name = "Kyubi Aura Start"
;stateno = 10970
;id = 10970
;ownpal = 1
;postype = p1
;pos = 0,0
;keyctrl = 0
;pausemovetime = 9999
;supermovetime = 9999

; When anim finishes, set Kyubi flag and return control
[State 33334, BecomeKyubi]
type = VarSet
trigger1 = AnimTime = 0
v = 20
value = 1

[State 33334, EndFX]
type = Helper
trigger1 = AnimTime = 0
name = "Kyubi Aura Fin"
stateno = 10975
id = 10975
ownpal = 1
postype = p1
pos = 0,0
keyctrl = 0
pausemovetime = 30
supermovetime = 30

; Go to idle (you can redirect to your own idle statenumber if different)
[State 33334, ToIdle]
type = ChangeState
trigger1 = AnimTime = 0
value = 19000
ctrl = 1

;===============================================================================
; OPTIONAL KYUBI VISUAL OVERRIDES (ANIMATION-ONLY)
; Wire these only if you want her stand/walk/run/jump to visually swap after var(20)=1
; Commented by default to avoid conflicts with base character states.
;===============================================================================

[Statedef -2]
; -- Example: Force Kyubi idle anim while in stand state 0 (if your char uses 0)
;[State -2, KyubiStandIdle]
;type = ChangeAnim
;triggerall = Var(20) = 1
;triggerall = StateNo = 0
;trigger1 = Anim != 19000
;value = 19000

; -- Example: Walk forward (commonly state 20)
;[State -2, KyubiWalkFwd]
;type = ChangeAnim
;triggerall = Var(20) = 1
;triggerall = StateNo = 20
;trigger1 = Anim != 19020
;value = 19020

; -- Example: Walk back (commonly state 21)
;[State -2, KyubiWalkBack]
;type = ChangeAnim
;triggerall = Var(20) = 1
;triggerall = StateNo = 21
;trigger1 = Anim != 19021
;value = 19021

;===============================================================================
; IDLE VARIATIONS (Kyubi-only)
;===============================================================================
[Statedef 19000]
type = S
movetype = I
physics = N
ctrl = 1
anim = 19000
sprpriority = 3
[State 19000, KyubiOnly]
type = AssertSpecial
trigger1 = Var(20) = 1
flag = noshadow

[Statedef 19005]
type = S
movetype = I
physics = N
ctrl = 1
anim = 19005
