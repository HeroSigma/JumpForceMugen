;turn
[State 0, Turn]
type = Turn
trigger1 = P2dist X < -10

;fly forward
[State 0, ChangeState]
type = ChangeState
trigger1 = P2dist X < -10
value = 5556
ctrl = 1

;fly forward
[State 0, ChangeState]
type = ChangeState
trigger1 = command = "holdfwd"
trigger1 = var(59) = 0
trigger2 = var(59) > 0
trigger2 = random = [200,250]
trigger2 = abs(p2bodydist x) > 50
value = 101011
ctrl = 1
;anim =
;ignorehitpause =
;persistent =

;fly backward
[State 0, ChangeState]
type = ChangeState
trigger1 = command = "holdback"
trigger1 = var(59) = 0
trigger2 = var(59) > 0
trigger2 = random = [300,350]
trigger2 = abs(p2bodydist x) < 50
value = 101029
ctrl = 1
;anim =
;ignorehitpause =
;persistent =

;fly up
[State 0, ChangeState]
type = ChangeState
trigger1 = command = "holdup"
trigger1 = var(59) = 0
trigger2 = var(59) > 0
trigger2 = random = [400,425]
trigger2 = p2bodydist y <= -25
value = 101031
ctrl = 1
;anim =
;ignorehitpause =
;persistent =

;fly down
[State 0, ChangeState]
type = ChangeState
trigger1 = command = "holddown"
trigger1 = var(59) = 0
trigger2 = var(59) > 0
trigger2 = random = [425,999]
trigger2 = p2bodydist y >= 50
value = 101041
ctrl = 1
;anim =
;ignorehitpause =
;persistent =

; go back to semi-bird form when power is less than 1000
[State 0, ChangeState]
type = ChangeState
trigger1 = power < 10
value = 50
ctrl = 1

;go back to jump/fall state
[State 0, ChangeState]
type = ChangeState
trigger1 = Win = 1
;trigger2 = roundstate != 2
value =50
ctrl = 1

[State 0, ChangeState]
type = ChangeState
trigger1 = command="a"
value = 10011
ctrl = 1

[State 0, ChangeState]
type = ChangeState
trigger1 = command="b"
value = 10015
ctrl = 1

[State 0, ChangeState]
type = ChangeState
trigger1 = command != "holdfwd"
trigger1 = command="c"
value = 2640
ctrl = 1

[State 0, ChangeState]
type = ChangeState
trigger1 = command = "holdfwd"
trigger1 = command="c"
value = 2640
ctrl = 1

[State 0, Super Velocity]
type = ChangeState
;triggerall = var(40) <= 4
triggerall = power >= 1000
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = ailevel > 0 && random < (ailevel * 100)/2
trigger2 = p2bodydist x = [40,200]
value = 12500

[State 0, Speed Kick]
type = ChangeState
Triggerall = power >= 2000
trigger1 = ailevel = 0 && command = "SPECIAL 3"
trigger2 = ailevel > 0 && roundstate = 2
trigger2 = p2bodydist x = [50,150]
trigger2 = random < (ailevel * 100)/2
value = 12200

[State 0, Spin Kick]
type = ChangeState
Triggerall = power >= 1500
trigger1 = ailevel = 0 && command = "SPECIAL 5"
trigger2 = ailevel > 0 && roundstate = 2
trigger2 = p2bodydist x = [50,200]
trigger2 = random < (ailevel * 100)/2
value = 12000


;go back to  damage fall state
[State 0, ChangeState]
type = ChangeState
trigger1 = Life = 0
value = 5050
ctrl = 1

