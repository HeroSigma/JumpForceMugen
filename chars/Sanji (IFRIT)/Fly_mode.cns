;flying transform
[Statedef 99910]
type    = A
movetype= I
physics = N
juggle  = 0
poweradd= 0
ctrl = 0
anim = 99910
velset = 0,-1

[State 0, PlaySnd]
type = PlaySnd
trigger1 =time = 1
value = S131,1
volume = 999

[State 0, VarSet]
type = VarSet
trigger1 = animelem=2
v = 10
value = 2

[State 0, HitOverride]
type = HitOverride
trigger1 = power>10
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
slot = 0
stateno = 3130
time = 1
forceair = 0
;ignorehitpause =
;persistent =

[State 0, HitOverride]
type = HitOverride
trigger1 = random < 100
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
slot = 0
stateno = 3130
time = 1
forceair = 0
;ignorehitpause =
;persistent =

[State 0, ChangeState]
type = ChangeState
trigger1 = time = 10
value = 5550
ctrl = 1
;---------------------------------------------------------------------------
;                              FLYING MODE
;---------------------------------------------------------------------------
; flying: stance
[Statedef 5550]
type    = A
movetype= I
physics = N
juggle  = 0
poweradd= 0
ctrl = 0
;anim = 5550
velset = 0,0
sprpriority = -1

[State 1, Andando]
type = PlaySnd
trigger1 = timemod = 40,0
value = S132,0
volume = 50
channel = 31

[State 0, 1]
type = ChangeAnim
triggerall = var(2) = 1
trigger1 = Anim != Cond(Facing = -1,5555,5550) && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = Cond(Facing = -1,5555,5550)

;[State 0, 0]
;type = ChangeAnim
;triggerall = facing = 1
;trigger1 = Anim != 5550
;value = 5550

;[State 0, 0]
;type = ChangeAnim
;triggerall = facing != 1
;trigger1 = Anim != 5555
;value = 5555

[State 0, PowerAdd]
type = PowerAdd
trigger1 = timemod = 5,0
value = -10

;limit for flying up
[State 0, PosSet]
type = PosSet
trigger1 = pos y <= -150
y = -150

;fly stance float up
[State 0, VelSet]
type = VelSet
trigger1 = gametime%30 = [0,14]
x = 0
y = -0.1

[State 1118, Explod]
type = Explod
trigger1 = gametime%30 = [0,14]
anim = 7014
ID = 7014
pos = -5,3
postype = p1  ;p2,front,back,left,right
