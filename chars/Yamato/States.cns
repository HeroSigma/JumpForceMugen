;---------------------- Iki Variable ----------------------
; var(2):= Mencolot Peng 2
; var(4):= Berubah Hybrid
; var(10):= 2000+
; var(11):= 4000+
; var(12):= Peteng (Specials/Supers)
; var(14):= Mabok
; var(17):= Fire Particle
; var(16):= Naga
;---------------------- Integer variable list ----------------------

; var(0):= 1215
; var(1):= 800, 350, 1215
; var(2):= -3, 1216
; var(4):= 1008, 1009, 1700, 1802, 1900, 400 - HYBRID, 401, -2
; var(6):= 61, -2
; var(7):= 5100 - HIT_BOUNCE (hit ground), -2
; var(8):= 5120 - HIT_GETUP
;var(10):= 62, -3, 6996
;var(11):= -3
;var(12):= 1400, 1700, 1800, 1802, 1900, 1950, 3005, 6900
;var(14):= 900, 901, -2
;var(16):= 910, 1300, 1302
;var(17):= 1202, 1203, 1800, -2, 902, 3010
;var(25):= -2
;var(29):= 1201, -2

;---------------------- Float variable list ----------------------

