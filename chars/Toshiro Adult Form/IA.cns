;===============================================================================
; INTELIGENCIA ARTIFICIAL:
;===============================================================================
[Statedef -2]

[State 0, Run]
type = ChangeState
triggerall = stateno != 60
triggerall = stateno != 70
triggerall = stateno != 110
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)/2
value = ifelse(pos y >= 0,60,110)

[State 0, Run Atras]
type = ChangeState
triggerall = stateno != 60
triggerall = stateno != 70
triggerall = stateno != 110
triggerall = backedgebodydist > 50
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 100 && p2movetype = A
trigger1 = random < (ailevel * 100)/4
value = ifelse(pos y >= 0,70,110)

[state 0]
type = changestate
triggerall = (roundstate = 2) && (alive) && ((ctrl) || (numhelper(99999) > 0)) && (pos y = 0)
trigger1 = ((!ailevel) && (command = "FF"))
trigger2 = ((ailevel) && (stateno = 20) && (animelemtime(2) >= 0) && (enemynear, p2bodydist x = [100, (helper(99000), var(1))]) && (var(58) = (1 + (random % 6))))
trigger2 = ((enemynear, movetype != a))
trigger3 = ((ailevel) && (enemynear, p2bodydist x = [50, (helper(99000), var(1)) * 4]) && (var(58) = (1 + (random % 6))))
trigger3 = (enemynear, stateno != [5090, 5150])
value = 60
[state 0]
type = changestate
triggerall = (roundstate = 2) && (alive) && (ctrl) && (pos y = 0) && (numhelper(1350) = 0)
trigger1 = ((!ailevel) && (command = "BB"))
trigger2 = ((ailevel) && (stateno = 60) && (animelemtime(2) >= 0) && (enemynear, p2bodydist x <= (helper(99000), var(1))) && (var(58) = (1 + (random % 6))))
trigger2 = ((enemynear, movetype != a))
trigger3 = ((ailevel) && (enemynear, p2bodydist x >= (helper(99000), var(1))) && ((var(58) = 1) || (var(58) = 3)))
trigger3 = ((enemynear, movetype = a))
value = 70
[state 0]
type = changestate
triggerall = (roundstate = 2) && (alive) && (ctrl) && (numhelper(1350) = 0)
trigger1 = ((!ailevel) && (command = "FF") || (command = "BB"))
trigger2 = ((ailevel) && (enemynear, p2bodydist x = [50, (helper(99000), var(1)) * 2]) && (var(58) = (1 + (random % 6))))
trigger2 = ((enemynear, movetype != a))
trigger3 = ((ailevel) && (enemynear, p2bodydist x = [0, (helper(99000), var(1)) * 2]) && (var(58) = (1 + (random % 6))))
trigger3 = ((enemynear, movetype = a))
value = 110
[State 0, Guard]
type = ChangeState
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = (p2bodydist x < 50 && p2movetype = A) || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/2
value = ifelse(statetype = A,132,130)

[State 0, Guard]
type = assertspecial
trigger1 = ailevel > 0 && roundstate = 2
flag = nostandguard
flag2 = nocrouchguard
flag3 = noairguard
ignorehitpause = 1

[State 0, Power Charge]
type = ChangeState
triggerall = statetype != A
triggerall = power < 3000
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)*2
value = 500

[State 0, Power Charge End]
type = ChangeState
triggerall = time >= 12
triggerall = stateno = 500
triggerall = ailevel > 0
trigger1 = (p2bodydist x < 50) || (enemy,numproj > 0)
trigger2 = power = 3000
value = 501

[State 0, A]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 30
trigger1 = random < (ailevel * 100)*4
value = 300

[State 0, B]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x < 30
trigger1 = random < (ailevel * 100)*4
value = 200

[State 0, C]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x< 30 
trigger1 = random < (ailevel * 100)
value = 400

[State 0, Instantaneous Freeze]
type = ChangeState
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [100,120]
trigger1 = random < (ailevel * 100)
