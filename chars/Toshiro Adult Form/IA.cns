Triggerall = numhelper(1350) = 0
Triggerall = numhelper(1050) = 0
triggerall = power >= 1500
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
triggerall = p2bodydist x > 100
trigger1 = random < (ailevel * 100)
value = 1000

[State 0, Guncho Tsurara]
Triggerall = numhelper(1850) = 0
Triggerall = numhelper(1852) = 0
Triggerall = numhelper(1855) = 0
type = ChangeState
triggerall = power >= 2000
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl || numhelper(700) > 0
triggerall = p2bodydist x >= 151
trigger1 = random < (ailevel * 100)*1.5
value = 1800

[State 0, Flash Freezing]
type = ChangeState
triggerall = power >= 2000
Triggerall = numhelper(1350) = 0
Triggerall = numhelper(1550) = 0
Triggerall = numhelper(1555) = 0
Triggerall = numhelper(1560) = 0
triggerall = statetype != A
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = p2bodydist x = [0,150] 
trigger1 = random < (ailevel * 100)*2
