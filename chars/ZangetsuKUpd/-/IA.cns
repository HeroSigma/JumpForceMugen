TriggerAll = Var(13)
TriggerAll = StateNO != 99600
Triggerall = Var(2) != 4
TriggerAll = GetHitVar(Guarded) 
TriggerAll = MoveType = H
TriggerAll = PlayerIDExist(Var(16))
Triggerall = StateType != A
TriggerAll = !HitOver
Trigger1 = AiLevel && NumEnemy
Trigger1 = RoundState = 2
Trigger1 = PlayerIDExist(Var(16))
Trigger1 = Var(20) = [(0 * AiLevel),(2 * AiLevel)]
Trigger1 = Fvar(39) <= 200/5
Trigger1 = EnemyNear,Pos Y >= Const(Size.Mid.Pos.Y)
Value = 99600
IgnoreHitPause = 1

[State 0, DFWD]
type = ChangeState
triggerall = statetype != A
triggerall = stateno != 106
triggerall = ailevel > 0 && roundstate = 2
triggerall = ctrl
triggerall = frontedgebodydist > 70
triggerall = p2bodydist x < 60 && p2movetype = A || (enemy,numproj > 0)
trigger1 = random < (ailevel * 100)/6
trigger2 = backedgebodydist < 30
trigger2 = random < (ailevel * 100)/3
value = 106

[State 0, Ryukansen]
Type = ChangeState
Triggerall = StateType!=A
Triggerall = P2Stateno = 200+Var(11) || P2Stateno = 300+Var(11) || P2Stateno = 400+Var(11)
Triggerall = AILevel > 0 && RoundState = 2
Triggerall = ctrl
Trigger1 = P2BodyDist x>=100
Trigger1 = Random < (AILevel * 100)/6
Trigger2 = P2BodyDist x = [50,100]
Trigger2 = Random < (AILevel * 100)/8
Trigger3=P2BodyDist x < 50
Trigger3=Random < (AILevel * 100)/10
Value = 106

[State 0, ChangeState]
type = ChangeState
value = 106
triggerall = (ailevel )&& (roundstate = 2) && (numenemy) 
triggerall = (statetype!=A)
trigger1 =(random<((50)*(ailevel**2/64.0))) &&(ctrl)
trigger1 = inguarddist

[State 0, Guard]
type = ChangeState
triggerall = stateno != [120,155]
triggerall = ailevel > 0 && roundstate = 2 && (numenemy) 
triggerall = (enemynear,hitdefattr = SCA,AT) 
triggerall = (enemynear,movetype = A || enemynear,numproj > 0) && InGuardDist 
trigger1 = ctrl
trigger2 = prevstateno = 5120 && ( random<((700)*(ailevel**2/64.0)) )
value = 120

[State 0, Full Power]
type = ChangeState
triggerall = Var(2) != 4
triggerall = (power >= Cond(Life <= LifeMax/4 && Var(2) < 2,0,1000)) && (statetype != A) && (ailevel > 0 && roundstate = 2)
triggerall = ctrl
Triggerall = Life <= LifeMax/Cond(Var(2) < 2,1.5,Cond(Var(2) = 2,4,2))
trigger1 = enemynear,pos y >= -const(size.height)*3
trigger1 = random < (ailevel * 100)/2
trigger1 = p2bodydist x >= 30
value = Cond(Var(2) < 2,800,Cond(Var(2) = 2,900,50192))

