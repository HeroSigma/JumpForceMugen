;-------------------------------------------------------
; Assists Changer
;-------------------------------------------------------
[StateDef 34365]
Type = S ; Don't Change
MoveType = I ; Don't Change
Physics = S ; Don't Change
VelSet = 0,0 ; Don't Change
Anim = 11 ; Don't Change

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, nothitby] ; Not Be Able To Get Hit In This State
Type = nothitby
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = !Var(2) ; Triggers If Mode ISN'T Active (You can Replace It With A Var If You Want Iso)
Value = Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),Cond(Random >= 500,1300,Cond(Random >= 750,1540,1501)),Cond(P2BodyDist x >= 60,1400,Cond(Random >= 500,1280,1000))) ; Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2) = 2 ; Triggers If Mode Is Active (You can Replace It With A Var If You Want Iso)
Value = Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),27500,Cond(Random >= 500,27000,Cond(Random >= 500,27300,Cond(Random >= 500,4101,27400)))) ; Change This To Whatever Assist You Want (After Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2) = 3 ; Triggers If Mode Is Active (You can Replace It With A Var If You Want Iso)
Value = Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),Cond(Random >= 500,29200,29300),Cond(Random >= 500,29000,29100)) ; Change This To Whatever Assist You Want (After Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2) = 4
Value = Cond((p2bodydist x=[90,-90])&&(p2bodydist y=[-105,-30]),Cond(Random >= 500,51100,51000),51300)
Ctrl = 0

;-----------------------------------------------------------
; Assists Changer 2
;-----------------------------------------------------------
[StateDef 34366] ; Just To Make Sure 2 Cannons Are Placed In Mode
Type = S
MoveType = I
Physics = S
VelSet = 0,0
Anim = 11

[state 0]
type = explod
Trigger1 = !Time
anim = 9999
id = Stateno-1
pos = 0, 0
bindtime = -1
removetime = -1

[State 0, nothitby] ; Not Be Able To Get Hit In This State
Type = nothitby
Trigger1 = 1
Value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Time = 1

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = !Var(2) ; Triggers If Mode ISN'T Active (You can Replace It With A Var If You Want Iso)
Value = Cond((p2bodydist x >= -60)&&(p2bodydist y=[-75,-30]),1400,Cond(Random >= 500,3000,1200)); Change This To Whatever Assist You Want (Before Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2) = 2 ; Triggers If Mode Is Active (You can Replace It With A Var If You Want Iso)
Value = Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),27500,Cond(Random >= 500,27000,Cond(Random >= 500,27300,Cond(Random >= 500,27200,Cond(Random >= 750,3100,Cond(Random >= 500,4101,27400)))))) ; Change This To Whatever Assist You Want (After Mode)
Ctrl = 0

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2) = 3 ; Triggers If Mode sist You Want (After Mode)
Ctrl = 0
Value = Cond((p2bodydist x=[-60,60])&&(p2bodydist y=[-75,-30]),Cond(Random >= 500,29200,29300),Cond(Random >= 850,3200,29500)) ; Change This To Whatever As

[State 0, End]
Type = ChangeState
Triggerall = RoundState = 2
Trigger1 = Var(2) = 4
Value = Cond((p2bodydist x=[90,-90])&&(p2bodydist y=[-105,-30]),Cond(Random >= 500,51100,51000),Cond(Random >= 800,51200,Cond(Random >= 750,51500,Cond(Random >= 800,53100,53000))))
Ctrl = 0

