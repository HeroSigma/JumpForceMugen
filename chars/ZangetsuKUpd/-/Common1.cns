[state ]
type = HitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
ignorehitpause = 1

[state ]
type = HitBy
trigger1 = 1
value2 = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
ignorehitpause = 1

[state ]
