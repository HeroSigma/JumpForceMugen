;===============================================================================
; Esquivar:
;-------------------------------------------------------------------------------
; Start
[Statedef 4]
type    = A
movetype= I
physics = N
anim = 4

[State 0, BindToRoot]
type = BindToRoot
trigger1 = 1
pos = 0,0

[State 0, VarSet]
type = VarSet
trigger1 = root,stateno != 6 && root,time > 10
v = 1
value = 0

[State 0, ReversalDef]
type = ReversalDef
triggerall = var(1) = 0
triggerall = root,movetype != H
trigger1 = random < 15
reversal.attr = SCA,NA,NP,NT
Pausetime = 0,0
sparkno = -1
hitsound = -1
p1stateno = 5
Numhits = 0

[State 200, End]
type = Destroyself
trigger1 = root,life = 0
trigger2 = root,var(9) = 0
