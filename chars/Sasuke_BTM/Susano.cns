triggerall = ifelse(prevstateno = 4002,time > 40,time > 0)
trigger1 = ailevel = 0 && command = "SPECIAL 2"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/2 && p2bodydist x = [100,300]
value = 4600

