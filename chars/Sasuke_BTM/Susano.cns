; Susanoo - Stand
[Statedef 4050]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 4050
sprpriority = 2

[State 0, PowerAdd]
type = PowerAdd
trigger1 = time = 0 && prevstateno = 4002
value = -1500

[State 0, Trans]
type = Trans
trigger1 = 1
trans = add
ignorehitpause = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = Noshadow
ignorehitpause = 1

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 5

[State 0, AngleDraw]
type = AngleDraw
trigger1 = prevstateno != [4050,4999]
scale = .6,.6
value = 0
ignorehitpause = 1

[State 0, AngleDraw]
type = AngleDraw
trigger1 = prevstateno = [4050,4999]
trigger1 = time > 0
scale = .6,.6
value = 0
ignorehitpause = 1

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
y = 0

[State 0, Turn]
type = Turn
triggerall = ifelse(prevstateno = 4002,time > 40,time > 0)
trigger1 = p2bodydist x < -30

; SPECIALS:

[State 0, SPECIAL 1]
type = ChangeState
triggerall = power >= 1500;triggerall = ifelse(prevstateno = 4002,time > 40,time > 0)
trigger1 = ailevel = 0 && command = "SPECIAL 1"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100) && p2bodydist x = [150,250]
value = 4500

[State 0, SPECIAL 2]
