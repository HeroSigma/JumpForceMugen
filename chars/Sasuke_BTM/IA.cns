; Susanoo Charge
[State 0, StopSnd]
type = StopSnd
trigger1 = prevstateno = 4000 && time < 2
channel = 8

[State 0, StopSnd]
type = StopSnd
trigger1 = prevstateno = 4000 && time < 2
channel = 9

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = stateno != 4002
trigger1 = prevstateno = 4000 && time < 2
trigger2 = stateno = 4002 && time > 10
id = 4005
;===============================================================================
; Pared Rota:
;-------------------------------------------------------------------------------
[State 0, Helper]
type = Helper
triggerall = numhelper(1365) = 0
trigger1 = p2stateno = 1361
helpertype = normal
name = "Pared Rota"
ID = 1365
stateno = 1365
pos = 0,-30
postype = p2
facing = 1
keyctrl = 0
ownpal = 1
;===============================================================================
; Air Jump y Limitador Air Jump:
;-------------------------------------------------------------------------------
[State 0, VarSet]
type = VarSet
trigger1 = var(5) = 0 && stateno = 40 && prevstateno = 50
trigger2 = var(5) = 0 && stateno = 40 && prevstateno = [60,70]
v = 5
value = 1

[State 0, VarSet]
type = VarSet
trigger1 = var(5) = 1 && pos y >= 0
v = 5
value = 0

[State 0, Air Jump]
type = ChangeState
triggerall = stateno = 50
triggerall = pos y < -20
triggerall = var(5) = 0
triggerall = time > 10
trigger1 = ailevel = 0 && command = "up"
trigger2 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100) && p2bodydist y < - 30
trigger3 = roundstate = 2 && ailevel > 0 && random < (ailevel * 100)/8
value = 40
ctrl = 1
