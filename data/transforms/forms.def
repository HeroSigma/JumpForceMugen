; This file defines the sequential transformation stages for each character.
; Each section corresponds to a character's name as defined in their .def file.
; formVar     = integer variable number used to store the current stage (global var in all characters)
; healPercent = percentage of max HP restored upon each transformation
; Each numbered entry has the format:
;   stage = stateNumber,HPPercent
;   where 'stateNumber' is the ChangeState value for the transformation
;   and 'HPPercent' is the threshold (0-100) of remaining HP at which the stage activates.

; Goku's internal character name in chars/Goku/Goku.def is "Son Goku".
; Keep both names so the system can match either internal name or display name.
[Goku]
formVar = 50
healPercent = 10
1 = 700,85
2 = 800,70
3 = 900,55
4 = 1900,40
5 = 1901,30
6 = 1903,20
7 = 1906,10

[Son Goku]
formVar = 50
healPercent = 10
1 = 700,85
2 = 800,70
3 = 900,55
4 = 1900,40
5 = 1901,30
6 = 1903,20
7 = 1906,10

; Add additional characters below following the same pattern.
; For example:
; [TC_Luffy_All_Forms]
; formVar = 50
; healPercent = 10
; 1 = 900,80
; 2 = 901,60
; 3 = 5999,40
; 4 = 69999,20
